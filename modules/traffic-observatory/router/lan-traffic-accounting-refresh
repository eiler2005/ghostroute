#!/bin/sh

LAN_OUT_CHAIN="RC_LAN_BYTES_OUT"
LAN_IN_CHAIN="RC_LAN_BYTES_IN"
REALITY_OUT_CHAIN="RC_LAN_REALITY_OUT"
REALITY_IN_CHAIN="RC_LAN_REALITY_IN"
STEALTH_SET="STEALTH_DOMAINS"
STATIC_SET="VPN_STATIC_NETS"
REALITY_CONNMARK="0x5200/0x5200"
GHOSTROUTE_RUNTIME_ENV="${GHOSTROUTE_RUNTIME_ENV:-/jffs/scripts/ghostroute-runtime.env}"
[ -r "$GHOSTROUTE_RUNTIME_ENV" ] && . "$GHOSTROUTE_RUNTIME_ENV"
REDIRECT_PORT="${SINGBOX_REDIRECT_PORT:-${GHOSTROUTE_REDIRECT_PORT:-}}"
[ -n "$REDIRECT_PORT" ] || {
  logger -t lan-traffic-accounting-refresh "SINGBOX_REDIRECT_PORT is not configured"
  exit 0
}
LEASES_FILE="/var/lib/misc/dnsmasq.leases"

ensure_chain() {
  iptables -t mangle -N "$1" 2>/dev/null || true
}

ensure_forward_hook() {
  direction_flag="$1"
  iface="$2"
  chain="$3"
  iptables -t mangle -C FORWARD "$direction_flag" "$iface" -j "$chain" 2>/dev/null || \
    iptables -t mangle -I FORWARD 1 "$direction_flag" "$iface" -j "$chain"
}

ensure_reality_prerouting_hook() {
  set_name="$1"

  # Count the original LAN client bytes before nat REDIRECT changes the
  # destination to the local sing-box listener. The connmark prevents double
  # counting when an IP exists in both STEALTH_DOMAINS and VPN_STATIC_NETS.
  iptables -t mangle -C PREROUTING -i br0 -p tcp -m set --match-set "$set_name" dst -m connmark ! --mark "$REALITY_CONNMARK" -j "$REALITY_OUT_CHAIN" 2>/dev/null || \
    iptables -t mangle -I PREROUTING 1 -i br0 -p tcp -m set --match-set "$set_name" dst -m connmark ! --mark "$REALITY_CONNMARK" -j "$REALITY_OUT_CHAIN"

  iptables -t mangle -C PREROUTING -i br0 -p tcp -m set --match-set "$set_name" dst -m connmark ! --mark "$REALITY_CONNMARK" -j CONNMARK --set-xmark "$REALITY_CONNMARK" 2>/dev/null || \
    iptables -t mangle -I PREROUTING 2 -i br0 -p tcp -m set --match-set "$set_name" dst -m connmark ! --mark "$REALITY_CONNMARK" -j CONNMARK --set-xmark "$REALITY_CONNMARK"
}

ensure_reality_output_hook() {
  # REDIRECT replies leave the router as local TCP responses from the sing-box
  # redirect listener before conntrack restores the original peer tuple.
  iptables -t mangle -D OUTPUT -o br0 -p tcp -m connmark --mark "$REALITY_CONNMARK" -j "$REALITY_IN_CHAIN" 2>/dev/null || true
  iptables -t mangle -C OUTPUT -o br0 -p tcp --sport "$REDIRECT_PORT" -j "$REALITY_IN_CHAIN" 2>/dev/null || \
    iptables -t mangle -I OUTPUT 1 -o br0 -p tcp --sport "$REDIRECT_PORT" -j "$REALITY_IN_CHAIN"
}

ensure_rule() {
  chain="$1"
  shift
  iptables -t mangle -C "$chain" "$@" 2>/dev/null || iptables -t mangle -A "$chain" "$@"
}

ensure_chain "$LAN_OUT_CHAIN"
ensure_chain "$LAN_IN_CHAIN"
ensure_chain "$REALITY_OUT_CHAIN"
ensure_chain "$REALITY_IN_CHAIN"
ensure_forward_hook -i br0 "$LAN_OUT_CHAIN"
ensure_forward_hook -o br0 "$LAN_IN_CHAIN"
ensure_reality_prerouting_hook "$STEALTH_SET"
ensure_reality_prerouting_hook "$STATIC_SET"
ensure_reality_output_hook

[ -f "$LEASES_FILE" ] || exit 0

awk 'NF >= 3 { print $3 }' "$LEASES_FILE" | while IFS= read -r ip; do
  [ -n "$ip" ] || continue

  ensure_rule "$REALITY_OUT_CHAIN" -s "$ip" -j RETURN
  ensure_rule "$REALITY_IN_CHAIN" -d "$ip" -j RETURN

  ensure_rule "$LAN_OUT_CHAIN" -s "$ip" -o wan0 -j RETURN
  ensure_rule "$LAN_OUT_CHAIN" -s "$ip" -j RETURN

  ensure_rule "$LAN_IN_CHAIN" -d "$ip" -i wan0 -j RETURN
  ensure_rule "$LAN_IN_CHAIN" -d "$ip" -j RETURN
done
