#!/bin/bash
# Machine-readable traffic facts for GhostRoute Console.
#
# traffic-facts is the stable machine contract. By default it reads
# traffic-evidence; set GHOSTROUTE_TRAFFIC_FACTS_SOURCE=report for rollback to
# the legacy traffic-report-derived source.

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"

JSON_MODE=0
DEEP_MODE=0
PERIOD_ARG="today"

while [ $# -gt 0 ]; do
  case "$1" in
    --json)
      JSON_MODE=1
      shift
      ;;
    --deep)
      DEEP_MODE=1
      shift
      ;;
    today|current|current-day|yesterday|week|month|[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9])
      PERIOD_ARG="$1"
      shift
      ;;
    *)
      echo "Usage: ./modules/traffic-observatory/bin/traffic-facts --json [today|yesterday|week|month|YYYY-MM-DD] [--deep]" >&2
      exit 1
      ;;
  esac
done

if [ "$JSON_MODE" -ne 1 ]; then
  echo "traffic-facts is a machine-readable command; use --json." >&2
  exit 1
fi

SOURCE_MODE="${GHOSTROUTE_TRAFFIC_FACTS_SOURCE:-evidence}"
START_MS="$(ruby -e 'puts (Time.now.to_f * 1000).to_i')"
TMP_JSON="$(mktemp)"
trap 'rm -f "$TMP_JSON"' EXIT

if [ -n "${GHOSTROUTE_TRAFFIC_FACTS_EVIDENCE_FILE:-}" ]; then
  cat "$GHOSTROUTE_TRAFFIC_FACTS_EVIDENCE_FILE" > "$TMP_JSON"
  SOURCE_MODE="evidence"
elif [ "$SOURCE_MODE" = "report" ]; then
  "${PROJECT_ROOT}/modules/traffic-observatory/bin/traffic-report" --json "$PERIOD_ARG" > "$TMP_JSON"
else
  "${PROJECT_ROOT}/modules/traffic-observatory/bin/traffic-evidence" --json "$PERIOD_ARG" > "$TMP_JSON"
  SOURCE_MODE="evidence"
fi

END_MS="$(ruby -e 'puts (Time.now.to_f * 1000).to_i')"

TRAFFIC_FACTS_PERIOD="$PERIOD_ARG" \
TRAFFIC_FACTS_DEEP="$DEEP_MODE" \
TRAFFIC_FACTS_DURATION_MS="$((END_MS - START_MS))" \
TRAFFIC_FACTS_SOURCE_MODE="$SOURCE_MODE" \
ruby -rjson -rdigest -rtime - "$TMP_JSON" <<'RUBY'
def text(value, fallback = '')
  value.nil? || value.to_s.empty? ? fallback : value.to_s
end

def number(value)
  Integer(value || 0)
rescue ArgumentError, TypeError
  0
end

def iso_time(value, fallback)
  raw = text(value)
  return fallback if raw.empty?
  Time.parse(raw).utc.iso8601(3)
rescue ArgumentError
  fallback
end

def first_present(*values)
  values.find { |value| !value.nil? && value.to_s != '' }
end

def route_from_split(vps, direct, unknown)
  vps = number(vps)
  direct = number(direct)
  unknown = number(unknown)
  return 'Mixed' if [vps > 0, direct > 0, unknown > 0].count(true) > 1
  return 'VPS' if vps > 0
  return 'Direct' if direct > 0
  return 'Unknown' if unknown > 0
  'Unknown'
end

def split_for_route(route, total)
  route = text(route, 'Unknown')
  total = number(total)
  case route.downcase
  when 'vps'
    [total, total, 0, 0]
  when 'direct'
    [total, 0, total, 0]
  else
    [total, 0, 0, total]
  end
end

def split_for_verification(route_verification, total)
  total = number(total)
  case text(route_verification).downcase
  when 'verified_vps'
    [total, total, 0, 0]
  when 'verified_direct'
    [total, 0, total, 0]
  else
    [total, 0, 0, total]
  end
end

def split_for_counter_allocation(total, allocation)
  total = number(total)
  vps_counter = number(allocation && allocation['vpn_bytes'])
  direct_counter = number(allocation && allocation['direct_bytes'])
  other_counter = number(allocation && allocation['other_bytes'])
  counter_total = vps_counter + direct_counter + other_counter
  return [total, 0, 0, total] if total <= 0 || counter_total <= 0 || vps_counter + direct_counter <= 0
  vps = (total * vps_counter / counter_total.to_f).floor
  direct = (total * direct_counter / counter_total.to_f).floor
  unknown = total - vps - direct
  [total, vps, direct, unknown]
end

def split_for_route_allocation(total, allocation)
  split_for_counter_allocation(total, allocation)
end

def explicit_outbound(row)
  text(first_present(row['outbound'], row['sing_box_outbound'], row['egress_outbound'], row['actual_outbound']))
end

def outbound_route(outbound)
  value = text(outbound).downcase
  return 'VPS' if value.match?(/reality|proxy|vps|tunnel|sing-box/)
  return 'Direct' if value.match?(/direct|wan|bypass/)
  ''
end

def route_intent?(row)
  source = text(row['route_source']).downcase
  basis = text(row['route_basis']).downcase
  return false if source.empty? || source == 'none'
  return false if basis == 'no_ipset'
  text(row['matched_ipset']) != '' || %w[ipset policy fwmark route_lookup].include?(source)
end

def intended_route_for(row)
  route = text(row['route'], 'Unknown')
  return route if %w[VPS Direct].include?(route)
  'Unknown'
end

def route_verification_for(row)
  route = text(row['route'], 'Unknown')
  outbound = explicit_outbound(row)
  observed_route = outbound_route(outbound)
  has_intent = route_intent?(row)

  if observed_route != ''
    return 'mismatch' if !route.casecmp('Unknown').zero? && !route.casecmp(observed_route).zero?
    return observed_route == 'VPS' ? 'verified_vps' : 'verified_direct'
  end

  return 'intent_only' if has_intent
  'unknown'
end

def route_status_for(route_verification)
  case text(route_verification)
  when 'verified_vps', 'verified_direct'
    'verified'
  when 'counter_allocated', 'ingress_route_allocated'
    'counter_allocated'
  when 'intent_only'
    'intent_only'
  when 'mismatch'
    'mismatch'
  else
    'unknown'
  end
end

def enforce_split(total, vps, direct, unknown)
  total = number(total)
  vps = number(vps)
  direct = number(direct)
  unknown = number(unknown)
  return [total, vps, direct, unknown, false] if total == vps + direct + unknown
  [total, 0, 0, total, true]
end

def accounting_status_for(corrected)
  return 'accounting_error' if corrected
  'ok'
end

def dns_ts_source_for(row)
  text(row['dns_ts_source'] || row['ts_source'], 'snapshot_approx')
end

def dns_status_for(link_type, confidence, ts_source)
  return 'no_match' if confidence == 'no_dns_match'
  return 'shared' if link_type == 'shared_answer'
  return 'approximate_ts' if ts_source == 'snapshot_approx'
  confidence.to_s.empty? ? 'no_match' : 'exact'
end

def traffic_class_for(destination)
  value = text(destination).downcase
  return 'personal_cloud' if value.match?(/icloud|google (drive|photos)|photos\.google|drive\.google|dropbox|onedrive|sharepoint|backup/)
  return 'service_background' if value.match?(/dns|resolver|ocsp|crash|analytics|app-measurement|connectivity|gvt|gstatic|ntp|telemetry|push\.apple|itunes|mzstatic|cloudfront|akamai|fastly|cloudflare/)
  return 'unclassified' if value.empty? || value.include?('unknown/unattributed') || value == 'other/ip'
  'client'
end

def client_key(row)
  text(first_present(row['client_key'], row['device_key'], row['profile'], row['client'], row['label'], row['client_ip'], row['ip']), 'unknown-client')
end

def client_label(row)
  text(first_present(row['client_label'], row['client'], row['label'], row['profile'], row['observed_label'], row['client_ip'], row['ip']), 'Unknown client')
end

def fact_hash(*parts)
  Digest::SHA256.hexdigest(parts.flatten.map { |part| text(part) }.join('|'))[0, 24]
end

def dns_answer_rows(evidence)
  (evidence['dns_queries'] || []).select { |row| row.is_a?(Hash) && text(row['answer_ip']) != '' }
end

def dns_link_for(sample, answers, generated_at, window_seconds)
  sample_ip = text(sample['remote_ip'] || sample['destination_ip'])
  sample_client = text(sample['client_ip'])
  sample_ts = Time.parse(iso_time(sample['ts'] || sample['event_ts'], generated_at)) rescue Time.parse(generated_at)
  candidates = answers.map do |row|
    next unless text(row['answer_ip']) == sample_ip
    dns_client = text(row['client_ip'])
    next if dns_client != '' && sample_client != '' && dns_client != sample_client
    dns_ts = Time.parse(iso_time(row['ts'], generated_at)) rescue nil
    next unless dns_ts
    age = sample_ts - dns_ts
    next if age.negative? || age > window_seconds
    [dns_client != '' && dns_client == sample_client ? 0 : 1, age, row]
  end.compact
  return [{}, 'no_dns_match', 'no_dns_match', ''] if candidates.empty?

  domains = candidates.map { |candidate| text(candidate[2]['domain']) }.reject(&:empty?).uniq.sort
  ranked = candidates.sort_by { |rank| [rank[0], rank[1]] }
  best = ranked.first
  row = best[2]
  age = best[1]
  client_match = best[0] == 0
  ts_source = dns_ts_source_for(row)
  if domains.length > 1
    link_type = 'shared_answer'
    confidence = 'low'
    domain = ''
  else
    link_type = client_match ? 'exact_client_ip' : 'recent_answer'
    confidence = client_match ? 'high' : 'medium'
    confidence = 'medium' if confidence == 'high' && ts_source == 'snapshot_approx'
    domain = text(row['domain'])
  end
  link = {
    'id' => fact_hash('dns-link', sample['sample_id'], row['id'], sample_ip),
    'collected_at_utc' => generated_at,
    'client_key' => text(sample['client_key'] || sample_client),
    'client_ip' => sample_client,
    'domain' => domain,
    'destination' => sample_ip,
    'destination_ip' => sample_ip,
    'destination_port' => text(sample['remote_port'] || sample['destination_port']),
    'protocol' => text(sample['proto'] || sample['protocol']),
    'dns_answer_ip' => sample_ip,
    'dns_event_ts_utc' => iso_time(row['ts'], generated_at),
    'dns_ts_source' => ts_source,
    'flow_event_ts_utc' => iso_time(sample['ts'] || sample['event_ts'], generated_at),
    'link_type' => link_type,
    'confidence' => confidence,
    'evidence_json' => JSON.generate({ 'dns_query' => row, 'candidate_domains' => domains, 'sample_id' => sample['sample_id'], 'age_seconds' => age })
  }
  [link, link_type, confidence, ts_source]
end

def lan_route_allocations(input)
  allocations = Hash.new { |hash, key| hash[key] = { 'vpn_bytes' => 0, 'direct_bytes' => 0, 'other_bytes' => 0, 'total_bytes' => 0, 'samples' => [] } }
  (input['lan_device_route_deltas'] || []).each do |row|
    next unless row.is_a?(Hash)
    keys = [text(row['client_key']), text(row['client_ip'])].reject(&:empty?).uniq
    next if keys.empty?
    payload = {
      'vpn_bytes' => number(row['vpn_bytes']),
      'direct_bytes' => number(row['direct_bytes']),
      'other_bytes' => number(row['other_bytes']),
      'total_bytes' => number(row['total_bytes']),
      'sample_id' => text(row['sample_id']),
      'ts' => text(row['ts'])
    }
    keys.each do |key|
      allocations[key]['vpn_bytes'] += payload['vpn_bytes']
      allocations[key]['direct_bytes'] += payload['direct_bytes']
      allocations[key]['other_bytes'] += payload['other_bytes']
      allocations[key]['total_bytes'] += payload['total_bytes']
      allocations[key]['samples'] << payload if allocations[key]['samples'].length < 12
    end
  end
  allocations
end

def allocation_for_sample(sample, allocations)
  [text(sample['client_key']), text(sample['client_ip'])].each do |key|
    next if key.empty?
    allocation = allocations[key]
    return allocation if allocation && number(allocation['vpn_bytes']) + number(allocation['direct_bytes']) > 0
  end
  nil
end

def ingress_channel_for_inbound(inbound)
  case text(inbound)
  when 'reality-in'
    'A/Home Reality'
  when 'channel-b-relay-socks'
    'Channel B'
  when 'channel-c-shadowrocket-http-in'
    'Channel C'
  when 'channel-c-naive-in'
    'Channel C'
  else
    ''
  end
end

def ingress_route_allocations(input)
  allocations = Hash.new { |hash, key| hash[key] = { 'vpn_bytes' => 0, 'direct_bytes' => 0, 'other_bytes' => 0, 'total_bytes' => 0, 'samples' => [], 'basis' => 'ingress_outbound_mix' } }
  (input['sing_box_route_evidence'] || []).each do |row|
    next unless row.is_a?(Hash)
    inbound = text(row['inbound'])
    channel = ingress_channel_for_inbound(inbound)
    next if channel.empty?
    route = text(row['route'])
    unit = 1
    keys = [channel]
    profile = text(row['profile'])
    keys << "#{channel}|#{profile}" unless profile.empty?
    payload = {
      'vpn_bytes' => route == 'VPS' ? unit : 0,
      'direct_bytes' => route == 'Direct' ? unit : 0,
      'other_bytes' => %w[VPS Direct].include?(route) ? 0 : unit,
      'total_bytes' => unit,
      'sample_id' => text(row['id']),
      'ts' => text(row['ts']),
      'inbound' => inbound,
      'profile' => profile
    }
    keys.uniq.each do |key|
      allocations[key]['vpn_bytes'] += payload['vpn_bytes']
      allocations[key]['direct_bytes'] += payload['direct_bytes']
      allocations[key]['other_bytes'] += payload['other_bytes']
      allocations[key]['total_bytes'] += payload['total_bytes']
      allocations[key]['samples'] << payload if allocations[key]['samples'].length < 12
    end
  end
  allocations
end

def ip_literal?(value)
  candidate = text(value).strip.downcase
  return true if candidate.match?(/\A(\d{1,3}\.){3}\d{1,3}\z/)
  candidate.include?(':') && candidate.match?(/\A[0-9a-f:.]+\z/i)
end

def strip_destination_port(value, port)
  candidate = text(value).strip
  port = text(port).strip
  return candidate if candidate.empty? || port.empty?
  if candidate.start_with?('[')
    close = candidate.index(']')
    return candidate[1...close] if close && candidate[(close + 1)..] == ":#{port}"
  end
  if candidate.count(':') == 1 && candidate.end_with?(":#{port}")
    return candidate[0...(candidate.length - port.length - 1)]
  end
  candidate
end

def ingress_destination_for(row)
  host = text(row['destination_host']).strip
  destination = host.empty? ? strip_destination_port(row['destination'], row['destination_port']) : host
  destination = destination.sub(/\A\[/, '').sub(/\]\z/, '').sub(/\.\z/, '').strip
  return '' if destination.empty?
  lower = destination.downcase
  return '' if %w[unknown unknown-destination n/a not-observed home-reality-ingress].include?(lower.tr(' ', '-'))
  ip_literal?(destination) ? destination : lower
end

def ingress_destination_allocations(input)
  allocations = Hash.new { |hash, key| hash[key] = { 'total_units' => 0, 'groups' => {}, 'basis' => 'home_reality_connection_share' } }
  (input['sing_box_route_evidence'] || []).each do |row|
    next unless row.is_a?(Hash)
    channel = ingress_channel_for_inbound(row['inbound'])
    next if channel.empty?
    profile = text(row['profile'])
    keys = []
    keys << "#{channel}|#{profile}" unless profile.empty?
    keys << channel if profile.empty?
    next if keys.empty?
    destination = ingress_destination_for(row)
    next if destination.empty?
    route = text(row['route'], 'Unknown')
    route = 'Unknown' unless %w[VPS Direct].include?(route)
    outbound = text(row['outbound'])
    port = text(row['destination_port'])
    kind = ip_literal?(destination) ? 'ip' : 'domain'
    group_key = [route, outbound, destination, port].join('|')
    keys.uniq.each do |key|
      group = allocations[key]['groups'][group_key] ||= {
        'destination' => destination,
        'destination_kind' => kind,
        'destination_port' => port,
        'route' => route,
        'outbound' => outbound,
        'units' => 0,
        'samples' => []
      }
      group['units'] += 1
      group['samples'] << {
        'sample_id' => text(row['id']),
        'ts' => text(row['ts']),
        'connection_id' => text(row['connection_id'])
      } if group['samples'].length < 8
      allocations[key]['total_units'] += 1
    end
  end
  allocations
end

def allocation_for_ingress_sample(sample, allocations)
  channel = text(sample['channel'])
  label = text(sample['client_label'], text(sample['client_key']))
  [channel.empty? ? '' : "#{channel}|#{label}", channel].each do |key|
    next if key.empty?
    allocation = allocations[key]
    return allocation if allocation && number(allocation['vpn_bytes']) + number(allocation['direct_bytes']) > 0
  end
  nil
end

def destination_allocation_for_ingress_sample(sample, allocations)
  channel = text(sample['channel'])
  label = text(sample['client_label'], text(sample['client_key']))
  profile_key = channel.empty? || label.empty? ? '' : "#{channel}|#{label}"
  allocation = allocations[profile_key]
  return allocation if allocation && number(allocation['total_units']) > 0
  return nil unless label.empty?
  allocation = allocations[channel]
  return allocation if allocation && number(allocation['total_units']) > 0
  nil
end

def proportional_group_allocations(groups, totals)
  groups = groups.sort_by { |group| [-number(group['units']), text(group['destination']), text(group['route']), text(group['outbound'])] }
  unit_total = groups.sum { |group| number(group['units']) }
  remaining = totals.transform_values { |value| number(value) }
  groups.each_with_index.map do |group, index|
    last = index == groups.length - 1
    allocated = {}
    remaining.each_key do |field|
      value = last ? remaining[field] : (number(totals[field]) * number(group['units']) / unit_total.to_f).floor
      allocated[field] = value
      remaining[field] -= value
    end
    group.merge(allocated)
  end
end

def route_candidates_for(sample, dns_link)
  [
    text(dns_link['domain']),
    text(sample['dns_qname']),
    text(sample['sni']),
    text(sample['remote_ip']),
    text(sample['destination_ip'])
  ].reject(&:empty?).uniq
end

def sing_box_route_for(sample, dns_link, evidence_rows, generated_at, window_seconds)
  candidates = route_candidates_for(sample, dns_link).map(&:downcase)
  return nil if candidates.empty?
  sample_ts = Time.parse(iso_time(sample['ts'] || sample['event_ts'], generated_at)) rescue Time.parse(generated_at)
  matches = evidence_rows.map do |row|
    next unless row.is_a?(Hash)
    destination_values = [row['destination'], row['destination_host']].map { |value| text(value).downcase }.reject(&:empty?)
    next if (destination_values & candidates).empty?
    evidence_ts = Time.parse(iso_time(row['ts'], generated_at)) rescue nil
    next unless evidence_ts
    age = (sample_ts - evidence_ts).abs
    next if age > window_seconds
    [age, row]
  end.compact
  matches.sort_by(&:first).first&.last
end

def verification_with_evidence(sample, dns_link, sing_box_evidence, allocation, generated_at, window_seconds)
  log_row = sing_box_route_for(sample, dns_link, sing_box_evidence, generated_at, window_seconds)
  observed_route = outbound_route(log_row && log_row['outbound'])
  route = text(sample['route'], 'Unknown')
  if observed_route != ''
    verification = (!route.casecmp('Unknown').zero? && !route.casecmp(observed_route).zero?) ? 'mismatch' : (observed_route == 'VPS' ? 'verified_vps' : 'verified_direct')
    return [verification, log_row]
  end
  base = route_verification_for(sample)
  if %w[unknown intent_only].include?(base) && allocation && number(allocation['vpn_bytes']) + number(allocation['direct_bytes']) > 0
    return ['counter_allocated', nil]
  end
  [base, nil]
end

def report_rows(report)
  rows = []
  %w[app_flows destinations].each do |key|
    next unless report[key].is_a?(Array)
    report[key].each { |row| rows << [key, row] if row.is_a?(Hash) }
  end
  if rows.empty? && report['route_events'].is_a?(Array)
    report['route_events'].each { |row| rows << ['route_events', row] if row.is_a?(Hash) }
  end
  rows
end

input = JSON.parse(File.read(ARGV.fetch(0)))
period = ENV.fetch('TRAFFIC_FACTS_PERIOD', 'today')
duration_ms = number(ENV['TRAFFIC_FACTS_DURATION_MS'])
deep = ENV.fetch('TRAFFIC_FACTS_DEEP', '0') == '1'
source_mode = ENV.fetch('TRAFFIC_FACTS_SOURCE_MODE', 'evidence')
source_command = source_mode == 'report' ? 'traffic-report' : 'traffic-evidence'
generated_at = iso_time(input['generated_at'], Time.now.utc.iso8601(3))
window = input['window'].is_a?(Hash) ? input['window'] : { 'period' => period }
facts = []
dns_links = []
gaps = []
clients = {}
warnings = []

if source_mode == 'report'
  report_rows(input).each_with_index do |(source_name, row), index|
    total = number(row['bytes'] || row['total_bytes'] || row['observed_bytes'])
    vps = number(row['via_vps_bytes'] || row['reality_bytes'])
    direct = number(row['direct_bytes'] || row['wan_bytes'])
    unknown = number(row['unknown_bytes'] || row['unresolved_bytes'])
    if total <= 0
      total = vps + direct + unknown
    elsif vps + direct + unknown == 0
      total, vps, direct, unknown = split_for_route(row['route'] || row['route_decision'], total)
    else
      unknown = [total - vps - direct, 0].max
    end
    next if total <= 0 && number(row['connections'] || row['total_connections']) <= 0
    destination = text(first_present(row['destination'], row['domain'], row['dns_qname'], row['sni'], row['app'], row['family'], row['destination_ip']), 'unknown destination')
    key = client_key(row)
    event_ts = iso_time(first_present(row['display_ts_utc'], row['event_ts_utc'], row['ts'], row['timestamp']), generated_at)
    fact = {
      'fact_id' => fact_hash('report', source_name, index, generated_at, key, destination, total),
      'sample_id' => '',
      'event_ts' => event_ts,
      'event_ts_utc' => event_ts,
      'observed_at_utc' => event_ts,
      'display_ts_utc' => event_ts,
      'time_precision' => text(row['time_precision'] || row['ts_precision'], 'collector_ms'),
      'client_key' => key,
      'client_label' => client_label(row),
      'client_ip' => text(row['client_ip'] || row['ip']),
      'channel' => text(row['channel'], 'Unknown'),
      'route' => route_from_split(vps, direct, unknown),
      'intended_route' => text(row['intended_route'], route_from_split(vps, direct, unknown)),
      'route_verification' => 'legacy_report',
      'route_status' => 'unknown',
      'route_source' => 'traffic-report',
      'route_basis' => 'reported_summary',
      'matched_ipset' => '',
      'egress_iface' => '',
      'fwmark' => '',
      'traffic_class' => text(row['traffic_class'], traffic_class_for(destination)),
      'destination' => destination,
      'destination_kind' => text(row['destination_kind'] || row['destination_class'], text(row['destination_ip']).empty? ? 'domain' : 'ip'),
      'destination_ip' => text(row['destination_ip']),
      'destination_port' => text(row['destination_port'] || row['port']),
      'protocol' => text(row['protocol']),
      'dns_qname' => text(row['dns_qname'] || row['qname'] || row['domain']),
      'dns_answer_ip' => text(row['dns_answer_ip'] || row['answer_ip']),
      'dns_link_id' => '',
      'dns_link_confidence' => '',
      'dns_status' => '',
      'dns_ts_source' => '',
      'sni' => text(row['sni']),
      'policy' => text(row['policy']),
      'matched_rule' => text(row['matched_rule'] || row['rule'] || row['rule_name']),
      'outbound' => text(row['sing_box_outbound'] || row['outbound']),
      'bytes' => total,
      'bytes_up' => number(row['bytes_up'] || row['out_bytes']),
      'bytes_down' => number(row['bytes_down'] || row['in_bytes']),
      'via_vps_bytes' => vps,
      'direct_bytes' => direct,
      'unknown_bytes' => unknown,
      'connections' => number(row['connections'] || row['total_connections']),
      'identity_confidence' => text(row['identity_confidence'] || row['confidence'], 'estimated'),
      'byte_confidence' => text(row['byte_confidence'] || row['confidence'], 'estimated'),
      'destination_confidence' => text(row['destination_confidence'] || row['confidence'], 'unknown'),
      'confidence' => text(row['confidence'], 'estimated'),
      'accounting_status' => 'ok',
      'allocation_basis' => text(row['allocation_basis'], 'reported_summary'),
      'evidence_level' => text(row['evidence_level'], 'legacy_report'),
      'sources' => ["traffic-report #{source_name}"],
      'evidence_json' => JSON.generate(row)
    }
    facts << fact
  end
else
  answers = dns_answer_rows(input)
  route_allocations = lan_route_allocations(input)
  ingress_allocations = ingress_route_allocations(input)
  ingress_destination_groups = ingress_destination_allocations(input)
  sing_box_evidence = (input['sing_box_route_evidence'] || []).select { |row| row.is_a?(Hash) }
  window_seconds = [1, number(ENV['GHOSTROUTE_DNS_LINK_WINDOW_SECONDS'] || 600)].max
  (input['warnings'] || []).each { |warning| warnings << warning if warning.is_a?(Hash) }
  (input['flow_samples'] || []).each_with_index do |sample, index|
    next unless sample.is_a?(Hash)
    total = number(sample['total_bytes'])
    next if total <= 0 && number(sample['connections']) <= 0
    dns_link, link_type, link_confidence, dns_ts_source = dns_link_for(sample, answers, generated_at, window_seconds)
    dns_links << dns_link unless dns_link.empty?
    dns_status = dns_status_for(link_type, link_confidence, dns_ts_source)
    destination = text(dns_link['domain'], text(sample['remote_ip'], 'unknown destination'))
    destination_kind = dns_link.empty? ? 'ip' : 'domain'
    destination_confidence = dns_link.empty? ? 'ip_only' : "dns_#{link_confidence}"
    allocation = allocation_for_sample(sample, route_allocations)
    route_verification, log_route_evidence = verification_with_evidence(sample, dns_link, sing_box_evidence, allocation, generated_at, window_seconds)
    route_status = route_status_for(route_verification)
    total, vps, direct, unknown = route_verification == 'counter_allocated' ? split_for_counter_allocation(total, allocation) : split_for_verification(route_verification, total)
    total, vps, direct, unknown, corrected_split = enforce_split(total, vps, direct, unknown)
    event_ts = iso_time(sample['ts'], generated_at)
    key = text(sample['client_key'], text(sample['client_ip'], 'unknown-client'))
    fact = {
      'fact_id' => fact_hash('evidence', sample['sample_id'], event_ts, key, sample['remote_ip'], total),
      'sample_id' => text(sample['sample_id']),
      'event_ts' => event_ts,
      'event_ts_utc' => event_ts,
      'observed_at_utc' => event_ts,
      'display_ts_utc' => event_ts,
      'time_precision' => 'second',
      'client_key' => key,
      'client_label' => key,
      'client_ip' => text(sample['client_ip']),
      'channel' => 'Home Wi-Fi/LAN',
      'route' => route_from_split(vps, direct, unknown),
      'intended_route' => intended_route_for(sample),
      'route_verification' => route_verification,
      'route_status' => route_status,
      'route_source' => text(sample['route_source']),
      'route_basis' => text(sample['route_basis']),
      'matched_ipset' => text(sample['matched_ipset']),
      'egress_iface' => text(sample['egress_iface']),
      'fwmark' => text(sample['fwmark']),
      'traffic_class' => traffic_class_for(destination),
      'destination' => destination,
      'destination_kind' => destination_kind,
      'destination_ip' => text(sample['remote_ip']),
      'destination_port' => text(sample['remote_port']),
      'protocol' => text(sample['proto']),
      'dns_qname' => text(dns_link['domain']),
      'dns_answer_ip' => text(dns_link['dns_answer_ip']),
      'dns_link_id' => text(dns_link['id']),
      'dns_link_confidence' => link_confidence,
      'dns_status' => dns_status,
      'dns_ts_source' => dns_ts_source,
      'sni' => '',
      'policy' => text(sample['matched_ipset']),
      'matched_rule' => text(sample['matched_ipset']),
      'outbound' => text(explicit_outbound(sample), text(log_route_evidence && log_route_evidence['outbound'])),
      'bytes' => total,
      'bytes_up' => number(sample['out_bytes']),
      'bytes_down' => number(sample['in_bytes']),
      'via_vps_bytes' => vps,
      'direct_bytes' => direct,
      'unknown_bytes' => unknown,
      'connections' => number(sample['connections']),
      'identity_confidence' => text(sample['client_ip']).empty? ? 'unknown' : 'client_ip',
      'byte_confidence' => 'observed',
      'destination_confidence' => destination_confidence,
      'confidence' => 'observed',
      'accounting_status' => accounting_status_for(corrected_split),
      'allocation_basis' => text(sample['allocation_basis'], 'observed_delta'),
      'evidence_level' => 'flow_sample',
      'sources' => ['traffic-evidence', text(sample['source'], 'lan-flow-facts')],
      'evidence_json' => JSON.generate({
        'sample' => sample,
        'dns_link_type' => link_type,
        'accounting_corrected' => corrected_split,
        'route_allocation' => route_verification == 'counter_allocated' ? allocation : nil,
        'route_allocation_basis' => route_verification == 'counter_allocated' ? 'client_counter_delta' : '',
        'sing_box_route_evidence' => log_route_evidence
      })
    }
    if corrected_split
      warnings << { 'code' => 'accounting_split_corrected', 'sample_id' => text(sample['sample_id']), 'message' => 'byte split was corrected to unknown_bytes to preserve invariant' }
    end
    facts << fact
  end
  (input['home_reality_samples'] || []).each do |sample|
    next unless sample.is_a?(Hash)
    total = number(sample['total_bytes'])
    next if total <= 0
    event_ts = iso_time(sample['ts'], generated_at)
    key = text(sample['client_key'], text(sample['client_label'], text(sample['source_ip'], 'unknown-home-reality-profile')))
    label = text(sample['client_label'], key)
    allocation = allocation_for_ingress_sample(sample, ingress_allocations)
    route_verification = allocation ? 'ingress_route_allocated' : 'unknown'
    route_status = route_status_for(route_verification)
    total, vps, direct, unknown = route_verification == 'ingress_route_allocated' ? split_for_route_allocation(total, allocation) : split_for_verification(route_verification, total)
    total, vps, direct, unknown, corrected_split = enforce_split(total, vps, direct, unknown)
    destination_allocation = destination_allocation_for_ingress_sample(sample, ingress_destination_groups)
    if destination_allocation && number(destination_allocation['total_units']) > 0
      groups = proportional_group_allocations(destination_allocation['groups'].values, {
        'bytes' => total,
        'bytes_up' => number(sample['bytes_up']),
        'bytes_down' => number(sample['bytes_down'])
      })
      groups.each_with_index do |group, group_index|
        allocated_bytes = number(group['bytes'])
        next if allocated_bytes <= 0
        allocated_total, allocated_vps, allocated_direct, allocated_unknown = split_for_route(group['route'], allocated_bytes)
        allocated_total, allocated_vps, allocated_direct, allocated_unknown, allocated_corrected = enforce_split(allocated_total, allocated_vps, allocated_direct, allocated_unknown)
        destination = text(group['destination'])
        destination_kind = text(group['destination_kind'], ip_literal?(destination) ? 'ip' : 'domain')
        fact_id = fact_hash('home-reality-destination', sample['sample_id'], event_ts, key, destination, group['route'], group_index, allocated_total)
        facts << {
          'fact_id' => fact_id,
          'flow_group_key' => fact_id,
          'sample_id' => text(sample['sample_id']),
          'event_ts' => event_ts,
          'event_ts_utc' => event_ts,
          'observed_at_utc' => event_ts,
          'display_ts_utc' => event_ts,
          'time_precision' => 'second',
          'client_key' => key,
          'client_label' => label,
          'client_ip' => text(sample['source_ip']),
          'channel' => text(sample['channel'], 'A/Home Reality'),
          'route' => route_from_split(allocated_vps, allocated_direct, allocated_unknown),
          'intended_route' => 'Unknown',
          'route_verification' => 'ingress_route_allocated',
          'route_status' => route_status_for('ingress_route_allocated'),
          'route_source' => 'sing-box',
          'route_basis' => 'home_reality_connection_share',
          'matched_ipset' => '',
          'egress_iface' => '',
          'fwmark' => '',
          'traffic_class' => traffic_class_for(destination),
          'destination' => destination,
          'destination_kind' => destination_kind,
          'destination_ip' => destination_kind == 'ip' ? destination : '',
          'destination_port' => text(group['destination_port']),
          'protocol' => 'tcp',
          'dns_qname' => '',
          'dns_answer_ip' => '',
          'dns_link_id' => '',
          'dns_link_confidence' => 'no_dns_match',
          'dns_status' => 'no_match',
          'dns_ts_source' => '',
          'sni' => '',
          'policy' => '',
          'matched_rule' => '',
          'outbound' => text(group['outbound']),
          'bytes' => allocated_total,
          'bytes_up' => number(group['bytes_up']),
          'bytes_down' => number(group['bytes_down']),
          'via_vps_bytes' => allocated_vps,
          'direct_bytes' => allocated_direct,
          'unknown_bytes' => allocated_unknown,
          'connections' => number(group['units']),
          'identity_confidence' => text(sample['client_label']).empty? ? 'source_ip' : 'profile',
          'byte_confidence' => 'estimated_connection_share',
          'destination_confidence' => 'sing_box_destination',
          'confidence' => 'estimated',
          'accounting_status' => accounting_status_for(corrected_split || allocated_corrected),
          'allocation_basis' => 'home_reality_connection_share',
          'evidence_level' => 'home_reality_sing_box_destination_estimate',
          'sources' => ['traffic-evidence', text(sample['source'], 'mobile-reality-counters'), 'sing-box-route-evidence'],
          'evidence_json' => JSON.generate({
            'sample' => sample,
            'route_allocation' => allocation,
            'destination_allocation' => {
              'basis' => 'home_reality_connection_share',
              'total_units' => number(destination_allocation['total_units']),
              'group_units' => number(group['units']),
              'samples' => group['samples']
            },
            'route_allocation_basis' => allocation ? 'ingress_outbound_mix' : '',
            'accounting_corrected' => corrected_split || allocated_corrected
          })
        }
      end
      next
    end
    fact = {
      'fact_id' => fact_hash('home-reality', sample['sample_id'], event_ts, key, total),
      'flow_group_key' => fact_hash('home-reality', sample['sample_id'], event_ts, key, total),
      'sample_id' => text(sample['sample_id']),
      'event_ts' => event_ts,
      'event_ts_utc' => event_ts,
      'observed_at_utc' => event_ts,
      'display_ts_utc' => event_ts,
      'time_precision' => 'second',
      'client_key' => key,
      'client_label' => label,
      'client_ip' => text(sample['source_ip']),
      'channel' => text(sample['channel'], 'A/Home Reality'),
      'route' => route_from_split(vps, direct, unknown),
      'intended_route' => 'Unknown',
      'route_verification' => route_verification,
      'route_status' => route_status,
      'route_source' => allocation ? 'sing-box' : '',
      'route_basis' => allocation ? 'ingress_outbound_mix' : '',
      'matched_ipset' => '',
      'egress_iface' => '',
      'fwmark' => '',
      'traffic_class' => 'client',
      'destination' => 'Home Reality ingress',
      'destination_kind' => 'encrypted_ingress',
      'destination_ip' => '',
      'destination_port' => '',
      'protocol' => 'tcp',
      'dns_qname' => '',
      'dns_answer_ip' => '',
      'dns_link_id' => '',
      'dns_link_confidence' => 'no_dns_match',
      'dns_status' => 'no_match',
      'dns_ts_source' => '',
      'sni' => '',
      'policy' => '',
      'matched_rule' => '',
      'outbound' => '',
      'bytes' => total,
      'bytes_up' => number(sample['bytes_up']),
      'bytes_down' => number(sample['bytes_down']),
      'via_vps_bytes' => vps,
      'direct_bytes' => direct,
      'unknown_bytes' => unknown,
      'connections' => 0,
      'identity_confidence' => text(sample['client_label']).empty? ? 'source_ip' : 'profile',
      'byte_confidence' => 'observed_delta',
      'destination_confidence' => 'none',
      'confidence' => 'observed',
      'accounting_status' => accounting_status_for(corrected_split),
      'allocation_basis' => text(sample['allocation_basis'], 'observed_profile_counter_delta'),
      'evidence_level' => 'home_reality_profile_counter',
      'sources' => ['traffic-evidence', text(sample['source'], 'mobile-reality-counters')],
      'evidence_json' => JSON.generate({
        'sample' => sample,
        'route_allocation' => allocation,
        'route_allocation_basis' => allocation ? 'ingress_outbound_mix' : ''
      })
    }
    facts << fact
  end
end

facts.each do |fact|
  key = fact['client_key']
  clients[key] ||= {
    'client_key' => key,
    'client_label' => fact['client_label'],
    'client_ip' => fact['client_ip'],
    'hostname' => '',
    'mac_hash' => '',
    'channel' => fact['channel'],
    'route' => 'Unknown',
    'traffic_class' => fact['traffic_class'],
    'total_bytes' => 0,
    'via_vps_bytes' => 0,
    'direct_bytes' => 0,
    'unknown_bytes' => 0,
    'identity_confidence' => fact['identity_confidence'],
    'sources' => []
  }
  clients[key]['total_bytes'] += number(fact['bytes'])
  clients[key]['via_vps_bytes'] += number(fact['via_vps_bytes'])
  clients[key]['direct_bytes'] += number(fact['direct_bytes'])
  clients[key]['unknown_bytes'] += number(fact['unknown_bytes'])
  clients[key]['sources'] = (clients[key]['sources'] + (fact['sources'] || [])).uniq
  clients[key]['route'] = route_from_split(clients[key]['via_vps_bytes'], clients[key]['direct_bytes'], clients[key]['unknown_bytes'])
end

coverage = {
  'scope' => 'traffic_facts',
  'traffic_fact_bytes' => facts.sum { |row| number(row['bytes']) },
  'gap_bytes' => gaps.sum { |row| number(row['bytes']) },
  'facts' => facts.length,
  'gaps' => gaps.length,
  'dns_links' => dns_links.length
}

output = {
  'schema_version' => 3,
  'generated_at' => generated_at,
  'window' => window,
  'source' => {
    'command' => 'traffic-facts',
    'period' => period,
    'source_report' => source_command,
    'schema' => 'traffic-facts-v3',
    'deep' => deep
  },
  'collector_metrics' => {
    'duration_ms' => duration_ms,
    'source_command_timings' => { source_command => duration_ms },
      'source_row_counts' => {
      'flow_samples' => (input['flow_samples'] || []).length,
      'lan_device_route_deltas' => (input['lan_device_route_deltas'] || []).length,
      'sing_box_route_evidence' => (input['sing_box_route_evidence'] || []).length,
      'home_reality_samples' => (input['home_reality_samples'] || []).length,
      'dns_queries' => (input['dns_queries'] || []).length,
      'traffic_facts' => facts.length,
      'attribution_gaps' => gaps.length,
      'dns_links' => dns_links.length
    },
    'deep' => deep,
    'warnings' => warnings
  },
  'confidence' => facts.empty? ? 'unknown' : 'mixed',
  'clients' => clients.values,
  'traffic_facts' => facts,
  'dns_links' => dns_links,
  'attribution_gaps' => gaps,
  'coverage' => coverage
}

puts JSON.pretty_generate(output)
RUBY
