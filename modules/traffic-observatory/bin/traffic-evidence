#!/bin/bash
# Raw read-only traffic evidence for traffic-facts v3.

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
. "${PROJECT_ROOT}/modules/shared/lib/router-health-common.sh"

JSON_MODE=0
PERIOD_ARG="today"

while [ $# -gt 0 ]; do
  case "$1" in
    --json)
      JSON_MODE=1
      shift
      ;;
    today|current|current-day|yesterday|week|month|[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9])
      PERIOD_ARG="$1"
      shift
      ;;
    *)
      echo "Usage: ./modules/traffic-observatory/bin/traffic-evidence --json [today|yesterday|week|month|YYYY-MM-DD]" >&2
      exit 1
      ;;
  esac
done

if [ "$JSON_MODE" -ne 1 ]; then
  echo "traffic-evidence is a machine-readable command; use --json." >&2
  exit 1
fi

STATE_DIR="${GHOSTROUTE_TRAFFIC_STATE_DIR:-}"
REMOTE_STATE_DIR="${GHOSTROUTE_ROUTER_TRAFFIC_STATE_DIR:-/opt/var/log/router_configuration}"
TMP_STATE_DIR=""
cleanup() {
  [ -z "$TMP_STATE_DIR" ] || rm -rf "$TMP_STATE_DIR"
}
trap cleanup EXIT

if [ -z "$STATE_DIR" ]; then
  for candidate in \
    "$PROJECT_ROOT/.ghostroute/traffic" \
    "$PROJECT_ROOT/reports/traffic" \
    "/opt/var/log/router_configuration" \
    "/jffs/addons/router_configuration/traffic"; do
    if [ -d "$candidate" ]; then
      STATE_DIR="$candidate"
      break
    fi
  done
fi

if [ -z "$STATE_DIR" ] && [ "${GHOSTROUTE_TRAFFIC_EVIDENCE_REFRESH_REMOTE:-1}" = "1" ]; then
  if router_health_load_env >/dev/null 2>&1; then
    TMP_STATE_DIR="$(mktemp -d "${TMPDIR:-/tmp}/ghostroute-traffic-evidence.XXXXXX")"
    router_ssh "cat '${REMOTE_STATE_DIR}/lan-flow-facts.tsv' 2>/dev/null || true" > "${TMP_STATE_DIR}/lan-flow-facts.tsv" || true
    router_ssh "cat '${REMOTE_STATE_DIR}/dns-query-facts.tsv' 2>/dev/null || true" > "${TMP_STATE_DIR}/dns-query-facts.tsv" || true
    router_ssh "cat '${REMOTE_STATE_DIR}/lan-device-counters.tsv' 2>/dev/null || true" > "${TMP_STATE_DIR}/lan-device-counters.tsv" || true
    router_ssh "cat '${REMOTE_STATE_DIR}/mobile-reality-counters.tsv' 2>/dev/null || true" > "${TMP_STATE_DIR}/mobile-reality-counters.tsv" || true
    router_ssh "cat '${REMOTE_STATE_DIR}/sing-box-route-evidence.tsv' 2>/dev/null || true" > "${TMP_STATE_DIR}/sing-box-route-evidence.tsv" || true
    STATE_DIR="$TMP_STATE_DIR"
  fi
fi

TRAFFIC_EVIDENCE_PERIOD="$PERIOD_ARG" \
TRAFFIC_EVIDENCE_STATE_DIR="$STATE_DIR" \
ruby -rjson -rdigest -rtime -rdate - <<'RUBY'
def text(value, fallback = '')
  value.nil? || value.to_s.empty? ? fallback : value.to_s
end

def number(value)
  Integer(value || 0)
rescue ArgumentError, TypeError
  0
end

def parse_time(value)
  raw = text(value)
  return nil if raw.empty?
  Time.parse(raw).utc
rescue ArgumentError
  nil
end

def iso_time(value)
  parsed = parse_time(value)
  parsed&.iso8601(3)
end

def sample_id(row)
  Digest::SHA1.hexdigest([
    row['ts'], row['client_ip'], row['remote_ip'], row['remote_port'],
    row['proto'], row['total_bytes'], row['source']
  ].join('|'))
end

def evidence_id(*parts)
  Digest::SHA1.hexdigest(parts.map { |part| text(part) }.join('|'))
end

def local_midnight(date)
  Time.local(date.year, date.month, date.day, 0, 0, 0)
end

def window_for(period, timezone)
  original_tz = ENV['TZ']
  ENV['TZ'] = timezone
  now = ENV['GHOSTROUTE_TRAFFIC_WINDOW_NOW'] ? Time.parse(ENV['GHOSTROUTE_TRAFFIC_WINDOW_NOW']) : Time.now
  today = Date.new(now.year, now.month, now.day)
  normalized = period.to_s

  start_date =
    case normalized
    when 'today', 'current', 'current-day'
      today
    when 'yesterday'
      today - 1
    when 'week'
      today - (today.cwday - 1)
    when 'month'
      Date.new(today.year, today.month, 1)
    when /\A\d{4}-\d{2}-\d{2}\z/
      Date.parse(normalized)
    else
      today
    end

  end_date =
    case normalized
    when 'week'
      start_date + 7
    when 'month'
      start_date.next_month
    else
      start_date + 1
    end

  {
    'period' => period,
    'timezone' => timezone,
    'start_ts_utc' => local_midnight(start_date).utc.iso8601(3),
    'end_ts_utc' => local_midnight(end_date).utc.iso8601(3)
  }
ensure
  ENV['TZ'] = original_tz
end

def in_window?(parsed_time, start_time, end_time)
  parsed_time && parsed_time >= start_time && parsed_time < end_time
end

period = ENV.fetch('TRAFFIC_EVIDENCE_PERIOD', 'today')
timezone = ENV.fetch('GHOSTROUTE_TRAFFIC_WINDOW_TZ', 'Europe/Moscow')
state_dir = text(ENV['TRAFFIC_EVIDENCE_STATE_DIR'])
generated_at = Time.now.utc.iso8601(3)
window = window_for(period, timezone)
window_start = Time.parse(window['start_ts_utc'])
window_end = Time.parse(window['end_ts_utc'])
warnings = []
flow_samples = []
dns_queries = []
lan_device_route_deltas = []
sing_box_route_evidence = []
home_reality_samples = []
route_evidence = []

if state_dir.empty? || !Dir.exist?(state_dir)
  warnings << { 'code' => 'state_dir_unavailable', 'message' => 'traffic state directory was not found', 'state_dir' => state_dir }
else
  lan_path = File.join(state_dir, 'lan-flow-facts.tsv')
  if File.file?(lan_path)
    File.readlines(lan_path, chomp: true).each_with_index do |line, index|
      next if line.strip.empty?
      parts = line.split('|', -1)
      next if parts.length < 14
      parsed_ts = parse_time(parts[0])
      unless parsed_ts
        warnings << { 'code' => 'unparsable_timestamp', 'source' => 'lan-flow-facts.tsv', 'line' => index + 1, 'raw_ts' => text(parts[0]) }
        next
      end
      next unless in_window?(parsed_ts, window_start, window_end)
      ts = parsed_ts.iso8601(3)
      total = number(parts[8])
      row = {
        'ts' => ts,
        'client_ip' => text(parts[1]),
        'remote_ip' => text(parts[2]),
        'remote_port' => text(parts[3]),
        'proto' => text(parts[4]).downcase,
        'route' => text(parts[5], 'Unknown'),
        'out_bytes' => number(parts[6]),
        'in_bytes' => number(parts[7]),
        'total_bytes' => total,
        'connections' => number(parts[9]),
        'source' => text(parts[10], 'conntrack_snapshot_delta'),
        'allocation_basis' => text(parts[11], 'observed_delta'),
        'destination_kind' => text(parts[12], 'ip'),
        'status' => text(parts[13], 'ok'),
        'route_source' => text(parts[14]),
        'route_basis' => text(parts[15]),
        'matched_ipset' => text(parts[16]),
        'egress_iface' => text(parts[17]),
        'fwmark' => text(parts[18]),
        'conn_state' => text(parts[19]),
        'raw_refs' => [{ 'source' => 'lan-flow-facts.tsv', 'line' => index + 1 }]
      }
      row['sample_id'] = sample_id(row)
      flow_samples << row
      route_evidence << {
        'sample_id' => row['sample_id'],
        'ts' => row['ts'],
        'client_ip' => row['client_ip'],
        'remote_ip' => row['remote_ip'],
        'route' => row['route'],
        'route_source' => row['route_source'],
        'route_basis' => row['route_basis'],
        'matched_ipset' => row['matched_ipset'],
        'egress_iface' => row['egress_iface'],
        'fwmark' => row['fwmark'],
        'status' => row['status']
      }
    end
  else
    warnings << { 'code' => 'lan_flow_facts_missing', 'message' => 'lan-flow-facts.tsv not found', 'path' => lan_path }
  end

  dns_path = File.join(state_dir, 'dns-query-facts.tsv')
  if File.file?(dns_path)
    File.readlines(dns_path, chomp: true).each_with_index do |line, index|
      next if line.strip.empty?
      parts = line.split('|', -1)
      next if parts.length < 8
      parsed_ts = parse_time(parts[0])
      unless parsed_ts
        warnings << { 'code' => 'unparsable_timestamp', 'source' => 'dns-query-facts.tsv', 'line' => index + 1, 'raw_ts' => text(parts[0]) }
        next
      end
      next unless in_window?(parsed_ts, window_start, window_end)
      row = {
        'id' => Digest::SHA1.hexdigest([line, index].join('|')),
        'ts' => parsed_ts.iso8601(3),
        'client_ip' => text(parts[1]),
        'domain' => text(parts[2]),
        'qtype' => text(parts[3], 'A'),
        'answer_ip' => text(parts[4]),
        'event_type' => text(parts[5]),
        'source' => text(parts[6], 'dnsmasq'),
        'status' => text(parts[7], 'ok'),
        'ts_source' => text(parts[8], 'snapshot_approx'),
        'raw_refs' => [{ 'source' => 'dns-query-facts.tsv', 'line' => index + 1 }]
      }
      dns_queries << row
    end
  else
    warnings << { 'code' => 'dns_query_facts_missing', 'message' => 'dns-query-facts.tsv not found', 'path' => dns_path }
  end

  lan_counters_path = File.join(state_dir, 'lan-device-counters.tsv')
  if File.file?(lan_counters_path)
    rows_by_ip = Hash.new { |hash, key| hash[key] = [] }
    File.readlines(lan_counters_path, chomp: true).each_with_index do |line, index|
      next if line.strip.empty?
      parts = line.split('|', -1)
      next if parts.length < 10
      parsed_ts = parse_time(parts[0])
      unless parsed_ts
        warnings << { 'code' => 'unparsable_timestamp', 'source' => 'lan-device-counters.tsv', 'line' => index + 1, 'raw_ts' => text(parts[0]) }
        next
      end
      client_ip = text(parts[1])
      next if client_ip.empty?
      rows_by_ip[client_ip] << {
        'ts' => parsed_ts,
        'client_ip' => client_ip,
        'client_label' => text(parts[2], client_ip),
        'vpn_up_counter' => number(parts[3]),
        'vpn_down_counter' => number(parts[4]),
        'wan_up_counter' => number(parts[5]),
        'wan_down_counter' => number(parts[6]),
        'other_up_counter' => number(parts[7]),
        'other_down_counter' => number(parts[8]),
        'mac' => text(parts[9]),
        'hostname' => text(parts[10], text(parts[2], client_ip)),
        'raw_refs' => [{ 'source' => 'lan-device-counters.tsv', 'line' => index + 1 }]
      }
    end

    rows_by_ip.each_value do |rows|
      previous = nil
      rows.sort_by { |row| row['ts'] }.each do |row|
        in_window = in_window?(row['ts'], window_start, window_end)
        if previous && in_window
          vpn_up = row['vpn_up_counter'] >= previous['vpn_up_counter'] ? row['vpn_up_counter'] - previous['vpn_up_counter'] : row['vpn_up_counter']
          vpn_down = row['vpn_down_counter'] >= previous['vpn_down_counter'] ? row['vpn_down_counter'] - previous['vpn_down_counter'] : row['vpn_down_counter']
          wan_up = row['wan_up_counter'] >= previous['wan_up_counter'] ? row['wan_up_counter'] - previous['wan_up_counter'] : row['wan_up_counter']
          wan_down = row['wan_down_counter'] >= previous['wan_down_counter'] ? row['wan_down_counter'] - previous['wan_down_counter'] : row['wan_down_counter']
          other_up = row['other_up_counter'] >= previous['other_up_counter'] ? row['other_up_counter'] - previous['other_up_counter'] : row['other_up_counter']
          other_down = row['other_down_counter'] >= previous['other_down_counter'] ? row['other_down_counter'] - previous['other_down_counter'] : row['other_down_counter']
          vpn_bytes = vpn_up + vpn_down
          direct_bytes = wan_up + wan_down
          other_bytes = other_up + other_down
          total = vpn_bytes + direct_bytes + other_bytes
          if total > 0
            lan_device_route_deltas << {
              'sample_id' => evidence_id('lan-device-route', previous['ts'].iso8601(3), row['ts'].iso8601(3), row['client_ip'], total),
              'ts' => row['ts'].utc.iso8601(3),
              'client_ip' => row['client_ip'],
              'client_key' => row['client_ip'],
              'client_label' => row['client_label'],
              'hostname' => row['hostname'],
              'vpn_bytes' => vpn_bytes,
              'direct_bytes' => direct_bytes,
              'other_bytes' => other_bytes,
              'total_bytes' => total,
              'source' => 'lan_device_route_counters',
              'allocation_basis' => 'client_counter_delta',
              'status' => 'ok',
              'raw_refs' => row['raw_refs']
            }
          end
        end
        previous = in_window ? row : nil
      end
    end
  end

  sing_box_path = File.join(state_dir, 'sing-box-route-evidence.tsv')
  if File.file?(sing_box_path)
    File.readlines(sing_box_path, chomp: true).each_with_index do |line, index|
      next if line.strip.empty?
      parts = line.split('|', -1)
      next if parts.length < 8
      parsed_ts = parse_time(parts[0])
      unless parsed_ts
        warnings << { 'code' => 'unparsable_timestamp', 'source' => 'sing-box-route-evidence.tsv', 'line' => index + 1, 'raw_ts' => text(parts[0]) }
        next
      end
      next unless in_window?(parsed_ts, window_start, window_end)
      row = {
        'id' => evidence_id('sing-box-route', line, index),
        'ts' => parsed_ts.iso8601(3),
        'connection_id' => text(parts[1]),
        'route' => text(parts[2], 'Unknown'),
        'outbound' => text(parts[3]),
        'destination' => text(parts[4]),
        'destination_host' => text(parts[5]),
        'destination_port' => text(parts[6]),
        'source' => text(parts[7], 'sing-box.log'),
        'status' => text(parts[8], 'ok'),
        'inbound' => text(parts[9]),
        'profile' => text(parts[10]),
        'raw_refs' => [{ 'source' => 'sing-box-route-evidence.tsv', 'line' => index + 1 }]
      }
      sing_box_route_evidence << row
      route_evidence << {
        'sample_id' => row['id'],
        'ts' => row['ts'],
        'client_ip' => '',
        'remote_ip' => '',
        'route' => row['route'],
        'route_source' => 'sing-box',
        'route_basis' => 'outbound_log',
        'matched_ipset' => '',
        'egress_iface' => '',
        'fwmark' => '',
        'outbound' => row['outbound'],
        'destination' => row['destination'],
        'status' => row['status']
      }
    end
  end

  mobile_path = File.join(state_dir, 'mobile-reality-counters.tsv')
  if File.file?(mobile_path)
    rows_by_key = Hash.new { |hash, key| hash[key] = [] }
    File.readlines(mobile_path, chomp: true).each_with_index do |line, index|
      next if line.strip.empty?
      parts = line.split('|', -1)
      next if parts.length < 5
      parsed_ts = parse_time(parts[0])
      unless parsed_ts
        warnings << { 'code' => 'unparsable_timestamp', 'source' => 'mobile-reality-counters.tsv', 'line' => index + 1, 'raw_ts' => text(parts[0]) }
        next
      end
      source_ip = text(parts[1])
      profile = text(parts[2], source_ip.empty? ? 'unknown-home-reality-profile' : "remote:#{source_ip}")
      key = [source_ip, profile].join('|')
      rows_by_key[key] << {
        'ts' => parsed_ts,
        'source_ip' => source_ip,
        'client_key' => profile.sub(/\Aremote:/, 'remote:'),
        'client_label' => profile,
        'bytes_up_counter' => number(parts[3]),
        'bytes_down_counter' => number(parts[4]),
        'raw_refs' => [{ 'source' => 'mobile-reality-counters.tsv', 'line' => index + 1 }]
      }
    end

    rows_by_key.each_value do |rows|
      previous = nil
      rows.sort_by { |row| row['ts'] }.each do |row|
        in_window = in_window?(row['ts'], window_start, window_end)
        if previous && in_window
          up_delta = row['bytes_up_counter'] >= previous['bytes_up_counter'] ? row['bytes_up_counter'] - previous['bytes_up_counter'] : row['bytes_up_counter']
          down_delta = row['bytes_down_counter'] >= previous['bytes_down_counter'] ? row['bytes_down_counter'] - previous['bytes_down_counter'] : row['bytes_down_counter']
          total = up_delta + down_delta
          if total > 0
            sample = {
              'sample_id' => evidence_id('home-reality', previous['ts'].iso8601(3), row['ts'].iso8601(3), row['source_ip'], row['client_label'], total),
              'ts' => row['ts'].utc.iso8601(3),
              'client_key' => row['client_key'],
              'client_label' => row['client_label'],
              'source_ip' => row['source_ip'],
              'channel' => 'A/Home Reality',
              'bytes_up' => up_delta,
              'bytes_down' => down_delta,
              'total_bytes' => total,
              'source' => 'mobile_reality_counter_delta',
              'allocation_basis' => 'observed_profile_counter_delta',
              'destination_kind' => 'encrypted_ingress',
              'status' => 'ok',
              'raw_refs' => row['raw_refs']
            }
            home_reality_samples << sample
          end
        end
        previous = in_window ? row : nil
      end
    end
  end
end

output = {
  'schema_version' => 1,
  'generated_at' => generated_at,
  'window' => window,
  'source' => { 'command' => 'traffic-evidence', 'schema' => 'traffic-evidence-v1', 'state_dir' => state_dir },
  'flow_samples' => flow_samples,
  'lan_device_route_deltas' => lan_device_route_deltas,
  'sing_box_route_evidence' => sing_box_route_evidence,
  'home_reality_samples' => home_reality_samples,
  'dns_queries' => dns_queries,
  'route_evidence' => route_evidence,
  'rollups' => {},
  'warnings' => warnings,
  'collector_metrics' => {
    'source_row_counts' => {
      'flow_samples' => flow_samples.length,
      'lan_device_route_deltas' => lan_device_route_deltas.length,
      'sing_box_route_evidence' => sing_box_route_evidence.length,
      'home_reality_samples' => home_reality_samples.length,
      'dns_queries' => dns_queries.length,
      'route_evidence' => route_evidence.length
    }
  }
}

puts JSON.pretty_generate(output)
RUBY
