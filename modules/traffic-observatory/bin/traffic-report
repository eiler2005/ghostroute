fi

if [ -s "$CHANNEL_C_LOG" ]; then
  awk -v totals="$CHANNEL_C_TOTALS" -v clients_out="$CHANNEL_C_CLIENTS" -v dests_out="$CHANNEL_C_DESTS" '
    function conn_id(line,   body, parts) {
      if (match(line, /\[[0-9]+ [^]]+\]/)) {
        body = substr(line, RSTART + 1, RLENGTH - 2)
        split(body, parts, " ")
        return parts[1]
      }
      return ""
    }
    function human_dest(dest,   d) {
      d = dest
      sub(/:[0-9]+$/, "", d)
      return d
    }
    function extract_client(line,   client) {
      client = line
      sub(/^.*inbound\/[^:]+: \[/, "", client)
      if (client != line) {
        sub(/\].*$/, "", client)
        return client
      }
      return "channel-c"
    }
    {
      id = conn_id($0)
      if (id == "") next

      if (($0 ~ /inbound\/http\[channel-c-shadowrocket-http-in\]: .*inbound connection to /) ||
          ($0 ~ /inbound\/naive\[channel-c-naive-in\]: .*inbound connection to /)) {
        client = extract_client($0)
        dest = $0
        sub(/^.* inbound connection to /, "", dest)

        seen[id] = 1
        client_by_id[id] = client
        dest_by_id[id] = dest
        next
      }

      if ($0 ~ /inbound\/(http\[channel-c-shadowrocket-http-in\]|naive\[channel-c-naive-in\]): process connection from .*: EOF/) {
        channel_errors++
        next
      }

      if (id == "" || !(id in seen) || (id in outbound_by_id)) next

      if ($0 ~ /outbound\/vless\[reality-out\]: outbound connection to /) {
        outbound_by_id[id] = "reality"
      } else if ($0 ~ /outbound\/direct\[direct-out\]: outbound connection to /) {
        outbound_by_id[id] = "direct"
      }
    }
    END {
      for (id in seen) {
        client = client_by_id[id]
        dest = human_dest(dest_by_id[id])
        outbound = outbound_by_id[id]
        if (outbound == "") outbound = "unresolved"

        total++
        clients[client] = 1
        client_total[client]++
        dest_total[dest]++

        if (outbound == "reality") {
          reality++
          client_reality[client]++
          dest_reality[dest]++
        } else if (outbound == "direct") {
          direct++
          client_direct[client]++
          dest_direct[dest]++
        } else {
          unresolved++
          client_unresolved[client]++
          dest_unresolved[dest]++
        }
      }

      client_count = 0
      for (client in clients) client_count++
      printf "%d|%d|%d|%d|%d|%d\n", total + 0, reality + 0, direct + 0, unresolved + 0, channel_errors + 0, client_count + 0 > totals

      for (client in clients) {
        printf "%s|%d|%d|%d|%d\n", client, client_total[client] + 0, client_reality[client] + 0, client_direct[client] + 0, client_unresolved[client] + 0 >> clients_out
      }

      for (dest in dest_total) {
        printf "%s|%d|%d|%d|%d\n", dest, dest_total[dest] + 0, dest_reality[dest] + 0, dest_direct[dest] + 0, dest_unresolved[dest] + 0 >> dests_out
      }
    }
  ' "$CHANNEL_C_LOG"
  [ -s "$CHANNEL_C_CLIENTS" ] && sort -t'|' -k2,2nr -k1,1 "$CHANNEL_C_CLIENTS" -o "$CHANNEL_C_CLIENTS"
  [ -s "$CHANNEL_C_DESTS" ] && sort -t'|' -k2,2nr -k1,1 "$CHANNEL_C_DESTS" -o "$CHANNEL_C_DESTS"
else
  printf '0|0|0|0|0|0\n' > "$CHANNEL_C_TOTALS"
  : > "$CHANNEL_C_CLIENTS"
  : > "$CHANNEL_C_DESTS"
fi

if [ -n "$MOBILE_BYTES_START" ] && [ -s "$MOBILE_BYTES_CURRENT" ]; then
  awk -F'|' -v ts="$MOBILE_BYTES_START" '
    $1 == ts { print $2 "|" $3 "|" $4 "|" $5 }
  ' "$MOBILE_BYTES_HISTORY" > "$MOBILE_BYTES_BASE"

  awk -F'|' '
    function delta(current, base) {
      current += 0
      base += 0
      return current >= base ? current - base : current
    }
    NR == FNR {
      label[$1] = $2
      upload[$1] = $3 + 0
      download[$1] = $4 + 0
      seen[$1] = 1
      next
    }
    {
      ip = $1
      current_label[ip] = $2
      current_upload[ip] = $3 + 0
      current_download[ip] = $4 + 0
      seen[ip] = 1
    }
    END {
      for (ip in seen) {
        out_label = current_label[ip]
        if (out_label == "") out_label = label[ip]
        if (out_label == "") out_label = "remote:" ip

        up = delta(current_upload[ip], upload[ip])
        down = delta(current_download[ip], download[ip])
        total = up + down
        printf "%s|%s|%d|%d|%d\n", ip, out_label, up, down, total
      }
    }' "$MOBILE_BYTES_BASE" "$MOBILE_BYTES_CURRENT" | sort -t'|' -k5,5nr -k1,1V > "$MOBILE_BYTES_PARSED"
else
  : > "$MOBILE_BYTES_PARSED"
fi

if [ -s "$MOBILE_BYTES_PARSED" ]; then
  awk -F'|' '
    BEGIN { OFS = "|" }
    {
      label = $2
      if (label == "") label = $1
      if (($5 + 0) <= 0) next
      if (label ~ /^remote:#/ || label ~ /^remote:\*/) next
      upload[label] += $3 + 0
      download[label] += $4 + 0
      total[label] += $5 + 0
    }
    END {
      for (label in total) {
        print label, label, upload[label], download[label], total[label]
      }
    }' "$MOBILE_BYTES_PARSED" | sort -t'|' -k5,5nr -k1,1 > "$MOBILE_BYTES_PARSED.aggregated"
  mv "$MOBILE_BYTES_PARSED.aggregated" "$MOBILE_BYTES_PARSED"
fi

if [ -s "$MOBILE_BYTES_PARSED" ]; then
  awk -F'|' '
    {
      upload += $3 + 0
      download += $4 + 0
      total += $5 + 0
      sources++
    }
    END {
      printf "%d|%d|%d|%d\n", total, upload, download, sources
    }' "$MOBILE_BYTES_PARSED" > "$MOBILE_BYTES_TOTALS"
else
  : > "$MOBILE_BYTES_TOTALS"
fi

ruby -rjson -e '
  current = JSON.parse(File.read(ARGV[0]))
  base = JSON.parse(File.read(ARGV[1]))
  base_peers = {}
  (base["Peer"] || {}).each_value do |peer|
    next unless peer["ID"]
    base_peers[peer["ID"]] = {
      "rx" => (peer["RxBytes"] || 0).to_i,
      "tx" => (peer["TxBytes"] || 0).to_i
    }
  end

  peers = (current["Peer"] || {}).values
  peers.sort_by { |peer| peer["DNSName"].to_s }.each do |peer|
    id = peer["ID"]
    base_rx = base_peers.dig(id, "rx").to_i
    base_tx = base_peers.dig(id, "tx").to_i
    cur_rx = (peer["RxBytes"] || 0).to_i
    cur_tx = (peer["TxBytes"] || 0).to_i
    delta_rx = cur_rx >= base_rx ? cur_rx - base_rx : cur_rx
    delta_tx = cur_tx >= base_tx ? cur_tx - base_tx : cur_tx

    name = peer["DNSName"].to_s.sub(/\.$/, "").sub(/\.tail.*$/, "")
    name = peer["HostName"].to_s if name.empty?
    puts [name, peer["Online"], delta_rx, delta_tx, peer["LastSeen"].to_s].join("|")
  end
' "$CURRENT_TAILSCALE" "$BASE_TAILSCALE" > "$TAILSCALE_PARSED"

TAILSCALE_RX_TOTAL="$(awk -F'|' '{ sum += ($3 + 0) } END { print sum + 0 }' "$TAILSCALE_PARSED")"
TAILSCALE_TX_TOTAL="$(awk -F'|' '{ sum += ($4 + 0) } END { print sum + 0 }' "$TAILSCALE_PARSED")"
TAILSCALE_TOTAL=$(( TAILSCALE_RX_TOTAL + TAILSCALE_TX_TOTAL ))

if [ "$REPORT_REDACT_NAMES" = "1" ] && { [ -s "$MOBILE_CLIENTS" ] || [ -s "$MOBILE_BYTES_PARSED" ]; }; then
  {
    awk -F'|' '$1 != "" { print "profile|" $1 }' "$MOBILE_CLIENTS"
    awk -F'|' '$2 != "" { print "source|" $2 }' "$MOBILE_BYTES_PARSED"
  } | sort -u | awk -F'|' '
    function source_ip(label,   ip) {
      ip = label
      sub(/^remote:/, "", ip)
      return ip
    }
    function is_private_ip(ip,   octets) {
      split(ip, octets, ".")
      return octets[1] == "10" ||
        (octets[1] == "192" && octets[2] == "168") ||
        (octets[1] == "172" && octets[2] + 0 >= 16 && octets[2] + 0 <= 31)
    }
    BEGIN { OFS = "|" }
    $1 == "profile" && $2 != "" {
      if (!($2 in alias)) alias[$2] = sprintf("mobile-client-%02d", ++profile_idx)
      next
    }
    $1 == "source" && $2 != "" {
      if ($2 in alias) next

      if ($2 ~ /^remote:/) {
        ip = source_ip($2)
        if (is_private_ip(ip)) alias[$2] = sprintf("lan-hairpin-%02d", ++lan_idx)
        else alias[$2] = sprintf("unattributed-external-%02d", ++external_idx)
      } else {
        alias[$2] = sprintf("unattributed-source-%02d", ++source_idx)
      }
    }
    END {
      for (key in alias) print key, alias[key]
    }
  ' > "$MOBILE_ALIAS_MAP"

  if [ -s "$DEVICE_METADATA_MAP" ]; then
    awk -F'|' '
      BEGIN { OFS="|" }
      NR == FNR {
        if ($2 != "") label[$1] = $2
        next
      }
      {
        if (($1 in label) && label[$1] != "") $2 = $2 " (" label[$1] ")"
        else if (($2 in label) && label[$2] != "") $2 = $2 " (" label[$2] ")"
        print
      }
    ' "$DEVICE_METADATA_MAP" "$MOBILE_ALIAS_MAP" > "$MOBILE_ALIAS_MAP.named" && mv "$MOBILE_ALIAS_MAP.named" "$MOBILE_ALIAS_MAP"
  fi

  if [ -s "$MOBILE_CLIENTS" ]; then
    awk -F'|' '
      BEGIN { OFS="|" }
      NR == FNR {
        alias[$1] = $2
        next
      }
      {
        if ($1 in alias) $1 = alias[$1]
        print
      }' "$MOBILE_ALIAS_MAP" "$MOBILE_CLIENTS" > "$MOBILE_CLIENTS.redacted" && mv "$MOBILE_CLIENTS.redacted" "$MOBILE_CLIENTS"
  fi

  if [ -s "$MOBILE_BYTES_PARSED" ]; then
    awk -F'|' '
      BEGIN { OFS="|" }
      NR == FNR {
        alias[$1] = $2
        next
      }
      {
        if ($2 in alias) $2 = alias[$2]
        print
      }' "$MOBILE_ALIAS_MAP" "$MOBILE_BYTES_PARSED" > "$MOBILE_BYTES_PARSED.redacted" && mv "$MOBILE_BYTES_PARSED.redacted" "$MOBILE_BYTES_PARSED"
  fi
fi

: > "$MOBILE_BYTES_ATTRIBUTED"
: > "$MOBILE_BYTES_LAN_HAIRPIN"
: > "$MOBILE_BYTES_UNKNOWN_EXTERNAL"
: > "$MOBILE_BYTES_CATEGORY_TOTALS"
if [ -s "$MOBILE_BYTES_PARSED" ]; then
  awk -F'|' \
    -v attributed_file="$MOBILE_BYTES_ATTRIBUTED" \
    -v lan_file="$MOBILE_BYTES_LAN_HAIRPIN" \
    -v unknown_file="$MOBILE_BYTES_UNKNOWN_EXTERNAL" \
    -v totals_file="$MOBILE_BYTES_CATEGORY_TOTALS" '
    function source_ip(raw,   ip) {
      ip = raw
      sub(/^remote:/, "", ip)
      return ip
    }
    function is_private_ip(ip,   octets) {
      split(ip, octets, ".")
      return octets[1] == "10" ||
        (octets[1] == "192" && octets[2] == "168") ||
        (octets[1] == "172" && octets[2] + 0 >= 16 && octets[2] + 0 <= 31)
    }
    function add(category, file) {
      count[category]++
      upload[category] += $3 + 0
      download[category] += $4 + 0
      total[category] += $5 + 0
      print $0 >> file
    }
    BEGIN { OFS = "|" }
    ($5 + 0) <= 0 { next }
    {
      raw = $1
      if (raw ~ /^remote:/) {
        ip = source_ip(raw)
        if (is_private_ip(ip)) add("lan_hairpin", lan_file)
        else add("unknown_external", unknown_file)
      } else {
        add("attributed", attributed_file)
      }
    }
    END {
      print "attributed", count["attributed"] + 0, upload["attributed"] + 0, download["attributed"] + 0, total["attributed"] + 0 > totals_file
      print "lan_hairpin", count["lan_hairpin"] + 0, upload["lan_hairpin"] + 0, download["lan_hairpin"] + 0, total["lan_hairpin"] + 0 >> totals_file
      print "unknown_external", count["unknown_external"] + 0, upload["unknown_external"] + 0, download["unknown_external"] + 0, total["unknown_external"] + 0 >> totals_file
    }' "$MOBILE_BYTES_PARSED"
fi

