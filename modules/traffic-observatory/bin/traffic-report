def clean_dest(value)
  value.to_s.strip.sub(/\Atcp:/, '').sub(/:[0-9]+\z/, '').downcase
end

def app_family(dest)
  d = dest.to_s.downcase
  return 'Telegram' if d.match?(/(^149\.154\.|telegram|t\.me)/)
  return 'Google/YouTube' if d.match?(/(youtube|googlevideo|ytimg|ggpht|youtubei|googleapis|googleusercontent|google\.com|gstatic|gmail|imap\.gmail|googlemail)/)
  return 'Meta/Instagram' if d.match?(/(instagram|cdninstagram|facebook|fbcdn|edge-mqtt|meta\.)/)
  return 'WhatsApp' if d.match?(/(whatsapp|whatsapp\.net)/)
  return 'Apple/iCloud' if d.match?(/(apple|icloud|itunes|mzstatic|aaplimg|apple-dns|ls-apple|gs-loc|mask\.icloud|me\.com)/)
  return 'Yandex/Dzen' if d.match?(/(yandex|yastatic|kinopoisk|dzen)/)
  return 'Banking/RU' if d.match?(/(alfa|alfabank|sber|tinkoff|tbank|vtb|groupib)/)
  return 'Retail/RU' if d.match?(/(ozon|wildberries|lamoda|x5\.ru|market\.yandex|vs\.market\.yandex)/)
  return 'Mail/VK/RU social' if d.match?(/(mail\.ru|vk\.com|vk\.ru|ok\.ru)/)
  return 'Dev/Productivity' if d.match?(/(github|miro|wisprflow|hetzner|segment\.io|microsoft|office|teams|slack|notion|dropbox)/)
  return 'AI services' if d.match?(/(openai|chatgpt|anthropic|claude|perplexity)/)
  return 'AWS/CDN' if d.match?(/(amazonaws|cloudfront|cloudflare|cdn|akamai|fastly|s3\.)/)
  return 'DNS/Resolver' if d.match?(/\A(1\.1\.1\.1|8\.8\.8\.8|9\.9\.9\.9|dns\.google)\z/)
  return 'Other/IP' if d.match?(/\A[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+\z/)
  'Other'
end

def estimate_bytes(total_bytes, part, total)
  total = total.to_i
  return 0 if total <= 0 || total_bytes.to_i <= 0
  (total_bytes.to_f * part.to_i / total).round
end

def conn_id(line)
  match = line.match(/\[([0-9]+) [^\]]+\]/)
  match && match[1]
end

metadata_label = {}
profile_label = {}
if File.file?(metadata_path)
  File.foreach(metadata_path, chomp: true) do |line|
    next if line.strip.empty? || line.lstrip.start_with?('#')

    key, alias_name, type, notes = line.split('|', 4).map { |part| part.to_s.strip }
    next if key.empty?

    label = alias_name.empty? ? type : alias_name
    label = "#{label} (#{type})" if !alias_name.empty? && !type.empty? && alias_name != type
    metadata_label[key] = label unless label.empty?

    next unless notes.to_s.match(/Home Reality QR:\s*(iphone-[0-9]+)/)

    profile = Regexp.last_match(1)
    next if label.empty?

    profile_label[profile] = label
    if profile.match(/iphone-([0-9]+)/)
      idx = Regexp.last_match(1)
      profile_label["iphone-b-#{idx}"] = label
      profile_label["c1_iphone_#{idx}"] = label
    end
  end
end

mobile_alias = {}
if redact_names == '1' && File.file?(mobile_alias_path)
  File.foreach(mobile_alias_path, chomp: true) do |line|
    raw, label = line.split('|', 2).map { |part| part.to_s.strip }
    mobile_alias[raw] = label unless raw.empty? || label.empty?
  end
end

display_profile = lambda do |profile|
  raw = profile.to_s.sub(/-xhttp@.*\z/, '')
  if redact_names == '1'
    return mobile_alias[raw] if mobile_alias[raw]
    if raw.match(/\Aiphone-b-([0-9]+)\z/) && mobile_alias["iphone-#{Regexp.last_match(1)}"]
      return "#{mobile_alias["iphone-#{Regexp.last_match(1)}"]} / B"
    end
    if raw.match(/\Ac1_iphone_([0-9]+)\z/) && mobile_alias["iphone-#{Regexp.last_match(1)}"]
      return "#{mobile_alias["iphone-#{Regexp.last_match(1)}"]} / C1"
    end
  end
  profile_label[raw] || metadata_label[raw] || raw
end

records = {}
if File.file?(combined_log_path)
  File.foreach(combined_log_path, chomp: true) do |line|
    id = conn_id(line)
    next unless id

    record = (records[id] ||= {})
    case line
    when /inbound\/vless\[reality-in\]: \[([^\]]+)\] inbound connection to (.+)\z/
      record[:channel] = 'A/Home Reality'
      record[:profile] = Regexp.last_match(1)
      record[:dest] = clean_dest(Regexp.last_match(2))
    when /inbound\/socks\[channel-b-relay-socks\]: inbound connection to (.+)\z/
      record[:channel] = 'B/XHTTP relay'
      record[:profile] = 'channel-b'
      record[:dest] = clean_dest(Regexp.last_match(1))
    when /inbound\/http\[channel-c-shadowrocket-http-in\]: (?:\[([^\]]+)\] )?inbound connection to (.+)\z/
      record[:channel] = 'C1/Shadowrocket'
      record[:profile] = Regexp.last_match(1) || 'channel-c'
      record[:dest] = clean_dest(Regexp.last_match(2))
    when /inbound\/naive\[channel-c-naive-in\]: (?:\[([^\]]+)\] )?inbound connection to (.+)\z/
      record[:channel] = 'C1/native Naive'
      record[:profile] = Regexp.last_match(1) || 'channel-c-native'
      record[:dest] = clean_dest(Regexp.last_match(2))
    when /outbound\/vless\[reality-out\]: outbound connection to /
      record[:outbound] = 'VPS'
    when /outbound\/direct\[direct-out\]: outbound connection to /
      record[:outbound] = 'Direct'
    end
  end
end

connection_rows = []
records.each_value do |record|
  next unless record[:channel] && record[:dest]
  next if record[:channel] == 'B/XHTTP relay'

  connection_rows << record.merge(outbound: record[:outbound] || 'Unresolved', count: 1)
end

channel_b_accepts = Hash.new(0)
if File.file?(channel_b_home_log_path)
  File.foreach(channel_b_home_log_path, chomp: true) do |line|
    next unless line.match(/accepted tcp:([^\s]+) \[channel-b-home-in -> channel-b-upstream-socks\] email: ([^\s]+)/)

    dest = clean_dest(Regexp.last_match(1))
    profile = Regexp.last_match(2).sub(/-xhttp@.*\z/, '')
    channel_b_accepts[[profile, dest]] += 1
  end
end

channel_b_profile_totals = Hash.new(0)
channel_b_accepts.each { |(profile, _dest), count| channel_b_profile_totals[profile] += count }

totals = Hash.new { |hash, key| hash[key] = Hash.new(0) }
apps = Hash.new { |hash, key| hash[key] = Hash.new(0) }

connection_rows.each do |row|
  profile = row[:profile]
  display = display_profile.call(profile)
  key = [row[:channel], display, profile]
  family = app_family(row[:dest])
  count = row[:count].to_i
  outbound = row[:outbound]

  totals[key]['conn'] += count
  totals[key][outbound] += count
  apps[key + [family]]['conn'] += count
  apps[key + [family]][outbound] += count
end

channel_b_profile_totals.each do |profile, count|
  display = display_profile.call(profile)
  key = ['B/XHTTP relay', display, profile]
  totals[key]['conn'] += count
end

if channel_b_profile_totals.length == 1
  key = ['B/XHTTP relay', display_profile.call(channel_b_profile_totals.keys.first), channel_b_profile_totals.keys.first]
  totals[key]['VPS'] = channel_b_relay_vps
  totals[key]['Direct'] = channel_b_relay_direct
  totals[key]['Unresolved'] = channel_b_relay_unresolved
end

channel_b_accepts.each do |(profile, dest), count|
  display = display_profile.call(profile)
  key = ['B/XHTTP relay', display, profile, app_family(dest)]
  apps[key]['conn'] += count
end

File.open(user_totals_path, 'w') do |file|
  totals.sort_by { |key, values| [key[0], -values['conn'], key[1]] }.each do |key, values|
    channel, display, profile = key
    conn = values['conn']
    vps_conn = values['VPS']
    direct_conn = values['Direct']
    unresolved_conn = values['Unresolved']
    bytes_total = channel == 'A/Home Reality' ? estimate_bytes(mobile_byte_total, conn, mobile_conn_total) : 0
    bytes_vps = channel == 'A/Home Reality' ? estimate_bytes(mobile_byte_total, vps_conn, mobile_conn_total) : 0
    bytes_direct = channel == 'A/Home Reality' ? estimate_bytes(mobile_byte_total, direct_conn, mobile_conn_total) : 0
    note = case channel
           when 'A/Home Reality' then 'estimated bytes from Home Reality ingress connection share'
           when 'B/XHTTP relay' then 'bytes n/a; profile/apps from Xray, path split from sing-box relay'
           else 'bytes n/a; connection split from sing-box'
           end
    file.puts [channel, display, profile, bytes_total, bytes_vps, bytes_direct, 0, conn, vps_conn, direct_conn, unresolved_conn, note].join('|')
  end
end

File.open(user_apps_path, 'w') do |file|
  apps.sort_by { |key, values| [key[0], key[1], -values['conn'], key[3]] }.each do |key, values|
    channel, display, profile, family = key
    conn = values['conn']
    vps_conn = values['VPS']
    direct_conn = values['Direct']
    unresolved_conn = values['Unresolved']
    bytes_total = channel == 'A/Home Reality' ? estimate_bytes(mobile_byte_total, conn, mobile_conn_total) : 0
    bytes_vps = channel == 'A/Home Reality' ? estimate_bytes(mobile_byte_total, vps_conn, mobile_conn_total) : 0
    bytes_direct = channel == 'A/Home Reality' ? estimate_bytes(mobile_byte_total, direct_conn, mobile_conn_total) : 0
    file.puts [channel, display, profile, family, bytes_total, bytes_vps, bytes_direct, conn, vps_conn, direct_conn, unresolved_conn].join('|')
  end
end

dns_families = Hash.new { |hash, key| hash[key] = Hash.new(0) }
if File.file?(dns_path)
  File.foreach(dns_path, chomp: true) do |line|
    parts = line.split('|', -1)
    next unless parts[0] == 'TOPFAMILY'

    dns_families[parts[1]][parts[4]] += parts[3].to_i
  end
end

File.open(lan_user_apps_path, 'w') do |file|
  if File.file?(lan_bytes_path)
    File.foreach(lan_bytes_path, chomp: true) do |line|
      ip, label, reality, wan, other, _upload, _download, total = line.split('|', -1)
      next if ip.to_s.empty?

      families = dns_families[ip].sort_by { |_family, count| -count }.first(5)
      family_text = families.empty? ? 'n/a' : families.map { |family, count| "#{family}:#{count}" }.join(', ')
      file.puts [label, total.to_i, reality.to_i, wan.to_i, other.to_i, family_text].join('|')
    end
  end
end
