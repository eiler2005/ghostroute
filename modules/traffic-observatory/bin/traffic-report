BHOME_OUT_BYTES_RUNTIME="$(awk -F'|' '$1 == "BHOME" { print $6; exit }' "$STATE_FILE")"
BHOME_PACKETS_RUNTIME="$(awk -F'|' '$1 == "BHOME" { print $7; exit }' "$STATE_FILE")"

[ -n "$CHANNEL_B_HOME_ENABLED_RUNTIME" ] && CHANNEL_B_HOME_ENABLED="$CHANNEL_B_HOME_ENABLED_RUNTIME"
[ -n "$CHANNEL_B_HOME_PORT_RUNTIME" ] && CHANNEL_B_HOME_PORT="$CHANNEL_B_HOME_PORT_RUNTIME"
[ -n "$HOME_REALITY_PORT_RUNTIME" ] && HOME_REALITY_PORT="$HOME_REALITY_PORT_RUNTIME"
[ -n "$BHOME_IN_BYTES_RUNTIME" ] && BHOME_IN_BYTES="$BHOME_IN_BYTES_RUNTIME"
[ -n "$BHOME_OUT_BYTES_RUNTIME" ] && BHOME_OUT_BYTES="$BHOME_OUT_BYTES_RUNTIME"
[ -n "$BHOME_PACKETS_RUNTIME" ] && BHOME_PACKETS="$BHOME_PACKETS_RUNTIME"

CHANNEL_B_HOME_ENABLED="$(clean_int "$CHANNEL_B_HOME_ENABLED")"
CHANNEL_B_HOME_PORT="$(clean_int "$CHANNEL_B_HOME_PORT")"
HOME_REALITY_PORT="$(clean_int "$HOME_REALITY_PORT")"
