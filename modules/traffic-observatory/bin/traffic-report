grep -E "inbound/(http\\[channel-c-shadowrocket-http-in\\]|naive\\[channel-c-naive-in\\])|outbound/(vless\\[reality-out\\]|direct\\[direct-out\\])" "$CHANNEL_COMBINED_LOG" > "$CHANNEL_C_LOG" || true
