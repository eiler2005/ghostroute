#!/bin/bash
# Router channel traffic report.
#
# This report intentionally does not inspect wgs1/wgc1. Channel A is the
# router-managed default lane. Channel B is a selected-client production
# home-first lane with separate ingress, represented with best-effort telemetry
# in this report.

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
. "${PROJECT_ROOT}/modules/shared/lib/router-health-common.sh"
. "${PROJECT_ROOT}/modules/shared/lib/device-labels.sh"
router_health_load_env

REPORT_REDACT_NAMES="${REPORT_REDACT_NAMES:-1}"
DEVICE_METADATA_FILE="${DEVICE_METADATA_FILE:-$(device_labels_default_metadata_file)}"
PERIOD_ARG="${1:-today}"

channels_quick_report() {
  local filter="${1:-all}"
  router_ssh "GHOSTROUTE_QUICK_FILTER='$filter' sh -s" <<'REMOTE'
set -eu

runtime_env=""
for candidate in /jffs/scripts/ghostroute-runtime.env /jffs/scripts/ghostroute-runtime-env; do
  [ -f "$candidate" ] && runtime_env="$candidate" && break
done

env_value() {
  key="$1"
  if [ -n "$runtime_env" ]; then
    awk -F= -v key="$key" '$1 == key { print substr($0, index($0, "=") + 1); exit }' "$runtime_env"
  fi
}

legacy_value() {
  key="$1"
  if [ -f /jffs/scripts/stealth-route-init.sh ]; then
    awk -F= -v key="$key" '
      $1 == key {
        gsub(/["'\''"]/, "", $2)
        print $2
        exit
      }' /jffs/scripts/stealth-route-init.sh
  fi
}

redirect_port="$(env_value GHOSTROUTE_REDIRECT_PORT)"
home_reality_port="$(env_value GHOSTROUTE_HOME_REALITY_PORT)"
channel_b_enabled="$(env_value GHOSTROUTE_CHANNEL_B_HOME_ENABLED)"
channel_b_port="$(env_value GHOSTROUTE_CHANNEL_B_HOME_PORT)"
home_enabled="$(env_value GHOSTROUTE_CHANNEL_C_HOME_ENABLED)"
home_public="$(env_value GHOSTROUTE_CHANNEL_C_HOME_PUBLIC_PORT)"
home_port="$(env_value GHOSTROUTE_CHANNEL_C_HOME_PORT)"
sr_enabled="$(env_value GHOSTROUTE_CHANNEL_C_SHADOWROCKET_ENABLED)"
sr_public="$(env_value GHOSTROUTE_CHANNEL_C_SHADOWROCKET_PUBLIC_PORT)"
sr_port="$(env_value GHOSTROUTE_CHANNEL_C_SHADOWROCKET_PORT)"

redirect_port="${redirect_port:-$(legacy_value REDIRECT_PORT)}"
home_reality_port="${home_reality_port:-$(legacy_value HOME_REALITY_PORT)}"
channel_b_enabled="${channel_b_enabled:-$(legacy_value CHANNEL_B_HOME_ENABLED)}"
channel_b_port="${channel_b_port:-$(legacy_value CHANNEL_B_HOME_PORT)}"
home_enabled="${home_enabled:-$(legacy_value CHANNEL_C_HOME_ENABLED)}"
home_public="${home_public:-$(legacy_value CHANNEL_C_HOME_PUBLIC_PORT)}"
home_port="${home_port:-$(legacy_value CHANNEL_C_HOME_PORT)}"
sr_enabled="${sr_enabled:-$(legacy_value CHANNEL_C_SHADOWROCKET_ENABLED)}"
sr_public="${sr_public:-$(legacy_value CHANNEL_C_SHADOWROCKET_PUBLIC_PORT)}"
sr_port="${sr_port:-$(legacy_value CHANNEL_C_SHADOWROCKET_PORT)}"

redirect_port="${redirect_port:-16000}"
home_reality_port="${home_reality_port:-4433}"
channel_b_enabled="${channel_b_enabled:-0}"
channel_b_port="${channel_b_port:-0}"
home_enabled="${home_enabled:-0}"
home_public="${home_public:-443}"
home_port="${home_port:-41955}"
sr_enabled="${sr_enabled:-0}"
sr_public="${sr_public:-4443}"
sr_port="${sr_port:-41956}"

listen_sockets="$(netstat -nlp 2>/dev/null || true)"
nat_prerouting="$(iptables -t nat -S PREROUTING 2>/dev/null || true)"
filter_input="$(iptables -S INPUT 2>/dev/null || true)"
singbox_config="$(cat /opt/etc/sing-box/config.json 2>/dev/null || true)"
singbox_config_compact="$(printf '%s\n' "$singbox_config" | awk '{ gsub(/[[:space:]]/, ""); printf "%s", $0 }')"

listener_status() {
  port="$1"
  printf '%s\n' "$listen_sockets" | grep -E "[:.]${port}[[:space:]]" >/dev/null 2>&1 && printf 'OK' || printf 'MISSING'
}

redirect_status() {
  public_port="$1"
  inner_port="$2"
  if [ "$public_port" = "$inner_port" ]; then
    printf 'N/A'
  elif printf '%s\n' "$nat_prerouting" | grep -F -- "--dport $public_port" | grep -F -- "--to-ports $inner_port" >/dev/null 2>&1; then
    printf 'OK'
  else
    printf 'MISSING'
  fi
}

lan_redirect_status() {
  port="$1"
  printf '%s\n' "$nat_prerouting" | grep -F -- "-i br0" | grep -F -- "--to-ports $port" >/dev/null 2>&1 && printf 'OK' || printf 'MISSING'
}

input_status() {
  port="$1"
  printf '%s\n' "$filter_input" | grep -F -- "--dport $port" | grep -F -- "-j ACCEPT" >/dev/null 2>&1 && printf 'OK' || printf 'MISSING'
}

split_status() {
  inbound="$1"
  if printf '%s\n' "$singbox_config_compact" | grep -F -- "\"inbound\":\"$inbound\",\"rule_set\":[\"stealth-domains\",\"stealth-static\"],\"outbound\":\"reality-out\"" >/dev/null 2>&1 &&
    printf '%s\n' "$singbox_config_compact" | grep -F -- "\"inbound\":\"$inbound\",\"outbound\":\"direct-out\"" >/dev/null 2>&1; then
    printf 'OK'
  else
    printf 'MISSING'
  fi
}

log="/opt/var/log/sing-box.log"
tmp="/tmp/ghostroute-channels-check.$$"
trap 'rm -f "$tmp"' EXIT
if [ -f "$log" ]; then
  tail -5000 "$log" 2>/dev/null > "$tmp" || : > "$tmp"
else
  : > "$tmp"
fi

sanitize_line() {
  sed -E \
    -e 's/[0-9]{1,3}(\.[0-9]{1,3}){3}/<ip>/g' \
    -e 's/from <ip>:[0-9]+/from <ip>:<port>/g' \
    -e 's/to <ip>:[0-9]+/to <ip>:<port>/g'
}

reality_count="$(grep -F 'inbound/vless[reality-in]' "$tmp" 2>/dev/null | wc -l | tr -d ' ')"
channel_b_count="$(grep -F 'inbound/socks[channel-b-relay-socks]' "$tmp" 2>/dev/null | wc -l | tr -d ' ')"
sr_count="$(grep -F 'inbound/http[channel-c-shadowrocket-http-in]' "$tmp" 2>/dev/null | wc -l | tr -d ' ')"
native_count="$(grep -F 'inbound/naive[channel-c-naive-in]' "$tmp" 2>/dev/null | wc -l | tr -d ' ')"
reality_last="$(grep -F 'inbound/vless[reality-in]' "$tmp" 2>/dev/null | grep -F 'inbound connection to ' | tail -1 | sanitize_line || true)"
channel_b_last="$(grep -F 'inbound/socks[channel-b-relay-socks]' "$tmp" 2>/dev/null | grep -F 'inbound connection to ' | tail -1 | sanitize_line || true)"
sr_last="$(grep -F 'inbound/http[channel-c-shadowrocket-http-in]' "$tmp" 2>/dev/null | grep -F 'inbound connection to ' | tail -1 | sanitize_line || true)"
native_last="$(grep -F 'inbound/naive[channel-c-naive-in]' "$tmp" 2>/dev/null | grep -F 'inbound connection to ' | tail -1 | sanitize_line || true)"

redirect_listener="$(listener_status "$redirect_port")"
lan_redirect="$(lan_redirect_status "$redirect_port")"
reality_listener="$(listener_status "$home_reality_port")"
reality_input="$(input_status "$home_reality_port")"
reality_split="$(split_status reality-in)"
channel_b_listener="N/A"
channel_b_input="N/A"
if [ "$channel_b_enabled" = "1" ] && [ "$channel_b_port" != "0" ] && [ -n "$channel_b_port" ]; then
  channel_b_listener="$(listener_status "$channel_b_port")"
  channel_b_input="$(input_status "$channel_b_port")"
fi
channel_b_split="$(split_status channel-b-relay-socks)"
sr_listener="$(listener_status "$sr_port")"
sr_redirect="$(redirect_status "$sr_public" "$sr_port")"
sr_input="$(input_status "$sr_port")"
native_listener="$(listener_status "$home_port")"
native_redirect="$(redirect_status "$home_public" "$home_port")"
native_input="$(input_status "$home_port")"
native_split="$(split_status channel-c-naive-in)"
sr_split="$(split_status channel-c-shadowrocket-http-in)"

filter="${GHOSTROUTE_QUICK_FILTER:-all}"

printf 'GhostRoute Channels Quick Check\n'
if [ "$filter" = "all" ] || [ "$filter" = "channel-a" ]; then
  printf 'Channel A/LAN managed redirect: redirect-in=:%s listener=%s br0_redirect=%s\n' "$redirect_port" "$redirect_listener" "$lan_redirect"
  printf 'Channel A/Home Reality: public/internal=:%s listener=%s input=%s split=%s recent_log_lines=%s\n' "$home_reality_port" "$reality_listener" "$reality_input" "$reality_split" "${reality_count:-0}"
  if [ -n "$reality_last" ]; then
    printf 'Channel A last: %s\n' "$reality_last"
  else
    printf 'Channel A last: n/a in last 5000 sing-box log lines\n'
  fi
fi

if [ "$filter" = "all" ] || [ "$filter" = "channel-b" ]; then
  printf 'Channel B/home-first: enabled=%s public/internal=:%s listener=%s input=%s split=%s recent_relay_log_lines=%s\n' "$channel_b_enabled" "$channel_b_port" "$channel_b_listener" "$channel_b_input" "$channel_b_split" "${channel_b_count:-0}"
  if [ -n "$channel_b_last" ]; then
    printf 'Channel B last: %s\n' "$channel_b_last"
  else
    printf 'Channel B last: n/a in last 5000 sing-box log lines\n'
  fi
fi

if [ "$filter" = "all" ] || [ "$filter" = "channel-c" ]; then
  printf 'C1-Shadowrocket / 1-SR: enabled=%s public=:%s internal=:%s listener=%s redirect=%s input=%s split=%s recent_log_lines=%s\n' "$sr_enabled" "$sr_public" "$sr_port" "$sr_listener" "$sr_redirect" "$sr_input" "$sr_split" "${sr_count:-0}"
  if [ -n "$sr_last" ]; then
    printf 'C1-Shadowrocket last: %s\n' "$sr_last"
  else
    printf 'C1-Shadowrocket last: n/a in last 5000 sing-box log lines\n'
  fi
  printf 'C1-sing-box / native Naive: enabled=%s public=:%s internal=:%s listener=%s redirect=%s input=%s split=%s recent_log_lines=%s\n' "$home_enabled" "$home_public" "$home_port" "$native_listener" "$native_redirect" "$native_input" "$native_split" "${native_count:-0}"
  if [ -n "$native_last" ]; then
    printf 'C1-native last: %s\n' "$native_last"
  else
    printf 'C1-native last: n/a in last 5000 sing-box log lines; expected while tested iPhone SFI 1.11.4 lacks naive outbound\n'
  fi
fi

if [ "$redirect_listener" = "OK" ] && [ "$lan_redirect" = "OK" ] &&
  [ "$reality_listener" = "OK" ] && [ "$reality_input" = "OK" ] && [ "$reality_split" = "OK" ] &&
  { [ "$channel_b_enabled" != "1" ] || { [ "$channel_b_listener" = "OK" ] && [ "$channel_b_input" = "OK" ] && [ "$channel_b_split" = "OK" ]; }; } &&
  [ "$sr_listener" = "OK" ] && [ "$sr_redirect" != "MISSING" ] && [ "$sr_input" = "OK" ] && [ "$sr_split" = "OK" ]; then
  printf 'Decision: OK - fast channel invariants are green. C1-Shadowrocket is the current working Channel C client lane.\n'
else
  printf 'Decision: WARN - one or more fast channel invariants are incomplete; check the MISSING fields above.\n'
fi
printf 'Note: this quick check tails only the latest 5000 sing-box log lines and does not build the full daily traffic report.\n'
REMOTE
}

case "$PERIOD_ARG" in
  check|quick|channels|channel-check|--check)
    channels_quick_report all
    exit 0
    ;;
  channel-a|channel-a-check|a)
    channels_quick_report channel-a
    exit 0
    ;;
  channel-b|channel-b-check|b)
    channels_quick_report channel-b
    exit 0
    ;;
  channel-c|channel-c-check|c|quick-channel-c|--channel-c)
    channels_quick_report channel-c
    exit 0
    ;;
  ""|today|current|current-day) ;;
  yesterday|week|month|[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9])
    exec "${PROJECT_ROOT}/modules/traffic-observatory/bin/traffic-daily-report" "$PERIOD_ARG"
    ;;
  *)
    echo "Usage: ./modules/traffic-observatory/bin/traffic-report [today|yesterday|week|month|YYYY-MM-DD|check|channel-a|channel-b|channel-c]" >&2
    exit 1
    ;;
esac

TMPDIR="$(mktemp -d)"
trap 'rm -rf "$TMPDIR"' EXIT

STATE_FILE="$TMPDIR/state.txt"
CURRENT_COUNTERS="$TMPDIR/current-counters.tsv"
HISTORY_COUNTERS="$TMPDIR/history-counters.tsv"
LAN_BYTES_HISTORY="$TMPDIR/lan-device-counters.tsv"
LAN_BYTES_CURRENT="$TMPDIR/lan-device-counters-current.tsv"
LAN_BYTES_BASE="$TMPDIR/lan-device-counters-base.tsv"
LAN_BYTES_PARSED="$TMPDIR/lan-device-bytes.txt"
LAN_ALIAS_MAP="$TMPDIR/lan-alias-map.txt"
DEVICE_METADATA_MAP="$TMPDIR/device-metadata-map.txt"
DEVICE_MIX_TOTALS="$TMPDIR/device-mix-totals.txt"
DEVICE_TOP_REALITY="$TMPDIR/device-top-reality.txt"
DEVICE_TOP_WAN="$TMPDIR/device-top-wan.txt"
MOBILE_LOG="$TMPDIR/mobile-reality.log"
MOBILE_TOTALS="$TMPDIR/mobile-reality-totals.txt"
MOBILE_CLIENTS="$TMPDIR/mobile-reality-clients.txt"
MOBILE_DESTS="$TMPDIR/mobile-reality-dests.txt"
CHANNEL_COMBINED_LOG="$TMPDIR/channel-combined.log"
CHANNEL_B_RELAY_LOG="$TMPDIR/channel-b-relay.log"
CHANNEL_B_HOME_LOG="$TMPDIR/channel-b-home.log"
CHANNEL_B_RELAY_TOTALS="$TMPDIR/channel-b-relay-totals.txt"
CHANNEL_B_RELAY_DESTS="$TMPDIR/channel-b-relay-dests.txt"
CHANNEL_B_HOME_STATE="$TMPDIR/channel-b-home-state.txt"
CHANNEL_C_LOG="$TMPDIR/channel-c.log"
CHANNEL_C_TOTALS="$TMPDIR/channel-c-totals.txt"
CHANNEL_C_CLIENTS="$TMPDIR/channel-c-clients.txt"
CHANNEL_C_DESTS="$TMPDIR/channel-c-dests.txt"
MOBILE_ALIAS_MAP="$TMPDIR/mobile-alias-map.txt"
CHANNEL_B_HOME_ENABLED="0"
CHANNEL_B_HOME_PORT="0"
HOME_REALITY_PORT="0"
BHOME_IN_BYTES="0"
BHOME_OUT_BYTES="0"
BHOME_PACKETS="0"
MOBILE_BYTES_HISTORY="$TMPDIR/mobile-reality-counters.tsv"
MOBILE_BYTES_CURRENT="$TMPDIR/mobile-reality-counters-current.tsv"
MOBILE_BYTES_BASE="$TMPDIR/mobile-reality-counters-base.tsv"
MOBILE_BYTES_PARSED="$TMPDIR/mobile-reality-bytes.txt"
MOBILE_BYTES_TOTALS="$TMPDIR/mobile-reality-byte-totals.txt"
MOBILE_BYTES_ATTRIBUTED="$TMPDIR/mobile-reality-attributed.txt"
MOBILE_BYTES_LAN_HAIRPIN="$TMPDIR/mobile-reality-lan-hairpin.txt"
MOBILE_BYTES_UNKNOWN_EXTERNAL="$TMPDIR/mobile-reality-unknown-external.txt"
MOBILE_BYTES_CATEGORY_TOTALS="$TMPDIR/mobile-reality-category-totals.txt"
ROUTING_WARN_RU_VPS="$TMPDIR/routing-warn-ru-vps.txt"
ROUTING_WARN_MANAGED_DIRECT="$TMPDIR/routing-warn-managed-direct.txt"
ROUTING_WARN_CATALOG_RU="$TMPDIR/routing-warn-catalog-ru.txt"
CURRENT_TAILSCALE="$TMPDIR/current-tailscale.json"
BASE_TAILSCALE="$TMPDIR/base-tailscale.json"
TAILSCALE_PARSED="$TMPDIR/tailscale.txt"
TAILSCALE_TOP_SUMMARY="$TMPDIR/tailscale-top-summary.txt"
DNS_FORENSICS_TODAY="$TMPDIR/dns-forensics-today.tsv"
USER_CHANNEL_TOTALS="$TMPDIR/user-channel-totals.tsv"
USER_CHANNEL_APPS="$TMPDIR/user-channel-apps.tsv"
LAN_USER_APPS="$TMPDIR/lan-user-apps.tsv"

human_gib() {
  awk -v bytes="${1:-0}" 'BEGIN { printf "%.2f GiB", bytes / 1024 / 1024 / 1024; }'
}

human_bytes() {
  awk -v bytes="${1:-0}" '
    BEGIN {
      if (bytes >= 1024 * 1024 * 1024) printf "%.2f GiB", bytes / 1024 / 1024 / 1024;
      else if (bytes >= 1024 * 1024) printf "%.1f MiB", bytes / 1024 / 1024;
      else if (bytes >= 1024) printf "%.1f KiB", bytes / 1024;
      else printf "%d B", bytes;
    }'
}

human_pct() {
  awk -v part="${1:-0}" -v total="${2:-0}" '
    BEGIN {
      if (total <= 0) printf "n/a";
      else printf "%.1f%%", (part / total) * 100;
    }'
}

estimate_share_bytes() {
  local total_bytes="${1:-0}"
  local part="${2:-0}"
  local total="${3:-0}"
  awk -v bytes="$total_bytes" -v part="$part" -v total="$total" '
    BEGIN {
      if (total <= 0 || bytes <= 0) print 0;
      else printf "%.0f\n", bytes * part / total;
    }'
}

delta_or_current() {
  local current="${1:-0}"
  local base="${2:-0}"
  if [ "$current" -ge "$base" ]; then
    echo $((current - base))
  else
    echo "$current"
  fi
}

clean_int() {
  local value="${1:-0}"
  case "$value" in
    ''|*[!0-9]*)
      echo 0
      ;;
    *)
      echo "$value"
      ;;
  esac
}

apply_device_metadata() {
  [ -s "$DEVICE_METADATA_MAP" ] || return 0
  [ -s "$LAN_BYTES_PARSED" ] || return 0

  awk -F'|' '
    BEGIN { OFS="|" }
    NR == FNR {
      label[$1] = $2
      next
    }
    {
      if (($1 in label) && label[$1] != "") $2 = label[$1]
      print
    }
  ' "$DEVICE_METADATA_MAP" "$LAN_BYTES_PARSED" > "$LAN_BYTES_PARSED.metadata" && mv "$LAN_BYTES_PARSED.metadata" "$LAN_BYTES_PARSED"
}

redact_report_tables() {
  [ "$REPORT_REDACT_NAMES" = "1" ] || return 0
  [ -s "$LAN_BYTES_PARSED" ] || return 0

  awk -F'|' '
    BEGIN { OFS = "|" }
    NR == FNR {
      if ($3 != "") type[$1] = $3
      next
    }
    $1 != "" && !seen[$1]++ {
      suffix = (($1 in type) && type[$1] != "") ? " (" type[$1] ")" : ""
      printf "%s|lan-host-%02d%s\n", $1, ++idx, suffix
    }
  ' "$DEVICE_METADATA_MAP" "$LAN_BYTES_PARSED" > "$LAN_ALIAS_MAP"

  awk -F'|' '
    BEGIN { OFS="|" }
    NR == FNR {
      alias[$1] = $2
      next
    }
    {
      if ($1 in alias) $2 = alias[$1]
      print
    }' "$LAN_ALIAS_MAP" "$LAN_BYTES_PARSED" > "$LAN_BYTES_PARSED.redacted" && mv "$LAN_BYTES_PARSED.redacted" "$LAN_BYTES_PARSED"
}

router_ssh 'sh -s' <<'REMOTE' > "$STATE_FILE"
set -e
STATE_DIR="/jffs/addons/router_configuration/traffic"
[ -x /opt/bin/opkg ] && STATE_DIR="/opt/var/log/router_configuration"
mkdir -p "$STATE_DIR" "$STATE_DIR/tailscale"

RUNTIME_ENV=""
CHANNEL_B_HOME_ENABLED="0"
CHANNEL_B_HOME_PORT=""
HOME_REALITY_PORT=""
BHOME_PACKETS="0"

for candidate in /jffs/scripts/ghostroute-runtime.env /jffs/scripts/ghostroute-runtime-env; do
  if [ -f "$candidate" ]; then
    RUNTIME_ENV="$candidate"
    break
  fi
done

if [ -n "$RUNTIME_ENV" ]; then
  CHANNEL_B_HOME_ENABLED="$(awk -F= '/^GHOSTROUTE_CHANNEL_B_HOME_ENABLED=/{print $2; exit}' "$RUNTIME_ENV")"
  CHANNEL_B_HOME_PORT="$(awk -F= '/^GHOSTROUTE_CHANNEL_B_HOME_PORT=/{print $2; exit}' "$RUNTIME_ENV")"
  HOME_REALITY_PORT="$(awk -F= '/^GHOSTROUTE_HOME_REALITY_PORT=/{print $2; exit}' "$RUNTIME_ENV")"
fi

if [ -f /jffs/scripts/stealth-route-init.sh ]; then
  CHANNEL_B_HOME_ENABLED="${CHANNEL_B_HOME_ENABLED:-$(awk -F= '/^CHANNEL_B_HOME_ENABLED=/{gsub(/["'\''"]/, "", $2); print $2; exit}' /jffs/scripts/stealth-route-init.sh)}"
  CHANNEL_B_HOME_PORT="${CHANNEL_B_HOME_PORT:-$(awk -F= '/^CHANNEL_B_HOME_PORT=/{gsub(/["'\''"]/, "", $2); print $2; exit}' /jffs/scripts/stealth-route-init.sh)}"
  HOME_REALITY_PORT="${HOME_REALITY_PORT:-$(awk -F= '/^HOME_REALITY_PORT=/{gsub(/["'\''"]/, "", $2); print $2; exit}' /jffs/scripts/stealth-route-init.sh)}"
fi

case "$CHANNEL_B_HOME_ENABLED" in
  1) ;;
  *) CHANNEL_B_HOME_ENABLED="0" ;;
esac

BHOME_IN_BYTES="0"
BHOME_OUT_BYTES="0"
BHOME_PACKETS="0"
if [ "$CHANNEL_B_HOME_ENABLED" = "1" ] && [ -n "$CHANNEL_B_HOME_PORT" ]; then
  case "$CHANNEL_B_HOME_PORT" in
    ''|*[!0-9]*)
      ;;
    *)
      BHOME_COUNTERS="$(iptables-save -t filter -c 2>/dev/null | awk -v port="$CHANNEL_B_HOME_PORT" '
        $1 ~ /^\[[0-9]+:[0-9]+\]$/ &&
        $0 ~ /-A INPUT/ &&
        $0 ~ /-p tcp/ &&
        $0 ~ "--dport " port &&
        $0 ~ /-j ACCEPT/ {
          counters = $1
          gsub(/\[/, "", counters)
          gsub(/\]/, "", counters)
          split(counters, parts, ":")
          packets += parts[1]
          bytes += parts[2]
        }
        END { printf "%d|%d\n", packets, bytes }
      ' || true)"
      BHOME_PACKETS="${BHOME_COUNTERS%%|*}"
      BHOME_IN_BYTES="${BHOME_COUNTERS#*|}"
      ;;
  esac
fi

case "$BHOME_IN_BYTES" in
  ''|*[!0-9]*)
    BHOME_IN_BYTES="0"
    ;;
esac
case "$BHOME_OUT_BYTES" in
  ''|*[!0-9]*)
    BHOME_OUT_BYTES="0"
    ;;
esac
case "$BHOME_PACKETS" in
  ''|*[!0-9]*)
    BHOME_PACKETS="0"
    ;;
esac

printf "STATE_DIR=%s\n" "$STATE_DIR"
printf "WAN_IP=%s\n" "$(nvram get wan0_ipaddr 2>/dev/null || true)"
printf "TODAY=%s\n" "$(date +%Y-%m-%d)"
printf "BHOME|%s|%s|%s|%s|%s|%s\n" \
  "$CHANNEL_B_HOME_ENABLED" "$CHANNEL_B_HOME_PORT" "$HOME_REALITY_PORT" "$BHOME_IN_BYTES" "$BHOME_OUT_BYTES" "$BHOME_PACKETS"

for iface in wan0 br0 eth6 eth7; do
  if [ -d "/sys/class/net/$iface" ]; then
    rx=$(cat "/sys/class/net/$iface/statistics/rx_bytes")
    tx=$(cat "/sys/class/net/$iface/statistics/tx_bytes")
    printf "CUR|%s|%s|%s\n" "$iface" "$rx" "$tx"
  fi
done

[ -f "$STATE_DIR/interface-counters.tsv" ] && cat "$STATE_DIR/interface-counters.tsv" || true
REMOTE

awk -F'|' '$1 == "CUR" { print $2 "|" $3 "|" $4 }' "$STATE_FILE" > "$CURRENT_COUNTERS"
awk -F'|' '$1 != "CUR" && NF == 4 { print $0 }' "$STATE_FILE" > "$HISTORY_COUNTERS"
awk -F'|' '$1 == "BHOME" { print }' "$STATE_FILE" > "$CHANNEL_B_HOME_STATE"

TODAY="$(awk -F= '/^TODAY=/{print $2}' "$STATE_FILE")"
