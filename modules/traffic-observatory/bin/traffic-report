  echo
  printf "%-18s %8s %8s %8s %12s %12s %10s\n" "Client/profile" "Conn" "VPS" "Direct" "VPS est." "RU est." "Unresolved"
  awk -F'|' -v mobile_bytes="$MOBILE_BYTE_TOTAL" -v mobile_total="$MOBILE_TOTAL" '
    function human_bytes(x) {
      x += 0
      if (x >= 1024 * 1024 * 1024) return sprintf("%.2f GiB", x / 1024 / 1024 / 1024)
      if (x >= 1024 * 1024) return sprintf("%.1f MiB", x / 1024 / 1024)
      if (x >= 1024) return sprintf("%.1f KiB", x / 1024)
      return sprintf("%d B", x)
    }
    NR <= 8 {
      total = $2 + 0
      vps = $3 + 0
      direct = $4 + 0
      vps_bytes = mobile_total > 0 ? mobile_bytes * vps / mobile_total : 0
      direct_bytes = mobile_total > 0 ? mobile_bytes * direct / mobile_total : 0
      printf "%-18s %8d %8d %8d %12s %12s %10d\n", $1, total, vps, direct, human_bytes(vps_bytes), human_bytes(direct_bytes), $5
    }' "$MOBILE_CLIENTS"
fi
if [ -s "$MOBILE_BYTES_PARSED" ]; then
  echo
  printf "%-24s %12s %12s %12s %12s %12s %9s\n" "Ingress source" "Total" "Upload" "Download" "VPS est." "RU est." "VPS share"
  awk -F'|' -v clients_file="$MOBILE_CLIENTS" -v global_total="$MOBILE_TOTAL" -v global_vps="$MOBILE_REALITY" -v global_direct="$MOBILE_DIRECT" '
    function human_bytes(x) {
      x += 0
      if (x >= 1024 * 1024 * 1024) return sprintf("%.2f GiB", x / 1024 / 1024 / 1024)
      if (x >= 1024 * 1024) return sprintf("%.1f MiB", x / 1024 / 1024)
      if (x >= 1024) return sprintf("%.1f KiB", x / 1024)
      return sprintf("%d B", x)
    }
    function pct(part, total) {
      part += 0
      total += 0
      if (total <= 0) return "n/a"
      return sprintf("%.1f%%", (part / total) * 100)
    }
    BEGIN {
      while ((getline line < clients_file) > 0) {
        split(line, fields, "|")
        client_total[fields[1]] = fields[2] + 0
        client_vps[fields[1]] = fields[3] + 0
        client_direct[fields[1]] = fields[4] + 0
      }
      close(clients_file)
    }
    ($5 + 0) > 0 && NR <= 8 {
      label = $2
      bytes = $5 + 0
      if ((label in client_total) && client_total[label] > 0) {
        split_total = client_total[label]
        split_vps = client_vps[label]
        split_direct = client_direct[label]
      } else {
        split_total = global_total + 0
        split_vps = global_vps + 0
        split_direct = global_direct + 0
      }
      vps_bytes = split_total > 0 ? bytes * split_vps / split_total : 0
      direct_bytes = split_total > 0 ? bytes * split_direct / split_total : 0
      printf "%-24s %12s %12s %12s %12s %12s %9s\n", label, human_bytes(bytes), human_bytes($3), human_bytes($4), human_bytes(vps_bytes), human_bytes(direct_bytes), pct(vps_bytes, bytes)
    }' "$MOBILE_BYTES_PARSED"
fi
if [ -s "$MOBILE_BYTES_LAN_HAIRPIN" ]; then
  echo
  echo "Home Reality used from inside LAN:"
  printf "%-24s %12s %12s %12s\n" "LAN hairpin source" "Total" "Upload" "Download"
  awk -F'|' '
    function human_bytes(x) {
      x += 0
      if (x >= 1024 * 1024 * 1024) return sprintf("%.2f GiB", x / 1024 / 1024 / 1024)
      if (x >= 1024 * 1024) return sprintf("%.1f MiB", x / 1024 / 1024)
      if (x >= 1024) return sprintf("%.1f KiB", x / 1024)
      return sprintf("%d B", x)
    }
    ($5 + 0) > 0 {
      printf "%-24s %12s %12s %12s\n", $2, human_bytes($5), human_bytes($3), human_bytes($4)
    }' "$MOBILE_BYTES_LAN_HAIRPIN"
fi
if [ -s "$MOBILE_BYTES_UNKNOWN_EXTERNAL" ]; then
  echo
  echo "Unattributed external ingress sources:"
  printf "%-24s %12s %12s %12s\n" "External source" "Total" "Upload" "Download"
  awk -F'|' '
    function human_bytes(x) {
      x += 0
      if (x >= 1024 * 1024 * 1024) return sprintf("%.2f GiB", x / 1024 / 1024 / 1024)
      if (x >= 1024 * 1024) return sprintf("%.1f MiB", x / 1024 / 1024)
      if (x >= 1024) return sprintf("%.1f KiB", x / 1024)
      return sprintf("%d B", x)
    }
    NR <= 8 && ($5 + 0) > 0 {
      printf "%-24s %12s %12s %12s\n", $2, human_bytes($5), human_bytes($3), human_bytes($4)
    }' "$MOBILE_BYTES_UNKNOWN_EXTERNAL"
fi
echo

echo "=== 7. SITES / DESTINATIONS ==="
echo "Scope: Channel A/Home Reality includes estimated bytes. Channel B/C include destination connection split; byte attribution is not available yet for those lanes."
if [ -s "$MOBILE_DESTS" ] && [ "${MOBILE_TOTAL:-0}" -gt 0 ] && [ "${MOBILE_BYTE_TOTAL:-0}" -gt 0 ]; then
  echo "Top Home Reality / Channel A ingress destinations overall (estimated bytes from ingress traffic):"
  printf "%-20s %-38s %12s %9s %-20s %s\n" "App/family" "Destination" "Est. traffic" "% ingress" "Path" "Split"
  awk -F'|' -v mobile_bytes="$MOBILE_BYTE_TOTAL" -v mobile_total="$MOBILE_TOTAL" '
    function human_bytes(x) {
      x += 0
      if (x >= 1024 * 1024 * 1024) return sprintf("%.2f GiB", x / 1024 / 1024 / 1024)
      if (x >= 1024 * 1024) return sprintf("%.1f MiB", x / 1024 / 1024)
      if (x >= 1024) return sprintf("%.1f KiB", x / 1024)
      return sprintf("%d B", x)
    }
    function pct(part, total) {
      part += 0
      total += 0
      if (total <= 0) return "n/a"
      return sprintf("%.1f%%", (part / total) * 100)
    }
    function family(dest,   d) {
      d = tolower(dest)
      if (d ~ /(youtube|googlevideo|ytimg|ggpht|googleapis|googleusercontent)/) return "Google/YouTube"
      if (d ~ /(telegram|t\.me|149\.154\.)/) return "Telegram"
      if (d ~ /(instagram|cdninstagram|facebook|fbcdn)/) return "Meta"
      if (d ~ /(whatsapp|whatsapp\.net)/) return "WhatsApp"
      if (d ~ /(apple|icloud|itunes|mzstatic|push\.apple)/) return "Apple/iCloud"
      if (d ~ /(amazonaws|s3|cloudfront)/) return "AWS/CDN"
      if (d ~ /(cloudflare|1\.1\.1\.1|8\.8\.8\.8|9\.9\.9\.9)/) return "DNS/CDN"
      if (d ~ /(yandex|kinopoisk|vk\.com|ok\.ru|mail\.ru|ozon|wildberries|avito|sber|tinkoff|tbank|gosuslugi|dzen)/) return "RU services"
      if (d ~ /(openai|anthropic|claude|chatgpt)/) return "AI services"
      return "Other"
    }
    NR <= 12 {
      total = $2 + 0
      reality = $3 + 0
      direct = $4 + 0
      bytes = mobile_bytes * total / mobile_total
      path = "mixed"
      if (reality > 0 && direct == 0) path = "VPS"
      else if (direct > 0 && reality == 0) path = "Home RU direct"
      else if (reality >= direct) path = "mostly VPS"
      else path = "mostly Home RU direct"
      printf "%-20s %-38s %12s %9s %-20s R %d / D %d\n", family($1), $1, human_bytes(bytes), pct(total, mobile_total), path, reality, direct
    }' "$MOBILE_DESTS"

  echo
  echo "Popular via VPS (Channel A/Home Reality estimated; final site sees VPS exit IP):"
  printf "%-20s %-38s %12s %9s %s\n" "App/family" "Destination" "Est. traffic" "% ingress" "Reality conn"
  awk -F'|' '($3 + 0) > 0 { print $3 "|" $0 }' "$MOBILE_DESTS" \
    | sort -t'|' -k1,1nr -k2,2 \
    | head -10 \
    | awk -F'|' -v mobile_bytes="$MOBILE_BYTE_TOTAL" -v mobile_total="$MOBILE_TOTAL" '
      function human_bytes(x) {
        x += 0
        if (x >= 1024 * 1024 * 1024) return sprintf("%.2f GiB", x / 1024 / 1024 / 1024)
        if (x >= 1024 * 1024) return sprintf("%.1f MiB", x / 1024 / 1024)
        if (x >= 1024) return sprintf("%.1f KiB", x / 1024)
        return sprintf("%d B", x)
      }
      function pct(part, total) {
        part += 0
        total += 0
        if (total <= 0) return "n/a"
        return sprintf("%.1f%%", (part / total) * 100)
      }
      function family(dest,   d) {
        d = tolower(dest)
        if (d ~ /(youtube|googlevideo|ytimg|ggpht|googleapis|googleusercontent)/) return "Google/YouTube"
        if (d ~ /(telegram|t\.me|149\.154\.)/) return "Telegram"
        if (d ~ /(instagram|cdninstagram|facebook|fbcdn)/) return "Meta"
        if (d ~ /(whatsapp|whatsapp\.net)/) return "WhatsApp"
        if (d ~ /(apple|icloud|itunes|mzstatic|push\.apple)/) return "Apple/iCloud"
        if (d ~ /(amazonaws|s3|cloudfront)/) return "AWS/CDN"
        if (d ~ /(cloudflare|1\.1\.1\.1|8\.8\.8\.8|9\.9\.9\.9)/) return "DNS/CDN"
        if (d ~ /(yandex|kinopoisk|vk\.com|ok\.ru|mail\.ru|ozon|wildberries|avito|sber|tinkoff|tbank|gosuslugi|dzen)/) return "RU services"
        if (d ~ /(openai|anthropic|claude|chatgpt)/) return "AI services"
        return "Other"
      }
      {
        dest = $2
        reality = $4 + 0
        bytes = mobile_bytes * reality / mobile_total
        printf "%-20s %-38s %12s %9s %d\n", family(dest), dest, human_bytes(bytes), pct(reality, mobile_total), reality
      }'

  echo
  echo "Popular via home RU direct (Channel A/Home Reality estimated; final site sees home Russian IP):"
  printf "%-20s %-38s %12s %9s %s\n" "App/family" "Destination" "Est. traffic" "% ingress" "Direct conn"
  awk -F'|' '($4 + 0) > 0 { print $4 "|" $0 }' "$MOBILE_DESTS" \
    | sort -t'|' -k1,1nr -k2,2 \
    | head -10 \
    | awk -F'|' -v mobile_bytes="$MOBILE_BYTE_TOTAL" -v mobile_total="$MOBILE_TOTAL" '
      function human_bytes(x) {
        x += 0
        if (x >= 1024 * 1024 * 1024) return sprintf("%.2f GiB", x / 1024 / 1024 / 1024)
        if (x >= 1024 * 1024) return sprintf("%.1f MiB", x / 1024 / 1024)
        if (x >= 1024) return sprintf("%.1f KiB", x / 1024)
        return sprintf("%d B", x)
      }
      function pct(part, total) {
        part += 0
        total += 0
        if (total <= 0) return "n/a"
        return sprintf("%.1f%%", (part / total) * 100)
      }
      function family(dest,   d) {
        d = tolower(dest)
        if (d ~ /(youtube|googlevideo|ytimg|ggpht|googleapis|googleusercontent)/) return "Google/YouTube"
        if (d ~ /(telegram|t\.me|149\.154\.)/) return "Telegram"
        if (d ~ /(instagram|cdninstagram|facebook|fbcdn)/) return "Meta"
        if (d ~ /(whatsapp|whatsapp\.net)/) return "WhatsApp"
        if (d ~ /(apple|icloud|itunes|mzstatic|push\.apple)/) return "Apple/iCloud"
        if (d ~ /(amazonaws|s3|cloudfront)/) return "AWS/CDN"
        if (d ~ /(cloudflare|1\.1\.1\.1|8\.8\.8\.8|9\.9\.9\.9)/) return "DNS/CDN"
        if (d ~ /(yandex|kinopoisk|vk\.com|ok\.ru|mail\.ru|ozon|wildberries|avito|sber|tinkoff|tbank|gosuslugi|dzen)/) return "RU services"
        if (d ~ /(openai|anthropic|claude|chatgpt)/) return "AI services"
        return "Other"
      }
      {
        dest = $2
        direct = $5 + 0
        bytes = mobile_bytes * direct / mobile_total
        printf "%-20s %-38s %12s %9s %d\n", family(dest), dest, human_bytes(bytes), pct(direct, mobile_total), direct
      }'
elif [ -s "$MOBILE_DESTS" ]; then
  printf "%-44s %8s %-18s %s\n" "Destination" "Conn" "Path" "Split"
  awk -F'|' '
    NR <= 12 {
      path = "mixed"
      if (($3 + 0) > 0 && ($4 + 0) == 0) path = "VPS"
      else if (($4 + 0) > 0 && ($3 + 0) == 0) path = "Home RU direct"
      else if (($3 + 0) >= ($4 + 0)) path = "mostly VPS"
      else path = "mostly Home RU direct"
      printf "%-44s %8d %-18s Reality %d / Direct %d\n", $1, $2, path, $3, $4
    }' "$MOBILE_DESTS"
  echo "No Channel A/Home Reality byte baseline yet, so destination traffic is shown as connections only."
else
  echo "No Channel A/Home Reality destination log data for today."
fi
echo

echo "Channel B destinations (connection split; byte attribution n/a for local SOCKS relay):"
if [ -s "$CHANNEL_B_RELAY_DESTS" ] && [ "$CHANNEL_B_RELAY_CONN" -gt 0 ]; then
  printf "%-44s %8s %8s %8s %10s\n" "Destination" "Conn" "VPS" "Direct" "Unresolved"
  awk -F'|' '
    NR <= 12 {
      printf "%-44s %8d %8d %8d %10d\n", $1, $2 + 0, $3 + 0, $4 + 0, $5 + 0
    }' "$CHANNEL_B_RELAY_DESTS"
else
  echo "No Channel B destination log data for today."
fi
echo

echo "Channel C destinations (connection split; byte attribution n/a for C1 inbounds):"
if [ -s "$CHANNEL_C_DESTS" ] && [ "$CHANNEL_C_CONN" -gt 0 ]; then
  printf "%-44s %8s %8s %8s %10s\n" "Destination" "Conn" "VPS" "Direct" "Unresolved"
  awk -F'|' '
    NR <= 12 {
      printf "%-44s %8d %8d %8d %10d\n", $1, $2 + 0, $3 + 0, $4 + 0, $5 + 0
    }' "$CHANNEL_C_DESTS"

  if [ -s "$CHANNEL_C_CLIENTS" ]; then
    echo
    printf "%-24s %8s %8s %8s %10s\n" "Channel C client" "Conn" "VPS" "Direct" "Unresolved"
    awk -F'|' '
      NR <= 8 {
        printf "%-24s %8d %8d %8d %10d\n", $1, $2 + 0, $3 + 0, $4 + 0, $5 + 0
      }' "$CHANNEL_C_CLIENTS"
  fi
else
  echo "No Channel C destination log data for today."
fi
echo

echo "=== 8. ROUTING MISTAKES / CHECKS ==="
mistakes=0
if [ -s "$ROUTING_WARN_RU_VPS" ]; then
  mistakes=$((mistakes + 1))
  echo "WARN: RU/direct-looking Home Reality destinations used VPS:"
  awk -F'|' -v mobile_bytes="$MOBILE_BYTE_TOTAL" -v mobile_total="$MOBILE_TOTAL" '
    function human_bytes(x) {
      x += 0
      if (x >= 1024 * 1024 * 1024) return sprintf("%.2f GiB", x / 1024 / 1024 / 1024)
      if (x >= 1024 * 1024) return sprintf("%.1f MiB", x / 1024 / 1024)
      if (x >= 1024) return sprintf("%.1f KiB", x / 1024)
      return sprintf("%d B", x)
    }
    NR <= 8 {
      bytes = mobile_total > 0 ? mobile_bytes * ($3 + 0) / mobile_total : 0
      printf "  %-36s est=%s total=%d reality=%d direct=%d\n", $1, human_bytes(bytes), $2, $3, $4
    }' "$ROUTING_WARN_RU_VPS"
else
  echo "OK: no RU/direct-looking Home Reality destination via VPS found in today logs."
fi
if [ -s "$ROUTING_WARN_MANAGED_DIRECT" ]; then
  mistakes=$((mistakes + 1))
  echo "WARN: managed-looking Home Reality destinations had direct-out connections:"
  awk -F'|' -v mobile_bytes="$MOBILE_BYTE_TOTAL" -v mobile_total="$MOBILE_TOTAL" '
    function human_bytes(x) {
      x += 0
      if (x >= 1024 * 1024 * 1024) return sprintf("%.2f GiB", x / 1024 / 1024 / 1024)
      if (x >= 1024 * 1024) return sprintf("%.1f MiB", x / 1024 / 1024)
      if (x >= 1024) return sprintf("%.1f KiB", x / 1024)
      return sprintf("%d B", x)
    }
    NR <= 8 {
      bytes = mobile_total > 0 ? mobile_bytes * ($4 + 0) / mobile_total : 0
      printf "  %-36s est=%s total=%d reality=%d direct=%d\n", $1, human_bytes(bytes), $2, $3, $4
    }' "$ROUTING_WARN_MANAGED_DIRECT"
else
  echo "OK: no obvious managed Home Reality destination went direct."
fi
dns_direct="$(awk -F'|' '$1 == "1.1.1.1" || $1 == "8.8.8.8" || $1 == "9.9.9.9" { direct += $4 + 0 } END { print direct + 0 }' "$MOBILE_DESTS" 2>/dev/null || printf '0')"
if [ "${dns_direct:-0}" -gt 0 ]; then
  mistakes=$((mistakes + 1))
  echo "REVIEW: Home Reality direct resolver-like destinations observed: ${dns_direct} direct connections."
  echo "  This is not automatically an LTE DNS leak. It means traffic already inside"
  echo "  the Home Reality tunnel reached resolver-like IPs and then exited via"
  echo "  home Russian direct, so the destination sees the home Russian IP."
  awk -F'|' -v mobile_bytes="$MOBILE_BYTE_TOTAL" -v mobile_total="$MOBILE_TOTAL" '
    function human_bytes(x) {
      x += 0
      if (x >= 1024 * 1024 * 1024) return sprintf("%.2f GiB", x / 1024 / 1024 / 1024)
      if (x >= 1024 * 1024) return sprintf("%.1f MiB", x / 1024 / 1024)
      if (x >= 1024) return sprintf("%.1f KiB", x / 1024)
      return sprintf("%d B", x)
    }
    ($1 == "1.1.1.1" || $1 == "8.8.8.8" || $1 == "9.9.9.9") && ($4 + 0) > 0 {
      bytes = mobile_total > 0 ? mobile_bytes * ($4 + 0) / mobile_total : 0
      printf "  %-36s est=%s total=%d reality=%d direct=%d\n", $1, human_bytes(bytes), $2 + 0, $3 + 0, $4 + 0
    }' "$MOBILE_DESTS"
else
  echo "OK: no Home Reality direct DNS-like destinations observed."
fi
if [ "${MOBILE_UNRESOLVED:-0}" -gt 0 ]; then
  mistakes=$((mistakes + 1))
  echo "WARN: Home Reality unresolved connections: ${MOBILE_UNRESOLVED}."
else
  echo "OK: Home Reality unresolved connections: 0."
fi
if [ -s "$ROUTING_WARN_CATALOG_RU" ]; then
  mistakes=$((mistakes + 1))
  echo "REVIEW: RU-looking domains currently present in managed catalog:"
  awk 'NR <= 10 { printf "  %s\n", $0 }' "$ROUTING_WARN_CATALOG_RU"
else
  echo "OK: no obvious RU-looking domain in managed catalog."
fi
echo
echo "=== NOTES ==="
echo "- Site sees VPS for VLESS+Reality -> VPS paths; site sees home Russian IP for Home WAN direct paths."
echo "- LAN/Wi-Fi VPS/direct bytes are exact mangle byte counters."
echo "- USERS / APPS BY CHANNEL is the primary rollup for user names, A/B/C channels and app families."
echo "- LAN app families are DNS-interest counts, not per-app byte totals; Channel A app bytes are estimated from ingress connection share."
echo "- LAN/Wi-Fi RU direct means device -> home router -> home ISP/WAN -> destination. It often includes Russian services, but can also include foreign sites outside STEALTH_DOMAINS, Apple/CDN/API/background traffic, and resolver-like infrastructure."
echo "- Home Reality ingress bytes are exact TCP/<home-reality-port> counters; VPS/direct bytes for this ingress are estimated from connection split until per-outbound byte attribution is added."
echo "- SITES / DESTINATIONS gives estimated bytes for Channel A/Home Reality and connection-level destination split for Channel B/C. B/C per-destination byte attribution is not implemented yet."
echo "- Home Reality used from inside LAN usually means a QR/Home Reality profile was active while the device was on home Wi-Fi; this is tracked separately as LAN hairpin traffic."
echo "- Unattributed external ingress sources are byte-counter sources that were not confidently tied to a VLESS client identity in the current log window; review sustained high volume before blocking anything."
echo "- Home Reality direct-out can be Russian sites, Apple/CDN/API traffic, resolver-like IPs, or any destination not matched by STEALTH_DOMAINS/VPN_STATIC_NETS; it exits via home Russian IP."
echo "- Channel C current working variant is C1-Shadowrocket / 1-SR on :4443. It is not native Naive; it is HTTPS CONNECT compatibility."
echo "- Channel C native Naive on :443 is the intended stealth-primary design, but tested iPhone SFI 1.11.4 cannot run outbound type naive yet."
echo "- Resolver-like direct-out is a review signal, not necessarily your mistake and not proof of LTE-side DNS leak."
echo "- Routing mistakes are heuristics: WARN means review catalog/no-vpn rules, not automatic proof of breakage."
if [ "$REPORT_REDACT_NAMES" = "1" ]; then
  echo "- LAN/mobile names are redacted by default. Use REPORT_REDACT_NAMES=0 for trusted local inspection."
fi
