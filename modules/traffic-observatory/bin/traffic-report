iface_current() {
  local iface="$1"
  local column="$2"
  awk -F'|' -v iface="$iface" -v column="$column" '$1 == iface { print $column }' "$CURRENT_COUNTERS"
}

iface_base_pair() {
  local iface="$1"
  awk -F'|' -v today="$TODAY" -v iface="$iface" '$1 ~ ("^" today) && $2 == iface { print $3 "|" $4; exit }' "$HISTORY_COUNTERS"
}

REPORT_START="$(awk -F'|' -v today="$TODAY" '$1 ~ ("^" today) { print $1; exit }' "$HISTORY_COUNTERS")"
[ -n "$REPORT_START" ] || REPORT_START="${TODAY} (no samples yet; using current totals)"
LAN_BYTES_START="$(awk -F'|' -v today="$TODAY" '$1 ~ ("^" today) { print $1; exit }' "$LAN_BYTES_HISTORY")"
MOBILE_BYTES_START="$(awk -F'|' -v today="$TODAY" '$1 ~ ("^" today) { print $1; exit }' "$MOBILE_BYTES_HISTORY")"

WAN_RX_NOW="$(iface_current wan0 2)"; WAN_TX_NOW="$(iface_current wan0 3)"
BR0_RX_NOW="$(iface_current br0 2)"; BR0_TX_NOW="$(iface_current br0 3)"
WIFI24_RX_NOW="$(iface_current eth6 2)"; WIFI24_TX_NOW="$(iface_current eth6 3)"
WIFI5_RX_NOW="$(iface_current eth7 2)"; WIFI5_TX_NOW="$(iface_current eth7 3)"

base_pair="$(iface_base_pair wan0)"; WAN_RX_BASE="${base_pair%%|*}"; WAN_TX_BASE="${base_pair##*|}"; [ "$base_pair" = "$WAN_RX_BASE" ] && WAN_RX_BASE=0 WAN_TX_BASE=0
base_pair="$(iface_base_pair br0)"; BR0_RX_BASE="${base_pair%%|*}"; BR0_TX_BASE="${base_pair##*|}"; [ "$base_pair" = "$BR0_RX_BASE" ] && BR0_RX_BASE=0 BR0_TX_BASE=0
base_pair="$(iface_base_pair eth6)"; WIFI24_RX_BASE="${base_pair%%|*}"; WIFI24_TX_BASE="${base_pair##*|}"; [ "$base_pair" = "$WIFI24_RX_BASE" ] && WIFI24_RX_BASE=0 WIFI24_TX_BASE=0
base_pair="$(iface_base_pair eth7)"; WIFI5_RX_BASE="${base_pair%%|*}"; WIFI5_TX_BASE="${base_pair##*|}"; [ "$base_pair" = "$WIFI5_RX_BASE" ] && WIFI5_RX_BASE=0 WIFI5_TX_BASE=0

WAN_RX="$(delta_or_current "${WAN_RX_NOW:-0}" "${WAN_RX_BASE:-0}")"
WAN_TX="$(delta_or_current "${WAN_TX_NOW:-0}" "${WAN_TX_BASE:-0}")"
BR0_RX="$(delta_or_current "${BR0_RX_NOW:-0}" "${BR0_RX_BASE:-0}")"
BR0_TX="$(delta_or_current "${BR0_TX_NOW:-0}" "${BR0_TX_BASE:-0}")"
WIFI24_RX="$(delta_or_current "${WIFI24_RX_NOW:-0}" "${WIFI24_RX_BASE:-0}")"
WIFI24_TX="$(delta_or_current "${WIFI24_TX_NOW:-0}" "${WIFI24_TX_BASE:-0}")"
WIFI5_RX="$(delta_or_current "${WIFI5_RX_NOW:-0}" "${WIFI5_RX_BASE:-0}")"
WIFI5_TX="$(delta_or_current "${WIFI5_TX_NOW:-0}" "${WIFI5_TX_BASE:-0}")"

WAN_TOTAL=$(( WAN_RX + WAN_TX ))
BR0_TOTAL=$(( BR0_RX + BR0_TX ))
WIFI_RX_TOTAL=$(( WIFI24_RX + WIFI5_RX ))
WIFI_TX_TOTAL=$(( WIFI24_TX + WIFI5_TX ))
WIFI_TOTAL=$(( WIFI_RX_TOTAL + WIFI_TX_TOTAL ))

if [ -n "$LAN_BYTES_START" ] && [ -s "$LAN_BYTES_CURRENT" ]; then
  awk -F'|' -v ts="$LAN_BYTES_START" '
    $1 == ts { print $2 "|" $3 "|" $4 "|" $5 "|" $6 "|" $7 "|" $8 "|" $9 }
  ' "$LAN_BYTES_HISTORY" > "$LAN_BYTES_BASE"

  awk -F'|' '
    function delta(current, base) {
      current += 0
      base += 0
      return current >= base ? current - base : current
    }
    NR == FNR {
      host[$1] = $2
      reality_up[$1] = $3 + 0
      reality_down[$1] = $4 + 0
      wan_up[$1] = $5 + 0
      wan_down[$1] = $6 + 0
      other_up[$1] = $7 + 0
      other_down[$1] = $8 + 0
      seen[$1] = 1
      next
    }
    {
      ip = $1
      current_host[ip] = $2
      creality_up[ip] = $3 + 0
      creality_down[ip] = $4 + 0
      cwan_up[ip] = $5 + 0
      cwan_down[ip] = $6 + 0
      cother_up[ip] = $7 + 0
      cother_down[ip] = $8 + 0
      seen[ip] = 1
    }
    END {
      for (ip in seen) {
        label = current_host[ip]
        if (label == "" || label == "?") label = host[ip]
        if (label == "" || label == "?") label = ip

        rup = delta(creality_up[ip], reality_up[ip])
        rdown = delta(creality_down[ip], reality_down[ip])
        wup = delta(cwan_up[ip], wan_up[ip])
        wdown = delta(cwan_down[ip], wan_down[ip])
        oup = delta(cother_up[ip], other_up[ip])
        odown = delta(cother_down[ip], other_down[ip])

        rtotal = rup + rdown
        wtotal = wup + wdown
        ototal = oup + odown
        upload = rup + wup + oup
        download = rdown + wdown + odown
        total = upload + download

        printf "%s|%s|%d|%d|%d|%d|%d|%d\n",
          ip, label, rtotal, wtotal, ototal, upload, download, total
      }
    }' "$LAN_BYTES_BASE" "$LAN_BYTES_CURRENT" | sort -t'|' -k8,8nr -k1,1V > "$LAN_BYTES_PARSED"
else
  : > "$LAN_BYTES_PARSED"
fi

device_labels_build_map "$DEVICE_METADATA_MAP" "$DEVICE_METADATA_FILE"
apply_device_metadata
redact_report_tables

if [ -s "$LAN_BYTES_PARSED" ]; then
  awk -F'|' '
    {
      total += $8 + 0
      reality += $3 + 0
      wan += $4 + 0
      other += $5 + 0
      devices++
    }
    END {
      printf "%d|%d|%d|%d|%d\n", total, reality, wan, other, devices
    }
  ' "$LAN_BYTES_PARSED" > "$DEVICE_MIX_TOTALS"
  sort -t'|' -k3,3nr -k8,8nr "$LAN_BYTES_PARSED" | awk -F'|' '$3 > 0 { print }' > "$DEVICE_TOP_REALITY"
  sort -t'|' -k4,4nr -k8,8nr "$LAN_BYTES_PARSED" | awk -F'|' '$4 > 0 { print }' > "$DEVICE_TOP_WAN"
else
  : > "$DEVICE_MIX_TOTALS"
  : > "$DEVICE_TOP_REALITY"
  : > "$DEVICE_TOP_WAN"
fi

if [ -s "$MOBILE_LOG" ]; then
  awk -v totals="$MOBILE_TOTALS" -v clients_out="$MOBILE_CLIENTS" -v dests_out="$MOBILE_DESTS" '
    function conn_id(line,   start, body, parts) {
      if (match(line, /\[[0-9]+ [^]]+\]/)) {
        body = substr(line, RSTART + 1, RLENGTH - 2)
        split(body, parts, " ")
        return parts[1]
      }
      return ""
    }
    function human_dest(dest,   d) {
      d = dest
      sub(/:[0-9]+$/, "", d)
      return d
    }
    {
      id = conn_id($0)
      if (id == "") next

      if ($0 ~ /inbound\/vless\[reality-in\]: \[[^]]+\] inbound connection to /) {
        client = $0
        sub(/^.*inbound\/vless\[reality-in\]: \[/, "", client)
        sub(/\].*$/, "", client)

        dest = $0
        sub(/^.* inbound connection to /, "", dest)

        seen[id] = 1
        client_by_id[id] = client
        dest_by_id[id] = dest
        next
      }

      if ($0 ~ /inbound\/vless\[reality-in\]: process connection from .*: EOF/) {
        mobile_errors++
        next
      }

      if ($0 ~ /outbound\/vless\[reality-out\]: outbound connection to / && (id in seen)) {
        outbound_by_id[id] = "reality"
        next
      }

      if ($0 ~ /outbound\/direct\[direct-out\]: outbound connection to / && (id in seen)) {
        outbound_by_id[id] = "direct"
        next
      }
    }
    END {
      for (id in seen) {
        client = client_by_id[id]
        dest = human_dest(dest_by_id[id])
        outbound = outbound_by_id[id]
        if (outbound == "") outbound = "unresolved"

        total++
        clients[client] = 1
        client_total[client]++
        dest_total[dest]++

        if (outbound == "reality") {
          reality++
          client_reality[client]++
          dest_reality[dest]++
        } else if (outbound == "direct") {
          direct++
          client_direct[client]++
          dest_direct[dest]++
        } else {
          unresolved++
          client_unresolved[client]++
          dest_unresolved[dest]++
        }
      }

      client_count = 0
      for (client in clients) client_count++
      printf "%d|%d|%d|%d|%d|%d\n", total + 0, reality + 0, direct + 0, unresolved + 0, mobile_errors + 0, client_count + 0 > totals

      for (client in clients) {
        printf "%s|%d|%d|%d|%d\n", client, client_total[client] + 0, client_reality[client] + 0, client_direct[client] + 0, client_unresolved[client] + 0 >> clients_out
      }

      for (dest in dest_total) {
        printf "%s|%d|%d|%d|%d\n", dest, dest_total[dest] + 0, dest_reality[dest] + 0, dest_direct[dest] + 0, dest_unresolved[dest] + 0 >> dests_out
      }
    }
  ' "$MOBILE_LOG"

  [ -s "$MOBILE_CLIENTS" ] && sort -t'|' -k2,2nr -k1,1 "$MOBILE_CLIENTS" -o "$MOBILE_CLIENTS"
  [ -s "$MOBILE_DESTS" ] && sort -t'|' -k2,2nr -k1,1 "$MOBILE_DESTS" -o "$MOBILE_DESTS"
else
  printf '0|0|0|0|0|0\n' > "$MOBILE_TOTALS"
  : > "$MOBILE_CLIENTS"
  : > "$MOBILE_DESTS"
fi

