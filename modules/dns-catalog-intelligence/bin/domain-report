#!/bin/bash
# Fetches domain activity information from the router.
#
# Usage:
#   ./modules/dns-catalog-intelligence/bin/domain-report            # show auto-added STEALTH domains
#   ./modules/dns-catalog-intelligence/bin/domain-report --log      # show full activity log (что заходили, что добавлено)
#   ./modules/dns-catalog-intelligence/bin/domain-report --log 100  # show last N lines of log
#   ./modules/dns-catalog-intelligence/bin/domain-report --reset    # remove all auto-added domains and reload dnsmasq
#   ./modules/dns-catalog-intelligence/bin/domain-report --cleanup  # prune redundant child auto-domains and reload dnsmasq
#   ./modules/dns-catalog-intelligence/bin/domain-report --candidates # show domains skipped (not in blocked list)

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
[ -f "${PROJECT_ROOT}/secrets/router.env" ] && set -a && . "${PROJECT_ROOT}/secrets/router.env" && set +a
[ -f "${PROJECT_ROOT}/.env" ] && set -a && . "${PROJECT_ROOT}/.env" && set +a

ROUTER_USER="${ROUTER_USER:-admin}"
ROUTER_PORT="${ROUTER_PORT:-22}"
CONNECT_TIMEOUT="${CONNECT_TIMEOUT:-5}"
ROUTER="${ROUTER:-}"
SSH_IDENTITY_FILE="${SSH_IDENTITY_FILE:-${HOME}/.ssh/id_rsa}"

MODE="summary"
LOG_LINES=200
JSON_MODE=0

while [ $# -gt 0 ]; do
  case "$1" in
    --json) JSON_MODE=1; shift ;;
    --log)   MODE="log"; [ "${2:-}" -eq "${2:-}" ] 2>/dev/null && { LOG_LINES="${2:-200}"; shift; }; shift ;;
    --reset)      MODE="reset"; shift ;;
    --cleanup)    MODE="cleanup"; shift ;;
    --all)        MODE="all"; shift ;;
    --candidates) MODE="candidates"; shift ;;
    *) echo "Usage: $0 [--json] [--log [N]] [--reset] [--cleanup] [--all] [--candidates]" >&2; exit 1 ;;
  esac
done

SSH_OPTS=(
  -i "$SSH_IDENTITY_FILE"
  -p "$ROUTER_PORT"
  -o ConnectTimeout="$CONNECT_TIMEOUT"
  -o IdentitiesOnly=yes
  -o PubkeyAcceptedAlgorithms=+ssh-rsa
  -o StrictHostKeyChecking=accept-new
)

LOCAL_AUTO_FILE="${DOMAIN_REPORT_AUTO_FILE:-}"
LOCAL_ACTIVITY_FILE="${DOMAIN_REPORT_ACTIVITY_LOG_FILE:-}"
LOCAL_BLOCKED_FILE="${DOMAIN_REPORT_BLOCKED_LIST_FILE:-}"
NEEDS_ROUTER=1
if [ "$JSON_MODE" = "1" ] && [ -n "${LOCAL_AUTO_FILE}${LOCAL_ACTIVITY_FILE}${LOCAL_BLOCKED_FILE}" ]; then
  NEEDS_ROUTER=0
fi

if [ -z "$ROUTER" ] && [ "$NEEDS_ROUTER" = "1" ]; then
  ROUTER=$(route -n get default 2>/dev/null | awk '/gateway:/ { print $2; exit }') || true
fi
if [ -z "$ROUTER" ] && [ "$NEEDS_ROUTER" = "1" ]; then
  echo "Cannot detect router IP. Set ROUTER=<ip> in secrets/router.env (or .env)" >&2
  exit 1
fi

if [ "$JSON_MODE" = "1" ]; then
  case "$MODE" in
    reset|cleanup)
      echo "--json is read-only and is not supported with --${MODE}" >&2
      exit 1
      ;;
  esac

  TMPDIR="$(mktemp -d)"
  trap 'rm -rf "$TMPDIR"' EXIT
  AUTO_OUT="$TMPDIR/auto.txt"
  ACTIVITY_OUT="$TMPDIR/activity.txt"
  CANDIDATES_OUT="$TMPDIR/candidates.txt"
  BLOCKED_META_OUT="$TMPDIR/blocked-meta.txt"
  : > "$AUTO_OUT"
  : > "$ACTIVITY_OUT"
  : > "$CANDIDATES_OUT"
  : > "$BLOCKED_META_OUT"

  if [ -n "$LOCAL_AUTO_FILE" ]; then
    [ -f "$LOCAL_AUTO_FILE" ] && grep "^ipset=" "$LOCAL_AUTO_FILE" | sed "s|ipset=/||;s|/STEALTH_DOMAINS||" | sort -u > "$AUTO_OUT" || true
  elif [ -n "$ROUTER" ]; then
    ssh "${SSH_OPTS[@]}" "${ROUTER_USER}@${ROUTER}" \
      'AUTO=/jffs/configs/dnsmasq-autodiscovered.conf.add
       [ -f "$AUTO" ] && grep "^ipset=" "$AUTO" | sed "s|ipset=/||;s|/STEALTH_DOMAINS||" | sort -u || true' > "$AUTO_OUT"
  fi

  if [ -n "$LOCAL_ACTIVITY_FILE" ]; then
    [ -f "$LOCAL_ACTIVITY_FILE" ] && tail -n "$LOG_LINES" "$LOCAL_ACTIVITY_FILE" > "$ACTIVITY_OUT" || true
    [ -f "$LOCAL_ACTIVITY_FILE" ] && grep "^│  ?" "$LOCAL_ACTIVITY_FILE" | sed "s/^│  ? //" | awk "{print \$1}" | sort | uniq -c | sort -rn | head -50 > "$CANDIDATES_OUT" || true
  elif [ -n "$ROUTER" ]; then
    ssh "${SSH_OPTS[@]}" "${ROUTER_USER}@${ROUTER}" LOG_LINES="$LOG_LINES" \
      '[ -f /opt/var/log/domain-activity.log ] && tail -n "$LOG_LINES" /opt/var/log/domain-activity.log || true' > "$ACTIVITY_OUT"
    ssh "${SSH_OPTS[@]}" "${ROUTER_USER}@${ROUTER}" \
      'ACTIVITY=/opt/var/log/domain-activity.log
       [ -f "$ACTIVITY" ] && grep "^│  ?" "$ACTIVITY" | sed "s/^│  ? //" | awk "{print \$1}" | sort | uniq -c | sort -rn | head -50 || true' > "$CANDIDATES_OUT"
  fi

  if [ -n "$LOCAL_BLOCKED_FILE" ] && [ -f "$LOCAL_BLOCKED_FILE" ]; then
    printf 'count=%s\n' "$(wc -l < "$LOCAL_BLOCKED_FILE" | tr -d ' ')" > "$BLOCKED_META_OUT"
  elif [ -n "$ROUTER" ]; then
    ssh "${SSH_OPTS[@]}" "${ROUTER_USER}@${ROUTER}" \
      'BL=/opt/tmp/blocked-domains.lst
       [ -f "$BL" ] && printf "count=%s\n" "$(wc -l < "$BL")" || printf "count=0\n"' > "$BLOCKED_META_OUT"
  fi

  ruby -rjson -rtime - "$MODE" "$LOG_LINES" "$AUTO_OUT" "$ACTIVITY_OUT" "$CANDIDATES_OUT" "$BLOCKED_META_OUT" <<'RUBY'
mode, log_lines, auto_path, activity_path, candidates_path, blocked_meta_path = ARGV

def lines(path)
  return [] unless File.file?(path)
  File.readlines(path, chomp: true).reject { |line| line.strip.empty? }
end

blocked = {}
lines(blocked_meta_path).each do |line|
  key, value = line.split('=', 2)
  blocked[key] = value
end

candidate_rows = lines(candidates_path).map do |line|
  count, domain = line.strip.split(/\s+/, 2)
  {
    domain: domain,
    kind: 'domain',
    rule_set: 'STEALTH_DOMAINS',
    source_file: 'domain-activity.log',
    match_type: 'candidate',
    hit_count: count.to_i,
    status: 'candidate',
    confidence: 'dns-interest',
    raw_refs: [{ source: 'domain-activity.log' }]
  }
end

puts JSON.pretty_generate({
  schema_version: 1,
  generated_at: Time.now.utc.iso8601,
  source: {
    command: 'domain-report',
    mode: mode,
    confidence: 'dns-interest'
  },
  confidence: 'dns-interest',
  managed: [],
  auto: lines(auto_path).map do |domain|
    {
      domain: domain,
      kind: 'domain',
      source: 'dnsmasq-autodiscovered',
      source_file: 'dnsmasq-autodiscovered.conf.add',
      rule_set: 'STEALTH_DOMAINS',
      match_type: 'ipset-domain',
      status: 'auto',
      confidence: 'dns-interest',
      raw_refs: [{ source: 'dnsmasq-autodiscovered.conf.add', rule_set: 'STEALTH_DOMAINS' }]
    }
  end,
  candidates: candidate_rows,
  blocked: {
    count: blocked.fetch('count', '0').to_i
  },
  activity_tail: lines(activity_path).last(log_lines.to_i),
  notes: [
    'Domain report JSON is read-only.',
    'Catalog edits remain git-tracked and outside Console MVP.'
  ]
})
RUBY
  exit 0
fi

case "$MODE" in

  log)
    echo "=== ЛОГА АКТИВНОСТИ ДОМЕНОВ (последние ${LOG_LINES} строк) ==="
    echo "Файл на роутере: /opt/var/log/domain-activity.log"
    echo ""
    ssh "${SSH_OPTS[@]}" "${ROUTER_USER}@${ROUTER}" \
      "[ -f /opt/var/log/domain-activity.log ] \
       && tail -n ${LOG_LINES} /opt/var/log/domain-activity.log \
       || echo 'Лог ещё не создан. Подождите первого запуска крона (каждые 4 часа).'"
    ;;

  reset)
    echo "Удаляю все авто-добавленные домены..."
    ssh "${SSH_OPTS[@]}" "${ROUTER_USER}@${ROUTER}" \
      'rm -f /jffs/configs/dnsmasq-autodiscovered.conf.add
       service restart_dnsmasq
       echo "Готово. Все авто-добавленные домены удалены, dnsmasq перезапущен."'
    ;;

  cleanup)
    echo "Нормализую auto-файл на роутере и убираю дочерние записи, покрытые более общими правилами..."
    ssh "${SSH_OPTS[@]}" "${ROUTER_USER}@${ROUTER}" \
      'AUTO=/jffs/configs/dnsmasq-autodiscovered.conf.add
       BEFORE=$( [ -f "$AUTO" ] && grep -c "^ipset=" "$AUTO" || echo 0 )
       /jffs/addons/x3mRouting/domain-auto-add.sh --cleanup-only
       AFTER=$( [ -f "$AUTO" ] && grep -c "^ipset=" "$AUTO" || echo 0 )
       echo ""
       echo "Auto-domains: ${BEFORE} -> ${AFTER}"'
    ;;

  all)
    echo "=== ВСЕ АВТО-ДОБАВЛЕННЫЕ STEALTH-ДОМЕНЫ ==="
    ssh "${SSH_OPTS[@]}" "${ROUTER_USER}@${ROUTER}" \
      'AUTO=/jffs/configs/dnsmasq-autodiscovered.conf.add
       [ -f "$AUTO" ] || { echo "(нет авто-добавленных доменов)"; exit 0; }
       echo "Файл: $AUTO"
       echo ""
       grep "^ipset=" "$AUTO" | sed "s|ipset=/||;s|/STEALTH_DOMAINS||" | sort -u'
    ;;

  summary)
    ssh "${SSH_OPTS[@]}" "${ROUTER_USER}@${ROUTER}" \
      'AUTO=/jffs/configs/dnsmasq-autodiscovered.conf.add
       ACTIVITY=/opt/var/log/domain-activity.log

       echo "=== АВТО-ДОБАВЛЕННЫЕ STEALTH-ДОМЕНЫ ==="
       if [ -f "$AUTO" ] && grep -q "^ipset=" "$AUTO" 2>/dev/null; then
         grep "^ipset=" "$AUTO" | sed "s|ipset=/||;s|/STEALTH_DOMAINS||" | sort -u \
           | while read d; do
               added=$(grep "auto-added.*${d}" "$AUTO" | head -1 | grep -oE "[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}" || echo "?")
               printf "  %-45s добавлен: %s\n" "$d" "$added"
             done
       else
         echo "  (пока нет)"
       fi

       echo ""
       echo "=== ПОСЛЕДНИЙ ЗАПУСК ==="
       if [ -f "$ACTIVITY" ]; then
         # Show last run block
         awk "/^════/{found=1; buf=\"\"} found{buf=buf\"\n\"\$0} END{print buf}" "$ACTIVITY" \
           | tail -50
       else
         echo "  Лог ещё не создан."
       fi

       echo ""
       echo "Подробный лог: ./modules/dns-catalog-intelligence/bin/domain-report --log"
       echo "Все домены:    ./modules/dns-catalog-intelligence/bin/domain-report --all"
       echo "Кандидаты:     ./modules/dns-catalog-intelligence/bin/domain-report --candidates"
       echo "Cleanup:       ./modules/dns-catalog-intelligence/bin/domain-report --cleanup"
       echo "Сбросить всё:  ./modules/dns-catalog-intelligence/bin/domain-report --reset"'
    ;;

  candidates)
    echo "=== КАНДИДАТЫ (не в списке блокировок) ==="
    echo "Домены, которые видели в DNS, но не добавили в STEALTH"
    echo "(отсутствуют в blocked-domains.lst)"
    echo ""
    ssh "${SSH_OPTS[@]}" "${ROUTER_USER}@${ROUTER}" \
      'ACTIVITY=/opt/var/log/domain-activity.log
       if [ -f "$ACTIVITY" ]; then
         grep "^│  ?" "$ACTIVITY" \
           | sed "s/^│  ? //" \
           | awk "{print \$1}" \
           | sort | uniq -c | sort -rn \
           | head -50
       else
         echo "Лог ещё не создан."
       fi
       echo ""
       BL=/opt/tmp/blocked-domains.lst
       if [ -f "$BL" ]; then
         echo "Список блокировок: $(wc -l < "$BL") доменов ($(ls -lh "$BL" | awk "{print \$5}"))"
         echo "Обновлён: $(date -r "$BL" "+%Y-%m-%d %H:%M" 2>/dev/null || stat -c "%y" "$BL" 2>/dev/null | cut -d. -f1)"
       else
         echo "Список блокировок: не скачан"
         echo "Запустите: ssh admin@router /jffs/addons/x3mRouting/update-blocked-list.sh"
       fi'
    ;;
esac
