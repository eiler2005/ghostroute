#!/usr/bin/env python3
"""Lightweight repository secret scanner for pre-push hygiene.

This is intentionally conservative for this repo:
- generated QR/client profiles and vault files are ignored by git and skipped;
- public CIDR catalogs are allowed;
- documentation may contain RFC 5737 example IPs and fake VLESS examples only.
"""

from __future__ import annotations

import re
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[3]

ALLOW_PUBLIC_IP_FILES = {
    "configs/static-networks.txt",
    "modules/dns-catalog-intelligence/docs/telegram-deep-dive.md",
    "modules/dns-catalog-intelligence/fixtures/catalog-review/static-networks-sample.txt",
    "modules/dns-catalog-intelligence/fixtures/dns-forensics/dnsmasq-sample.log",
    "modules/dns-catalog-intelligence/tests/test-catalog-review.sh",
    "modules/dns-catalog-intelligence/router/domain-auto-add.sh",
    "modules/shared/lib/router-health-common.sh",
    "modules/routing-core/router/nat-start",
    "modules/recovery-verification/bin/verify.sh",
}

ALLOW_PUBLIC_IPS = {
    "1.1.1.1",
    "1.0.0.1",
    "8.8.8.8",
    "8.8.4.4",
    "9.9.9.9",
    "149.112.112.112",
}

SKIP_PREFIXES = (
    ".git/",
    "secrets/",
    "ansible/secrets/stealth.yml",
    "ansible/secrets/.stealth.generated.yml",
    "ansible/out/clients/",
    "modules/secrets-management/bin/secret-scan",
)

IPV4_RE = re.compile(r"(?<![\w.])(?:\d{1,3}\.){3}\d{1,3}(?![\w.])")
UUID_RE = re.compile(
    r"\b[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}\b"
)
VLESS_RE = re.compile(r"vless://", re.I)
KEY_RE = re.compile(r"BEGIN (?:OPENSSH|RSA|EC|PRIVATE) KEY")
SECRET_ASSIGN_RE = re.compile(
    r"(?i)\b(password|passwd|token|api[_-]?key|private[_-]?key|secret)\s*[:=]\s*['\"]?([^'\"\s]+)"
)
SSLIP_RE = re.compile(r"\b\d{1,3}(?:-\d{1,3}){3}\.sslip\.io\b")


def dotted(parts: list[str]) -> str:
    return ".".join(parts)


def joined(parts: list[str]) -> str:
    return "".join(parts)


SENSITIVE_LITERALS = {
    dotted(["204", "168", "239", "217"]): "retired real VPS IPv4",
    dotted(["149", "154", "167", "35"]): "retired real destination sample IPv4",
    joined(["419", "53"]): "production Home Reality ingress port",
    joined(["123", "45"]): "production LAN redirect port",
    joined(["543", "21"]): "production 3x-ui admin port",
}


def git_output(*args: str) -> list[str]:
    out = subprocess.check_output(["git", *args], cwd=ROOT, text=True)
    return [line for line in out.splitlines() if line]


def candidate_files() -> list[Path]:
    tracked = git_output("ls-files")
    untracked = git_output("ls-files", "--others", "--exclude-standard")
    paths = sorted(set(tracked + untracked))
    result: list[Path] = []
    for rel in paths:
        if rel.startswith(SKIP_PREFIXES):
            continue
        path = ROOT / rel
        if path.is_file():
            result.append(path)
    return result


def is_public_ip(ip: str) -> bool:
    parts = [int(p) for p in ip.split(".")]
    first, second = parts[0], parts[1]
    if first in (0, 10, 127):
        return False
    if first == 169 and second == 254:
        return False
    if first == 172 and 16 <= second <= 31:
        return False
    if first == 192 and second in (0, 168):
        return False
    if first == 198 and second == 51:
        return False
    if first == 203 and second == 0:
        return False
    return True


def fake_context(line: str) -> bool:
    markers = ("FAKE", "example.invalid", "00000000-0000-4000-8000-0000000000", "<", "{{")
    return any(marker in line for marker in markers)


def scan_file(path: Path) -> list[str]:
    rel = path.relative_to(ROOT).as_posix()
    try:
        text = path.read_text(errors="ignore")
    except UnicodeDecodeError:
        return []

    findings: list[str] = []
    for lineno, line in enumerate(text.splitlines(), 1):
        if KEY_RE.search(line):
            findings.append(f"{rel}:{lineno}: private key marker")
        for literal, reason in SENSITIVE_LITERALS.items():
            if literal in line:
                findings.append(f"{rel}:{lineno}: {reason}")
        if SSLIP_RE.search(line):
            findings.append(f"{rel}:{lineno}: sslip host with embedded public IP")
        if VLESS_RE.search(line) and not fake_context(line):
            findings.append(f"{rel}:{lineno}: non-fake vless URI")
        if UUID_RE.search(line) and not fake_context(line):
            findings.append(f"{rel}:{lineno}: UUID-like value")
        for m in SECRET_ASSIGN_RE.finditer(line):
            value = m.group(2)
            if value and value not in {"", "false", "true", "null"} and not fake_context(line):
                findings.append(f"{rel}:{lineno}: secret-looking assignment")
        if rel not in ALLOW_PUBLIC_IP_FILES:
            for ip in IPV4_RE.findall(line):
                if is_public_ip(ip) and ip not in ALLOW_PUBLIC_IPS:
                    findings.append(f"{rel}:{lineno}: public IPv4 outside allowlist")
    return findings


def main() -> int:
    findings: list[str] = []
    for path in candidate_files():
        findings.extend(scan_file(path))
    if findings:
        print("Potential sensitive data found:", file=sys.stderr)
        for item in findings:
            print(f"  {item}", file=sys.stderr)
        return 1
    print("secret-scan: ok")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
