#!/bin/sh

# GhostRoute boot is single-owner: this hook launches the runtime supervisor.
# The supervisor registers cron jobs, validates firewall invariants and runs
# targeted channel recovery.
# BEGIN GhostRouteRuntimeSupervisor
if [ -x /jffs/scripts/ghostroute-runtime-supervisor.sh ]; then
  ( /jffs/scripts/ghostroute-runtime-supervisor.sh boot ) >/dev/null 2>&1 &
else
  logger -t ghostroute-services-start "ghostroute runtime supervisor is missing"
fi
# END GhostRouteRuntimeSupervisor
