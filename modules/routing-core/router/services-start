#!/bin/sh

# Recreate the cron job on boot so duplicate entries do not accumulate.
cru d SaveIPSet 2>/dev/null
cru a SaveIPSet "0 */6 * * * /jffs/scripts/cron-save-ipset"

# Traffic snapshots every 6 hours (WAN/LAN/Tailscale/device counters, stored on
# USB/Entware when available).
cru d TrafficSnapshot 2>/dev/null
[ -x /jffs/scripts/cron-traffic-snapshot ] && \
  cru a TrafficSnapshot "0 */6 * * * /jffs/scripts/cron-traffic-snapshot"

# Keep Mobile Home Reality byte counters current across LTE source-IP changes.
cru d MobileRealityCounters 2>/dev/null
[ -x /jffs/scripts/mobile-reality-accounting-refresh ] && \
  cru a MobileRealityCounters "*/5 * * * * /jffs/scripts/mobile-reality-accounting-refresh"

# sing-box can produce large connection logs during troubleshooting-heavy days.
cru d RotateSingBoxLog 2>/dev/null
[ -x /jffs/scripts/rotate-singbox-log ] && \
  cru a RotateSingBoxLog "17 * * * * /jffs/scripts/rotate-singbox-log"

# GhostRoute health monitor: read-only probes + local status/alert reports.
cru d HealthMonitorProbes 2>/dev/null
[ -x /jffs/scripts/health-monitor/run-probes ] && \
  cru a HealthMonitorProbes "0 * * * * /jffs/scripts/health-monitor/run-probes"

cru d HealthMonitorAggregate 2>/dev/null
[ -x /jffs/scripts/health-monitor/aggregate ] && \
  cru a HealthMonitorAggregate "2 * * * * /jffs/scripts/health-monitor/aggregate"

cru d HealthMonitorDaily 2>/dev/null
[ -x /jffs/scripts/health-monitor/daily-digest ] && \
  cru a HealthMonitorDaily "10 3 * * * /jffs/scripts/health-monitor/daily-digest"

# Save a close-of-day LAN / remote-access baseline for readable daily reports.
cru d TrafficDailyClose 2>/dev/null
[ -x /jffs/scripts/cron-traffic-daily-close ] && \
  cru a TrafficDailyClose "55 23 * * * /jffs/scripts/cron-traffic-daily-close"

# Domain auto-routing: add newly discovered blocked domains to STEALTH (hourly).
# Requires dnsmasq logging (enabled by default) and Entware on USB.
cru d DomainCollect 2>/dev/null
cru d DomainAutoAdd 2>/dev/null
[ -x /jffs/addons/x3mRouting/domain-auto-add.sh ] && \
  cru a DomainAutoAdd "0 * * * * /jffs/addons/x3mRouting/domain-auto-add.sh"

# Update blocked domains list from antifilter.download (daily at 5:00 AM).
# Used by domain-auto-add.sh to filter: only blocked domains get Reality-routed.
cru d UpdateBlockedList 2>/dev/null
[ -x /jffs/addons/x3mRouting/update-blocked-list.sh ] && \
  cru a UpdateBlockedList "0 5 * * * /jffs/addons/x3mRouting/update-blocked-list.sh"

# Seed an initial traffic sample after boot/deploy so same-day reports have a baseline.
[ -x /jffs/scripts/cron-traffic-snapshot ] && /jffs/scripts/cron-traffic-snapshot >/dev/null 2>&1
[ -x /jffs/scripts/health-monitor/run-once ] && /jffs/scripts/health-monitor/run-once >/dev/null 2>&1 || true
