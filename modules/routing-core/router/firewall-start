#!/bin/sh

# Use persistent JFFS by default. Switch to /opt/tmp only when Entware is present.
STATE_DIR="/jffs/addons/router_configuration"
[ -x /opt/bin/opkg ] && STATE_DIR="/opt/tmp"
mkdir -p "$STATE_DIR"
STATE_FILE="$STATE_DIR/STEALTH_DOMAINS.ipset"
STATIC_NETWORKS_FILE="/jffs/configs/router_configuration.static_nets"
PORT_BYPASS_FILE="/jffs/configs/router_configuration.no_vpn_ip_ports"

# Create/restore the active Channel A target sets.
ipset create STEALTH_DOMAINS hash:ip family inet hashsize 1024 maxelem 65536 2>/dev/null
ipset create VPN_STATIC_NETS hash:net family inet hashsize 256 maxelem 65536 2>/dev/null
if [ -f "$STATE_FILE" ]; then
  # ipset save includes a create line. Merlin's ipset restore -! can still
  # abort on that line when the set already exists, so replay only entries.
  grep '^add STEALTH_DOMAINS ' "$STATE_FILE" | ipset restore -! 2>/dev/null || true
fi
ipset flush VPN_STATIC_NETS 2>/dev/null
if [ -f "$STATIC_NETWORKS_FILE" ]; then
  sed -e 's/#.*$//' -e '/^[[:space:]]*$/d' "$STATIC_NETWORKS_FILE" | while IFS= read -r network; do
    ipset add VPN_STATIC_NETS "$network" 2>/dev/null
  done
fi

# Router SSH access is owned by the Merlin SSH service setting. GhostRoute
# supports both direct LAN operator access and the approved WAN SSH profile, so
# remove the older LAN-only guard if it is still present after firewall rebuilds.
SSH_PORT="$(nvram get sshd_port 2>/dev/null || true)"
[ -n "$SSH_PORT" ] || SSH_PORT=22
iptables -D INPUT ! -i br0 -p tcp --dport "$SSH_PORT" -j DROP 2>/dev/null || true
if [ "$(nvram get sshd_enable 2>/dev/null || true)" = "1" ]; then
  iptables -D INPUT -p tcp --dport "$SSH_PORT" -j ACCEPT 2>/dev/null || true
  iptables -I INPUT 1 -p tcp --dport "$SSH_PORT" -j ACCEPT
fi

# Keep per-device LAN byte accounting chains up to date without resetting
# their counters during ordinary refreshes.
[ -x /jffs/scripts/lan-traffic-accounting-refresh ] && /jffs/scripts/lan-traffic-accounting-refresh >/dev/null 2>&1 || true

# Re-apply Channel A REDIRECT/QUIC-drop and home Reality INPUT rules after
# Merlin rebuilds firewall chains.
[ -x /jffs/scripts/stealth-route-init.sh ] && /jffs/scripts/stealth-route-init.sh >/dev/null 2>&1 || true
