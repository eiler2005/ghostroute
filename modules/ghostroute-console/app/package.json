{
  "name": "ghostroute-console",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "dev:gui": "npm run seed:gui && GHOSTROUTE_CONSOLE_DATA_DIR=../data/gui-test next dev --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1 --port 3000",
    "test": "node --test tests/*.test.mjs",
    "seed:gui": "node scripts/seed-gui-test-db.mjs",
    "test:e2e": "playwright test tests/e2e/smoke.spec.ts",
    "test:e2e:gui": "npm run seed:gui && GHOSTROUTE_CONSOLE_DATA_DIR=../data/gui-test playwright test tests/e2e/smoke.spec.ts",
    "test:perf": "playwright test tests/e2e/performance.spec.ts --project=desktop",
    "collector:once": "node scripts/collect-once.mjs",
    "collector:light": "node scripts/collect-light-once.mjs",
    "collector:live": "node scripts/collect-live-once.mjs",
    "doctor": "node scripts/doctor.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.10",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
