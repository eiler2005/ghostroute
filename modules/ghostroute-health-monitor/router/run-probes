split_kv() {
  file="$1"
  key="$2"
  awk -F= -v key="$key" '$1 == key { print substr($0, index($0, "=") + 1); found = 1; exit } END { if (!found) print "" }' "$file" 2>/dev/null
}

split_policy_since_ts() {
  if [ "${HEALTH_MONITOR_SPLIT_SINCE_TS+x}" = "x" ]; then
    printf '%s\n' "$HEALTH_MONITOR_SPLIT_SINCE_TS"
    return 0
  fi

  latest_file=""
  latest_epoch=0
  for file in \
    "${HEALTH_MONITOR_RULESET_FILE:-/opt/etc/sing-box/rule-sets/stealth-domains.json}" \
    "${HEALTH_MONITOR_STATIC_RULESET_FILE:-/opt/etc/sing-box/rule-sets/stealth-static.json}"; do
    [ -r "$file" ] || continue
    epoch="$(hm_file_epoch "$file")"
    case "$epoch" in ''|*[!0-9]*) epoch=0 ;; esac
    if [ "$epoch" -gt "$latest_epoch" ]; then
      latest_epoch="$epoch"
      latest_file="$file"
    fi
  done

  if [ -n "$latest_file" ]; then
    date -r "$latest_file" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || printf '\n'
  else
    printf '\n'
  fi
}

analyze_client_split() {
  managed_file="$1"
  direct_file="$2"
  log_file="$3"
  today="$4"
  inbound_tag="$5"
  since_ts="${6:-}"

  {
    printf '%s\n' '__hm_section__ managed'
    cat "$managed_file" 2>/dev/null
    printf '%s\n' '__hm_section__ direct'
    cat "$direct_file" 2>/dev/null
    printf '%s\n' '__hm_section__ log'
    cat "$log_file" 2>/dev/null
  } | awk -v today="$today" -v inbound_tag="$inbound_tag" -v since_ts="$since_ts" '
    function conn_id(line,   body, parts) {
      if (match(line, /\[[0-9]+ [^]]+\]/)) {
        body = substr(line, RSTART + 1, RLENGTH - 2)
        split(body, parts, " ")
        return parts[1]
      }
      return ""
    }
    function host_from_line(line,   host) {
      host = line
      sub(/^.* connection to /, "", host)
      sub(/:[0-9]+.*$/, "", host)
      return tolower(host)
    }
    function line_ts() {
      return $2 " " $3
    }
    function is_managed(host,   suffix) {
      for (suffix in managed) {
        if (host == suffix) return 1
        if (length(host) > length(suffix) &&
            substr(host, length(host) - length(suffix), 1) == "." &&
            substr(host, length(host) - length(suffix) + 1) == suffix) return 1
      }
      return 0
    }
    function is_direct_allowed(host,   suffix) {
      for (suffix in direct_allow) {
        if (host == suffix) return 1
        if (length(host) > length(suffix) &&
            substr(host, length(host) - length(suffix), 1) == "." &&
            substr(host, length(host) - length(suffix) + 1) == suffix) return 1
      }
      return 0
    }
    function is_direct_like(host) {
      return host ~ /(^|[.])ru$|[.]ru[.]|yandex|vk[.]com|ok[.]ru|ozon|wildberries|avito|sber|tbank|gosuslugi|mail[.]ru/
    }
    function add_sample(var_name, host) {
      if (var_name == "managed") {
        if (managed_sample_count < 5) {
          managed_sample_count++
          managed_sample = managed_sample (managed_sample == "" ? "" : ",") host
        }
      } else {
        if (direct_vps_sample_count < 5) {
          direct_vps_sample_count++
          direct_vps_sample = direct_vps_sample (direct_vps_sample == "" ? "" : ",") host
        }
      }
    }
    /^__hm_section__ / {
      section = $2
      next
    }
    section == "managed" {
      if ($0 != "") managed[tolower($0)] = 1
      next
    }
    section == "direct" {
      if ($0 != "") direct_allow[tolower($0)] = 1
      next
    }
    section == "log" {
      if (index($0, " " today " ") == 0) next
      if (since_ts != "" && line_ts() < since_ts) next
      id = conn_id($0)
      if (index($0, inbound_tag) > 0 && $0 ~ /inbound connection to /) {
        if (id != "") {
          client_id[id] = 1
          host_by_id[id] = host_from_line($0)
        }
      }
      if (id != "" && !(id in outbound_by_id)) {
        if ($0 ~ /outbound\/vless\[reality-out\]: outbound connection to /) {
          outbound_by_id[id] = "reality"
          outbound_host_by_id[id] = host_from_line($0)
        } else if ($0 ~ /outbound\/direct\[direct-out\]: outbound connection to /) {
          outbound_by_id[id] = "direct"
          outbound_host_by_id[id] = host_from_line($0)
        }
      }
      next
    }
    END {
      for (id in client_id) {
        total++
        host = host_by_id[id]
        if (host == "") host = outbound_host_by_id[id]
        managed_host = is_managed(host)
        direct_allowed_host = is_direct_allowed(host)
        if (outbound_by_id[id] == "reality") {
          reality++
          if (direct_allowed_host || (is_direct_like(host) && !managed_host)) {
            direct_via_vps++
            add_sample("direct_vps", host)
          }
        } else if (outbound_by_id[id] == "direct") {
          direct++
          if (managed_host && !direct_allowed_host) {
            managed_direct++
            add_sample("managed", host)
          }
        } else {
          unresolved++
        }
      }
      printf "total=%d\n", total + 0
      printf "reality=%d\n", reality + 0
      printf "direct=%d\n", direct + 0
      printf "unresolved=%d\n", unresolved + 0
      printf "managed_direct=%d\n", managed_direct + 0
      printf "managed_direct_sample=%s\n", managed_sample
      printf "direct_via_vps=%d\n", direct_via_vps + 0
      printf "direct_via_vps_sample=%s\n", direct_vps_sample
    }
  '
}

extract_stealth_domains() {
  awk -v target_set="STEALTH_DOMAINS" '
    /^ipset=\// {
      line = $0
      sub(/[[:space:]]*#.*/, "", line)
      n = split(line, parts, "/")
      if (n < 3) next
      set_name = parts[n]
      if (set_name != target_set) next
      for (i = 2; i < n; i++) {
        domain = parts[i]
        gsub(/^[.]+/, "", domain)
        gsub(/[[:space:]]/, "", domain)
        if (domain != "" && domain !~ /[*]/) print tolower(domain)
      }
    }' "$@" 2>/dev/null | sort -u
}

extract_direct_domains() {
  no_vpn_file="$1"
  config_file="$2"

  {
    if [ -r "$no_vpn_file" ]; then
      sed 's/[[:space:]]*#.*$//' "$no_vpn_file" 2>/dev/null |
        sed '/^[[:space:]]*$/d'
    fi

    if [ -r "$config_file" ]; then
      awk '
        function reset_rule() {
          delete domains
          domain_count = 0
          in_domains = 0
          direct = 0
        }
        function collect_quoted_domains(line,   rest, start, tail, value) {
          rest = line
          while (match(rest, /"[^"]+"/)) {
            value = substr(rest, RSTART + 1, RLENGTH - 2)
            if (value != "domain_suffix" && value != "outbound" && value != "direct-out") {
              domains[++domain_count] = value
            }
            rest = substr(rest, RSTART + RLENGTH)
          }
        }
        BEGIN { reset_rule() }
        /^[[:space:]]*\{/ { reset_rule() }
        /"domain_suffix"[[:space:]]*:/ { in_domains = 1 }
        in_domains { collect_quoted_domains($0) }
        in_domains && /\]/ { in_domains = 0 }
        /"outbound"[[:space:]]*:[[:space:]]*"direct-out"/ { direct = 1 }
        /^[[:space:]]*\}/ {
          if (direct) {
            for (i = 1; i <= domain_count; i++) print domains[i]
          }
          reset_rule()
        }
      ' "$config_file" 2>/dev/null
    fi
  } | awk '{ print tolower($0) }' | sort -u
}

extract_rule_domains() {
  sed -n 's/.*"\([^"]*\)".*/\1/p' "$1" 2>/dev/null |
    grep -Ev '^(version|rules|domain_suffix|ip_cidr)$' |
    sort -u
}

probe_rule_set_sync() {
  should_run rule_set_sync || return 0
  dnsmasq_file="${HEALTH_MONITOR_DNSMASQ_FILE:-/jffs/configs/dnsmasq-stealth.conf.add}"
  auto_file="${HEALTH_MONITOR_DNSMASQ_AUTO_FILE:-/jffs/configs/dnsmasq-autodiscovered.conf.add}"
  ruleset_file="${HEALTH_MONITOR_RULESET_FILE:-/opt/etc/sing-box/rule-sets/stealth-domains.json}"
  tmp_prefix="/tmp/health-monitor-rules.$$"
  dns_tmp="${tmp_prefix}.dns"
  rule_tmp="${tmp_prefix}.rules"
  only_dns="${tmp_prefix}.only_dns"
  only_rule="${tmp_prefix}.only_rule"

  if [ ! -r "$dnsmasq_file" ]; then
    hm_emit rule_set_sync CRIT "rule-set drift" \
      "dnsmasq STEALTH catalog is missing." \
      "path=$dnsmasq_file" \
      "Check router deploy state."
    return 0
  fi
  if [ ! -r "$ruleset_file" ]; then
    hm_emit rule_set_sync CRIT "rule-set drift" \
      "sing-box source rule-set is missing." \
      "path=$ruleset_file" \
      "Run update-singbox-rule-sets.sh with operator approval."
    return 0
  fi

  extract_stealth_domains "$dnsmasq_file" "$auto_file" > "$dns_tmp"
  extract_rule_domains "$ruleset_file" > "$rule_tmp"

  awk 'NR==FNR { a[$0]=1; next } $0 != "" && !($0 in a) { print }' "$rule_tmp" "$dns_tmp" > "$only_dns"
  awk 'NR==FNR { a[$0]=1; next } $0 != "" && !($0 in a) { print }' "$dns_tmp" "$rule_tmp" > "$only_rule"

  dns_count="$(wc -l < "$dns_tmp" 2>/dev/null | tr -d ' ')"
  rule_count="$(wc -l < "$rule_tmp" 2>/dev/null | tr -d ' ')"
  only_dns_count="$(wc -l < "$only_dns" 2>/dev/null | tr -d ' ')"
  only_rule_count="$(wc -l < "$only_rule" 2>/dev/null | tr -d ' ')"
  only_dns_sample="$(head -5 "$only_dns" 2>/dev/null | tr '\n' ',' | sed 's/,$//')"
  only_rule_sample="$(head -5 "$only_rule" 2>/dev/null | tr '\n' ',' | sed 's/,$//')"

  rm -f "$dns_tmp" "$rule_tmp" "$only_dns" "$only_rule"

  if [ "${only_dns_count:-0}" -gt 0 ] || [ "${only_rule_count:-0}" -gt 0 ]; then
    hm_emit rule_set_sync CRIT "rule-set drift" \
      "dnsmasq STEALTH catalog and sing-box rule-set differ." \
      "dnsmasq=$dns_count ruleset=$rule_count only_dns=$only_dns_count only_rule=$only_rule_count sample_dns=$only_dns_sample sample_rule=$only_rule_sample" \
      "Regenerate sing-box rule-sets after confirming the catalog change."
  else
    hm_emit rule_set_sync OK "rule-set drift" \
      "dnsmasq STEALTH catalog and sing-box domain_suffix rule-set are in sync." \
      "domains=$dns_count" \
      "No action."
  fi
}

probe_dns_ipv6_leaks() {
  should_run dns_ipv6_leaks || return 0
  issues=""
  ipv6_service="$(nvram get ipv6_service 2>/dev/null || true)"
  [ "${ipv6_service:-disabled}" = "disabled" ] || issues="${issues} ipv6_service=$ipv6_service"
  ip -6 -o addr show dev br0 2>/dev/null | grep -qE 'inet6 (2|3)[0-9a-f]{1,3}:' && issues="${issues} br0_global_ipv6"
  ip -6 -o addr show dev wan0 2>/dev/null | grep -qE 'inet6 (2|3)[0-9a-f]{1,3}:' && issues="${issues} wan0_global_ipv6"
  grep -q '^filter-AAAA$' /jffs/configs/dnsmasq.conf.add 2>/dev/null || issues="${issues} filter_aaaa_missing"

  tcpdump_bin="$(hm_command tcpdump 2>/dev/null || true)"
  plain_dns="skip"
  if [ -n "$tcpdump_bin" ]; then
    wan_if="$(hm_wan_if)"
    plain_dns="$(hm_timeout 5 "$tcpdump_bin" -i "$wan_if" -nn -c 5 'udp port 53' 2>/dev/null | wc -l | tr -d ' ')"
    [ "${plain_dns:-0}" -gt 0 ] && issues="${issues} plain_dns_packets=$plain_dns"
  fi

  if printf '%s\n' "$issues" | grep -q 'plain_dns_packets\|global_ipv6'; then
    hm_emit dns_ipv6_leaks CRIT "DNS/plain-53 or IPv6 leak" \
      "Potential DNS or IPv6 leak signal was detected." \
      "issues=${issues# } plain_dns_sample=$plain_dns" \
      "Stop and diagnose DNS/IPv6 policy before changing catalogs."
  elif [ -n "$issues" ]; then
    hm_emit dns_ipv6_leaks WARN "DNS/plain-53 or IPv6 leak" \
      "DNS/IPv6 policy drift was detected." \
      "issues=${issues# } plain_dns_sample=$plain_dns" \
      "Check dnsmasq filter-AAAA and Merlin IPv6 settings."
  else
    hm_emit dns_ipv6_leaks OK "DNS/plain-53 or IPv6 leak" \
      "IPv6 policy and DNS leak sample are clean." \
      "plain_dns_sample=$plain_dns" \
      "No action."
  fi
}

