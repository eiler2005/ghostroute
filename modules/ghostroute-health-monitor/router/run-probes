  delta_retrans="$3"

  hm_baseline_observe tcp_retransmits "$ratio"
  stats="$(hm_baseline_stats tcp_retransmits)"
  baseline_count="$(printf '%s\n' "$stats" | awk '{ print $1 }')"
  baseline_p95="$(printf '%s\n' "$stats" | awk '{ print $2 }')"
  case "$baseline_count" in ''|*[!0-9]*) baseline_count=0 ;; esac

  if awk -v ratio="$ratio" 'BEGIN { exit(ratio > 25 ? 0 : 1) }'; then
    hm_emit tcp_retransmits CRIT "TCP retransmit ratio" \
      "TCP retransmit ratio exceeded the hard catastrophic threshold." \
      "ratio_pct=$ratio delta_out=$delta_out delta_retrans=$delta_retrans baseline_samples=$baseline_count baseline_p95_pct=$baseline_p95 hard_crit_pct=25" \
      "Check Wi-Fi/WAN packet loss, MTU/MSS, and VPS path."
  elif [ "$baseline_count" -lt 24 ]; then
    hm_emit tcp_retransmits OK "TCP retransmit ratio" \
      "TCP retransmit sample collected while the 7-day baseline is still learning." \
      "ratio_pct=$ratio delta_out=$delta_out delta_retrans=$delta_retrans baseline=learning baseline_samples=$baseline_count required_samples=24" \
      "No action unless users report packet loss or performance problems."
  else
    thresholds="$(hm_thresholds_from_p95 "$baseline_p95" 5 15 1.5 2.5)"
    warn_pct="$(printf '%s\n' "$thresholds" | awk '{ print $1 }')"
    crit_pct="$(printf '%s\n' "$thresholds" | awk '{ print $2 }')"
    if awk -v ratio="$ratio" -v crit="$crit_pct" 'BEGIN { exit(ratio >= crit ? 0 : 1) }'; then
      hm_emit tcp_retransmits CRIT "TCP retransmit ratio" \
        "TCP retransmit ratio is critically above the learned baseline." \
        "ratio_pct=$ratio delta_out=$delta_out delta_retrans=$delta_retrans baseline_samples=$baseline_count baseline_p95_pct=$baseline_p95 warn_pct=$warn_pct crit_pct=$crit_pct" \
        "Check Wi-Fi/WAN packet loss, MTU/MSS, and VPS path."
    elif awk -v ratio="$ratio" -v warn="$warn_pct" 'BEGIN { exit(ratio >= warn ? 0 : 1) }'; then
      hm_emit tcp_retransmits WARN "TCP retransmit ratio" \
        "TCP retransmit ratio is above the learned baseline." \
        "ratio_pct=$ratio delta_out=$delta_out delta_retrans=$delta_retrans baseline_samples=$baseline_count baseline_p95_pct=$baseline_p95 warn_pct=$warn_pct crit_pct=$crit_pct" \
        "Correlate with RTT and user reports."
    else
      hm_emit tcp_retransmits OK "TCP retransmit ratio" \
        "TCP retransmit ratio is within the learned baseline." \
        "ratio_pct=$ratio delta_out=$delta_out delta_retrans=$delta_retrans baseline_samples=$baseline_count baseline_p95_pct=$baseline_p95 warn_pct=$warn_pct crit_pct=$crit_pct" \
        "No action."
    fi
  fi
}

probe_tcp_retransmits() {
  should_run tcp_retransmits || return 0
  state_file="$STATE_DIR/tcp-retrans.state"
  pair="$(awk '
    /^Tcp:/ && !seen {
      for (i = 1; i <= NF; i++) idx[$i] = i
      seen = 1
      next
    }
    /^Tcp:/ && seen {
      print $(idx["OutSegs"]) " " $(idx["RetransSegs"])
      exit
    }' /proc/net/snmp 2>/dev/null)"
  outsegs="$(printf '%s\n' "$pair" | awk '{ print $1 }')"
  retrans="$(printf '%s\n' "$pair" | awk '{ print $2 }')"
  case "$outsegs" in
    ''|*[!0-9]*) hm_emit tcp_retransmits UNKNOWN "TCP retransmit ratio" \
      "Could not parse /proc/net/snmp TCP counters." \
      "pair=$pair" \
      "Check router kernel counters manually."; return 0 ;;
  esac
  case "$retrans" in
    ''|*[!0-9]*) hm_emit tcp_retransmits UNKNOWN "TCP retransmit ratio" \
      "Could not parse /proc/net/snmp TCP counters." \
      "pair=$pair" \
      "Check router kernel counters manually."; return 0 ;;
  esac

  prev_out=0
  prev_retrans=0
  if [ -r "$state_file" ]; then
    prev_out="$(awk '{ print $1 }' "$state_file")"
    prev_retrans="$(awk '{ print $2 }' "$state_file")"
  fi
  printf '%s %s\n' "$outsegs" "$retrans" > "$state_file"

  delta_out=$((outsegs - prev_out))
  delta_retrans=$((retrans - prev_retrans))
  [ "$delta_out" -le 0 ] && delta_out=1
  [ "$delta_retrans" -lt 0 ] && delta_retrans=0
  ratio="$(awk -v r="$delta_retrans" -v o="$delta_out" 'BEGIN { printf "%.2f", r * 100 / o }')"

  if [ "$prev_out" = "0" ]; then
    hm_emit tcp_retransmits OK "TCP retransmit ratio" \
      "TCP retransmit baseline sample was initialized." \
      "ratio_pct=0.00 delta_out=0 delta_retrans=0" \
      "No action."
  else
    emit_tcp_retransmit_sample "$ratio" "$delta_out" "$delta_retrans"
  fi
}

probe_snapshot_freshness() {
  should_run snapshot_freshness || return 0
  base="/jffs/addons/router_configuration/traffic"
  [ -d /opt/var/log/router_configuration ] && base="/opt/var/log/router_configuration"
  now="$(hm_now_epoch)"
  iface="$base/interface-counters.tsv"
  daily="$(ls "$base"/daily/*-lan-conntrack.txt 2>/dev/null | sort | tail -1 || true)"
  iface_age=$((now - $(hm_file_epoch "$iface")))
  daily_age=$((now - $(hm_file_epoch "$daily")))
  [ "$iface_age" -lt 0 ] && iface_age=999999
  [ "$daily_age" -lt 0 ] && daily_age=999999

  if [ "$iface_age" -gt 86400 ] || [ "$daily_age" -gt 259200 ]; then
    hm_emit snapshot_freshness CRIT "stale cron/report snapshots" \
      "Traffic/report snapshots are critically stale." \
      "interface_age=$(hm_human_age "$iface_age") daily_age=$(hm_human_age "$daily_age") base=$base" \
      "Check cron service and services-start cron registration."
  elif [ "$iface_age" -gt 28800 ] || [ "$daily_age" -gt 129600 ]; then
    hm_emit snapshot_freshness WARN "stale cron/report snapshots" \
      "Traffic/report snapshots are stale." \
      "interface_age=$(hm_human_age "$iface_age") daily_age=$(hm_human_age "$daily_age") base=$base" \
      "Check TrafficSnapshot and TrafficDailyClose cron jobs."
  else
    hm_emit snapshot_freshness OK "stale cron/report snapshots" \
      "Traffic/report snapshots are fresh." \
      "interface_age=$(hm_human_age "$iface_age") daily_age=$(hm_human_age "$daily_age") base=$base" \
      "No action."
  fi
}

