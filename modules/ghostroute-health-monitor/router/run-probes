#!/bin/sh
# Read-only local health probes for GhostRoute.

set -u
. "$(dirname "$0")/lib.sh"

PROBE_FILTER=""
if [ "${1:-}" = "--probe" ]; then
  PROBE_FILTER="${2:-}"
elif [ -n "${HEALTH_MONITOR_PROBE_FILTER:-}" ]; then
  PROBE_FILTER="$HEALTH_MONITOR_PROBE_FILTER"
fi

should_run() {
  [ -z "$PROBE_FILTER" ] || [ "$PROBE_FILTER" = "$1" ]
}

hm_runtime_port() {
  name="$1"
  value="$2"
  tag="${3:-}"
  if [ -z "$value" ] && [ -n "$tag" ]; then
    value="$(hm_singbox_port_by_tag "$tag" 2>/dev/null || true)"
  fi
  if [ -z "$value" ]; then
    hm_emit "$name" UNKNOWN "monitor runtime configuration missing" \
      "The health monitor runtime port configuration is missing." \
      "missing=$name env=$HEALTH_MONITOR_ENV tag=${tag:-none} config=$(hm_singbox_config)" \
      "Re-render the health monitor env from Ansible or verify live sing-box config before interpreting this probe."
    return 1
  fi
  printf '%s\n' "$value"
}

probe_channel_a_reality() {
  should_run channel_a_reality || should_run channel_b_reality || return 0
  socks_port="$(hm_runtime_port channel_a_reality "${HEALTH_MONITOR_SOCKS_PORT:-}" dnscrypt-socks-in)" || return 0
  socks="${HEALTH_MONITOR_SOCKS:-127.0.0.1:$socks_port}"
  expected="$(hm_extract_reality_server 2>/dev/null || true)"
  log="$(hm_singbox_log)"
  recent_reality="$(tail -1000 "$log" 2>/dev/null | grep -c 'outbound/vless\[reality-out\]' || true)"
  curl_err="/tmp/health-monitor-curl.$$"
  exit_ip="$(hm_curl -sS --max-time 8 --proxy "socks5h://$socks" https://api.ipify.org 2>"$curl_err")"
  curl_rc=$?
  curl_error="$(head -c 120 "$curl_err" 2>/dev/null | tr '\n' ' ')"
  rm -f "$curl_err"

  if [ -z "$exit_ip" ]; then
    if [ "${recent_reality:-0}" -gt 0 ]; then
      hm_emit channel_a_reality OK "Channel A / Reality path down" \
        "Active SOCKS exit-IP probe is unavailable, but recent reality-out traffic is visible." \
        "active_check=unavailable curl_rc=$curl_rc recent_reality_out=$recent_reality expected=${expected:-unknown}" \
        "No action unless users report managed-site failures."
    else
      hm_emit channel_a_reality CRIT "Channel A / Reality path down" \
        "SOCKS path through sing-box did not return an exit IP and no recent reality-out traffic was visible." \
        "socks=$socks curl_rc=$curl_rc curl_error=$curl_error expected=${expected:-unknown}" \
        "Check sing-box, Caddy/Xray on VPS, and the VPS path before changing routing."
    fi
  elif printf '%s\n' "$expected" | grep -Eq '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$' && [ "$exit_ip" != "$expected" ]; then
    hm_emit channel_a_reality WARN "Managed traffic exits via unexpected IP" \
      "Reality path works, but the observed exit IP differs from the configured VPS IP." \
      "exit_ip=$exit_ip expected=$expected" \
      "Confirm the VPS address, DNS, and any planned VPS IP rotation."
  else
    hm_emit channel_a_reality OK "Channel A / Reality path down" \
      "Reality SOCKS path is reachable." \
      "exit_ip=$exit_ip expected=${expected:-not_ipv4_literal}" \
      "No action."
  fi
}

probe_vps_path() {
  should_run vps_path || return 0
  server="$(hm_extract_reality_server 2>/dev/null || true)"
  if [ -z "$server" ]; then
    hm_emit vps_path UNKNOWN "VPS path unavailable" \
      "Could not read reality-out server from sing-box config." \
      "config=$(hm_singbox_config)" \
      "Check sing-box config rendering."
    return 0
  fi

  log="$(hm_singbox_log)"
  recent_reality="$(tail -1000 "$log" 2>/dev/null | grep -c 'outbound/vless\[reality-out\]' || true)"
  if hm_tcp_open "$server" 443 || hm_curl -skI --max-time 5 "https://$server/" >/dev/null 2>&1; then
    hm_emit vps_path OK "VPS path unavailable" \
      "Router can open TCP/443 to the configured Reality VPS." \
      "server=$server port=443" \
      "No action."
  elif [ "${recent_reality:-0}" -gt 0 ]; then
    hm_emit vps_path OK "VPS path unavailable" \
      "Direct TCP probe tool could not verify the VPS, but recent reality-out traffic is visible." \
      "server=$server port=443 active_check=unavailable recent_reality_out=$recent_reality" \
      "No action unless users report managed-site failures."
  else
    hm_emit vps_path CRIT "VPS path unavailable" \
      "Router cannot open TCP/443 to the configured Reality VPS." \
      "server=$server port=443" \
      "Check home WAN, VPS reachability, Caddy listener, and provider status."
  fi
}

probe_singbox_health() {
  should_run singbox_health || return 0
  redirect_port="$(hm_runtime_port singbox_health "${HEALTH_MONITOR_REDIRECT_PORT:-}" redirect-in)" || return 0
  socks_port="$(hm_runtime_port singbox_health "${HEALTH_MONITOR_SOCKS_PORT:-}" dnscrypt-socks-in)" || return 0
  home_port="$(hm_runtime_port singbox_health "${HEALTH_MONITOR_HOME_REALITY_PORT:-}" reality-in)" || return 0
  ps_out="$(ps 2>/dev/null | grep '[s]ing-box' || true)"
  netstat_out="$(netstat -nlp 2>/dev/null || true)"
  missing=""

  printf '%s\n' "$netstat_out" | grep -q ":$redirect_port " || missing="${missing} redirect_listener"
  printf '%s\n' "$netstat_out" | grep -q "127.0.0.1:$socks_port " || missing="${missing} socks_listener"
  printf '%s\n' "$netstat_out" | grep -q "0.0.0.0:$home_port" || missing="${missing} home_reality_listener"

  if [ -z "$ps_out" ]; then
    hm_emit singbox_health CRIT "sing-box unhealthy" \
      "sing-box process is not visible in ps output." \
      "missing_process=1" \
      "Inspect logs and restart sing-box only with operator approval."
  elif [ -n "$missing" ]; then
    hm_emit singbox_health CRIT "sing-box unhealthy" \
      "sing-box is running but one or more expected listeners are missing." \
      "missing=${missing# }" \
      "Check /opt/etc/sing-box/config.json and S99singbox status."
  else
    hm_emit singbox_health OK "sing-box unhealthy" \
      "sing-box process and expected listeners are present." \
      "listeners=redirect,socks,home_reality" \
      "No action."
  fi
}

probe_home_reality_ingress() {
  should_run home_reality_ingress || return 0
  home_port="$(hm_runtime_port home_reality_ingress "${HEALTH_MONITOR_HOME_REALITY_PORT:-}" reality-in)" || return 0
  netstat_out="$(netstat -nlp 2>/dev/null || true)"
  input_rules="$(iptables -S INPUT 2>/dev/null || true)"
  mangle_rules="$(iptables -t mangle -S 2>/dev/null || true)"
  issues=""

  printf '%s\n' "$netstat_out" | grep -q "0.0.0.0:$home_port" || issues="${issues} listener_missing"
  printf '%s\n' "$input_rules" | grep -- "--dport $home_port" | grep -q -- '-j ACCEPT' || issues="${issues} input_accept_missing"
  printf '%s\n' "$mangle_rules" | grep -- "--dport $home_port" | grep -q 'TCPMSS' || issues="${issues} mss_prerouting_missing"
  printf '%s\n' "$mangle_rules" | grep -- "--sport $home_port" | grep -q 'TCPMSS' || issues="${issues} mss_output_missing"

  if printf '%s\n' "$issues" | grep -q 'listener_missing'; then
    hm_emit home_reality_ingress CRIT "Home Reality ingress down" \
      "The router is not listening on the configured Home Reality ingress." \
      "issues=${issues# }" \
      "Check sing-box home Reality inbound and firewall-start state."
  elif [ -n "$issues" ]; then
    hm_emit home_reality_ingress WARN "Home Reality ingress degraded" \
      "Home Reality listener is present but supporting firewall/MSS rules drifted." \
      "issues=${issues# }" \
      "Run diagnostics from the runbook before re-applying routing hooks."
  else
    hm_emit home_reality_ingress OK "Home Reality ingress down" \
      "Home Reality listener and supporting rules are present." \
      "port=configured" \
      "No action."
  fi
}

probe_mobile_activity() {
  should_run mobile_activity || return 0
  log="$(hm_singbox_log)"
  today="$(date +%Y-%m-%d)"
  [ -r "$log" ] || {
    hm_emit mobile_activity UNKNOWN "Remote device inactivity" \
      "sing-box log is not readable, so Home Reality activity cannot be assessed." \
      "log=$log" \
      "Check log path and rotation."
    return 0
  }

  count="$(grep " $today " "$log" 2>/dev/null | grep -c 'inbound/vless\[reality-in\]' || true)"
  if [ "${count:-0}" -gt 0 ]; then
    hm_emit mobile_activity OK "Remote device inactivity" \
      "Home Reality clients were observed today." \
      "reality_in_log_lines=$count" \
      "No action."
  else
    hm_emit mobile_activity WARN "Remote device inactivity" \
      "No Home Reality client activity was observed in today's sing-box log." \
      "reality_in_log_lines=0" \
      "If remote devices should be active, check client profiles and home ingress reachability."
  fi
}

probe_mobile_routing_leaks() {
  should_run mobile_routing_leaks || return 0
  log="$(hm_singbox_log)"
  today="$(date +%Y-%m-%d)"
  dnsmasq_file="${HEALTH_MONITOR_DNSMASQ_FILE:-/jffs/configs/dnsmasq-stealth.conf.add}"
  auto_file="${HEALTH_MONITOR_DNSMASQ_AUTO_FILE:-/jffs/configs/dnsmasq-autodiscovered.conf.add}"
  direct_file="${HEALTH_MONITOR_DIRECT_DOMAINS_FILE:-/jffs/configs/domains-no-vpn.txt}"
  tmp_prefix="/tmp/health-monitor-mobile-leaks.$$"
  managed_domains="${tmp_prefix}.managed"
  direct_domains="${tmp_prefix}.direct"
  split_result="${tmp_prefix}.split"
  [ -r "$log" ] || {
    hm_emit mobile_routing_leaks UNKNOWN "Mobile route split cannot be assessed" \
      "sing-box log is not readable." \
      "log=$log" \
      "Check log path and rotation."
    return 0
  }

  extract_stealth_domains "$dnsmasq_file" "$auto_file" > "$managed_domains"
  extract_direct_domains "$direct_file" "$(hm_singbox_config)" > "$direct_domains"
  since_ts="$(split_policy_since_ts)"
  since_label="$(printf '%s' "${since_ts:-day_start}" | tr ' ' T)"
  analyze_client_split "$managed_domains" "$direct_domains" "$log" "$today" 'inbound/vless[reality-in]' "$since_ts" > "$split_result"
  managed_direct="$(split_kv "$split_result" managed_direct)"
  managed_direct_sample="$(split_kv "$split_result" managed_direct_sample)"
  direct_via_vps="$(split_kv "$split_result" direct_via_vps)"
  direct_via_vps_sample="$(split_kv "$split_result" direct_via_vps_sample)"
  total="$(split_kv "$split_result" total)"
  reality="$(split_kv "$split_result" reality)"
  direct="$(split_kv "$split_result" direct)"
  unresolved="$(split_kv "$split_result" unresolved)"
  rm -f "$managed_domains" "$direct_domains" "$split_result"

  if [ "${managed_direct:-0}" -gt 0 ] || [ "${direct_via_vps:-0}" -gt 0 ]; then
    hm_emit mobile_routing_leaks WARN "Mobile managed/direct routing leak suspected" \
      "Home Reality connection-ID scan found destinations that may have used the wrong outbound." \
      "since=$since_label total=${total:-0} reality=${reality:-0} direct=${direct:-0} unresolved=${unresolved:-0} managed_direct=${managed_direct:-0} direct_via_vps=${direct_via_vps:-0} sample_managed_direct=${managed_direct_sample:-none} sample_direct_via_vps=${direct_via_vps_sample:-none}" \
      "Review traffic-report today and rule-set sync before changing catalogs."
  else
    hm_emit mobile_routing_leaks OK "Mobile managed/direct routing leak suspected" \
      "No obvious Home Reality split-routing leak was found in today's client connection IDs." \
      "since=$since_label total=${total:-0} reality=${reality:-0} direct=${direct:-0} unresolved=${unresolved:-0} managed_direct=0 direct_via_vps=0" \
      "No action."
  fi
}

