#!/bin/bash
set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
. "${PROJECT_ROOT}/modules/shared/lib/router-health-common.sh"

JSON_MODE=0
ACTIVE_PROBE=0
DEPLOY_GATE=0
LOG_ENABLED=1
CHANNEL="all"
LOG_DIR="${GHOSTROUTE_LIVE_CHECK_LOG_DIR:-${PROJECT_ROOT}/reports/live-check}"

usage() {
  cat <<'USAGE'
Usage: ./modules/ghostroute-health-monitor/bin/live-check [--json] [--active-probe] [--deploy-gate] [--no-log] [all|channel-a|channel-b|channel-c]

Read-only live A/B/C runtime-chain check.
Default mode checks listeners, firewall rules, sing-box split rules, DNS/catalog
sanity, iCloud Reality cover SNI, recent sanitised log evidence, and the
Console VPS-to-router collector path when Ansible/Vault are available.
--active-probe also runs bounded curl/TCP probes and may take about 15-30s.
--deploy-gate implies --active-probe and promotes deploy-critical WARN/N/A
checks to CRIT so mutating deploy entrypoints can stop before changing runtime.
USAGE
}

while [ $# -gt 0 ]; do
  case "$1" in
    --json)
      JSON_MODE=1
      shift
      ;;
    --active-probe)
      ACTIVE_PROBE=1
      shift
      ;;
    --deploy-gate)
      DEPLOY_GATE=1
      ACTIVE_PROBE=1
      shift
      ;;
    --no-log)
      LOG_ENABLED=0
      shift
      ;;
    all|check|quick|channels|channel-check)
      CHANNEL="all"
      shift
      ;;
    channel-a|a)
      CHANNEL="channel-a"
      shift
      ;;
    channel-b|b)
      CHANNEL="channel-b"
      shift
      ;;
    channel-c|c)
      CHANNEL="channel-c"
      shift
      ;;
    -h|--help|help)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 64
      ;;
  esac
done

router_health_load_env

raw_tmp="$(mktemp)"
trap 'rm -f "$raw_tmp"' EXIT

append_local_check() {
  printf 'CHECK|%s|%s|%s|%s|%s|%s\n' "$1" "$2" "$3" "$4" "$5" "$6" >>"$raw_tmp"
}

append_vps_router_check() {
  [ "$CHANNEL" = "all" ] || return 0
  [ "${GHOSTROUTE_LIVE_CHECK_VPS_ROUTER:-1}" = "1" ] || {
    append_local_check console_vps_router_tcp N/A "Console collector" "VPS to router check is disabled" "enabled=0" "Enable GHOSTROUTE_LIVE_CHECK_VPS_ROUTER when debugging Console freshness."
    return 0
  }

  ansible_dir="${PROJECT_ROOT}/ansible"
  if ! command -v ansible >/dev/null 2>&1 || [ ! -r "${ansible_dir}/secrets/stealth.yml" ]; then
    append_local_check console_vps_router_profile N/A "Console collector" "VPS router profile check is unavailable on this control machine" "ansible_or_vault=missing" "Run from the GhostRoute control machine with Vault access to check Console freshness path."
    append_local_check console_vps_router_tcp N/A "Console collector" "VPS to router TCP check is unavailable on this control machine" "ansible_or_vault=missing" "Run from the GhostRoute control machine with Vault access to check Console freshness path."
    return 0
  fi

  set +e
  vps_check_output="$(
    cd "$ansible_dir" &&
      ansible vps_stealth -e @secrets/stealth.yml -b -m shell -a 'set -eu
profile=missing
key=missing
tcp=NA
tool=none
if [ -r /opt/ghostroute-console/router.env ]; then
  profile=present
  set -a
  . /opt/ghostroute-console/router.env
  set +a
  probe_timeout=5
  if [ -n "${SSH_IDENTITY_FILE:-}" ] && [ -r "$SSH_IDENTITY_FILE" ]; then
    key=present
  fi
  if [ -n "${ROUTER:-}" ] && [ -n "${ROUTER_PORT:-}" ]; then
    if command -v nc >/dev/null 2>&1; then
      tool=nc
      timeout "$probe_timeout" nc -z "$ROUTER" "$ROUTER_PORT" >/dev/null 2>&1 && tcp=OK || tcp=FAIL
    elif command -v bash >/dev/null 2>&1; then
      tool=bash
      timeout "$probe_timeout" bash -c ": > /dev/tcp/$ROUTER/$ROUTER_PORT" >/dev/null 2>&1 && tcp=OK || tcp=FAIL
    else
      tcp=NO_TOOL
    fi
  fi
fi
echo PROFILE=$profile
echo KEY=$key
echo TCP=$tcp
echo TOOL=$tool
' 2>/dev/null
  )"
  vps_check_rc=$?
  set -e

  if [ "$vps_check_rc" -ne 0 ]; then
    append_local_check console_vps_router_profile WARN "Console collector" "Could not verify Console router profile on VPS" "ansible=failed" "Check Ansible/Vault access, then verify /opt/ghostroute-console/router.env on the VPS."
    append_local_check console_vps_router_tcp WARN "Console collector" "Could not verify VPS to router TCP reachability" "ansible=failed" "Run Console collector smoke from the VPS before trusting Dashboard freshness."
    return 0
  fi

  profile="$(printf '%s\n' "$vps_check_output" | awk -F= '$1=="PROFILE"{print $2; exit}')"
  key="$(printf '%s\n' "$vps_check_output" | awk -F= '$1=="KEY"{print $2; exit}')"
  tcp="$(printf '%s\n' "$vps_check_output" | awk -F= '$1=="TCP"{print $2; exit}')"
  tool="$(printf '%s\n' "$vps_check_output" | awk -F= '$1=="TOOL"{print $2; exit}')"

  if [ "$profile" = "present" ] && [ "$key" = "present" ]; then
    append_local_check console_vps_router_profile OK "Console collector" "Console router profile is installed on VPS" "profile=present key=present" "No action."
  else
    append_local_check console_vps_router_profile WARN "Console collector" "Console router profile is incomplete on VPS" "profile=${profile:-unknown} key=${key:-unknown}" "Install the Console read-only router profile before relying on live Dashboard freshness."
  fi

  case "$tcp" in
    OK)
      append_local_check console_vps_router_tcp OK "Console collector" "VPS can open the router remote endpoint used by Console" "tcp=OK tool=${tool:-unknown}" "No action."
      ;;
    FAIL)
      append_local_check console_vps_router_tcp WARN "Console collector" "VPS cannot open the router remote endpoint used by Console" "tcp=FAIL tool=${tool:-unknown}" "Compare Console router.env with the active local router profile and check router remote SSH exposure."
      ;;
    NO_TOOL)
      append_local_check console_vps_router_tcp WARN "Console collector" "VPS cannot run a bounded TCP reachability check" "tcp=NO_TOOL" "Install nc or bash on the VPS before relying on this check."
      ;;
    *)
      append_local_check console_vps_router_tcp N/A "Console collector" "VPS to router TCP check has no configured endpoint" "tcp=${tcp:-unknown}" "Install the Console router profile if Dashboard freshness is expected."
      ;;
  esac
}

append_vps_edge_check() {
  [ "$CHANNEL" = "all" ] || return 0
  [ "$DEPLOY_GATE" = "1" ] || return 0

  ansible_dir="${PROJECT_ROOT}/ansible"
  if ! command -v ansible >/dev/null 2>&1 || [ ! -r "${ansible_dir}/secrets/stealth.yml" ]; then
    append_local_check vps_edge_tcp443_listener N/A "VPS edge" "VPS edge check is unavailable on this control machine" "ansible_or_vault=missing" "Run from the GhostRoute control machine with Vault access before deploying."
    append_local_check vps_edge_public_dns53_closed N/A "VPS edge" "VPS public DNS exposure check is unavailable on this control machine" "ansible_or_vault=missing" "Run from the GhostRoute control machine with Vault access before deploying."
    return 0
  fi

  set +e
  vps_edge_output="$(
    cd "$ansible_dir" &&
      ansible vps_stealth -e @secrets/stealth.yml -b -m shell -a 'set -eu
tcp443=FAIL
dns53=UNKNOWN
tool=none
if command -v ss >/dev/null 2>&1; then
  tool=ss
  ss -ltn 2>/dev/null | awk '"'"'$4 ~ /(^|[.:])443$/ { found = 1 } END { exit(found ? 0 : 1) }'"'"' && tcp443=OK || tcp443=FAIL
elif command -v netstat >/dev/null 2>&1; then
  tool=netstat
  netstat -ltn 2>/dev/null | awk '"'"'$4 ~ /(^|[.:])443$/ { found = 1 } END { exit(found ? 0 : 1) }'"'"' && tcp443=OK || tcp443=FAIL
fi
if command -v ufw >/dev/null 2>&1; then
  ufw_text="$(ufw status verbose 2>/dev/null || true)"
  if printf "%s\n" "$ufw_text" | grep -E "^[[:space:]]*53/(tcp|udp)[[:space:]]+ALLOW[[:space:]]+IN" >/dev/null 2>&1; then
    dns53=FAIL
  elif printf "%s\n" "$ufw_text" | grep -E "^[[:space:]]*53/(tcp|udp)[[:space:]]+DENY[[:space:]]+IN" >/dev/null 2>&1; then
    dns53=OK
  else
    dns53=UNKNOWN
  fi
fi
echo TCP443=$tcp443
echo DNS53=$dns53
echo TOOL=$tool
' 2>/dev/null
  )"
  vps_edge_rc=$?
  set -e

  if [ "$vps_edge_rc" -ne 0 ]; then
    append_local_check vps_edge_tcp443_listener WARN "VPS edge" "Could not verify VPS TCP/443 listener" "ansible=failed" "Check Ansible/Vault access, then verify Caddy/layer4 and provider firewall."
    append_local_check vps_edge_public_dns53_closed WARN "VPS edge" "Could not verify VPS public DNS exposure" "ansible=failed" "Verify UFW/provider firewall keeps public TCP/UDP 53 closed."
    return 0
  fi

  tcp443="$(printf '%s\n' "$vps_edge_output" | awk -F= '$1=="TCP443"{print $2; exit}')"
  dns53="$(printf '%s\n' "$vps_edge_output" | awk -F= '$1=="DNS53"{print $2; exit}')"
  tool="$(printf '%s\n' "$vps_edge_output" | awk -F= '$1=="TOOL"{print $2; exit}')"

  if [ "$tcp443" = "OK" ]; then
    append_local_check vps_edge_tcp443_listener OK "VPS edge" "VPS TCP/443 listener is present" "tcp443=OK tool=${tool:-unknown}" "No action."
  else
    append_local_check vps_edge_tcp443_listener WARN "VPS edge" "VPS TCP/443 listener is missing or not visible" "tcp443=${tcp443:-unknown} tool=${tool:-unknown}" "Check Caddy/layer4, Xray/Reality backend and host/provider firewall before deploying."
  fi

  if [ "$dns53" = "OK" ]; then
    append_local_check vps_edge_public_dns53_closed OK "VPS edge" "VPS public TCP/UDP 53 is not allowed by host firewall" "dns53=closed" "No action."
  else
    append_local_check vps_edge_public_dns53_closed WARN "VPS edge" "VPS public DNS 53 exposure is not proven closed" "dns53=${dns53:-unknown}" "Ensure public TCP/UDP 53 is denied in provider and host firewall."
  fi
}

router_ssh "GHOSTROUTE_LIVE_FILTER='$CHANNEL' GHOSTROUTE_LIVE_ACTIVE_PROBE='$ACTIVE_PROBE' GHOSTROUTE_LIVE_DEPLOY_GATE='$DEPLOY_GATE' sh -s" >"$raw_tmp" <<'REMOTE'
set -eu

emit() {
  printf 'CHECK|%s|%s|%s|%s|%s|%s\n' "$1" "$2" "$3" "$4" "$5" "$6"
}

runtime_env=""
for candidate in /jffs/scripts/ghostroute-runtime.env /jffs/scripts/ghostroute-runtime-env; do
  [ -f "$candidate" ] && runtime_env="$candidate" && break
done

env_value() {
  key="$1"
  [ -n "$runtime_env" ] && awk -F= -v key="$key" '$1 == key { print substr($0, index($0, "=") + 1); exit }' "$runtime_env"
}

legacy_value() {
  key="$1"
  if [ -f /jffs/scripts/stealth-route-init.sh ]; then
    awk -F= -v key="$key" '$1 == key { gsub(/["'\''"]/, "", $2); print $2; exit }' /jffs/scripts/stealth-route-init.sh
  fi
}

redirect_port="$(env_value GHOSTROUTE_REDIRECT_PORT)"
home_reality_port="$(env_value GHOSTROUTE_HOME_REALITY_PORT)"
dnscrypt_socks_port="$(env_value GHOSTROUTE_DNSCRYPT_SOCKS_PORT)"
dnscrypt_port="$(env_value GHOSTROUTE_DNSCRYPT_PORT)"
managed_dns_forward_port="$(env_value GHOSTROUTE_MANAGED_DNS_FORWARD_PORT)"
vps_dns_port="$(env_value GHOSTROUTE_VPS_DNS_FORWARD_PORT)"
channel_b_enabled="$(env_value GHOSTROUTE_CHANNEL_B_HOME_ENABLED)"
channel_b_port="$(env_value GHOSTROUTE_CHANNEL_B_HOME_PORT)"
native_enabled="$(env_value GHOSTROUTE_CHANNEL_C_HOME_ENABLED)"
native_public="$(env_value GHOSTROUTE_CHANNEL_C_HOME_PUBLIC_PORT)"
native_port="$(env_value GHOSTROUTE_CHANNEL_C_HOME_PORT)"
sr_enabled="$(env_value GHOSTROUTE_CHANNEL_C_SHADOWROCKET_ENABLED)"
sr_public="$(env_value GHOSTROUTE_CHANNEL_C_SHADOWROCKET_PUBLIC_PORT)"
sr_port="$(env_value GHOSTROUTE_CHANNEL_C_SHADOWROCKET_PORT)"

redirect_port="${redirect_port:-$(legacy_value REDIRECT_PORT)}"
home_reality_port="${home_reality_port:-$(legacy_value HOME_REALITY_PORT)}"
dnscrypt_socks_port="${dnscrypt_socks_port:-$(legacy_value DNSCRYPT_SOCKS_PORT)}"
dnscrypt_port="${dnscrypt_port:-$(legacy_value DNSCRYPT_PORT)}"
managed_dns_forward_port="${managed_dns_forward_port:-$dnscrypt_port}"
vps_dns_port="${vps_dns_port:-15353}"
channel_b_enabled="${channel_b_enabled:-$(legacy_value CHANNEL_B_HOME_ENABLED)}"
channel_b_port="${channel_b_port:-$(legacy_value CHANNEL_B_HOME_PORT)}"
native_enabled="${native_enabled:-$(legacy_value CHANNEL_C_HOME_ENABLED)}"
native_public="${native_public:-$(legacy_value CHANNEL_C_HOME_PUBLIC_PORT)}"
native_port="${native_port:-$(legacy_value CHANNEL_C_HOME_PORT)}"
sr_enabled="${sr_enabled:-$(legacy_value CHANNEL_C_SHADOWROCKET_ENABLED)}"
sr_public="${sr_public:-$(legacy_value CHANNEL_C_SHADOWROCKET_PUBLIC_PORT)}"
sr_port="${sr_port:-$(legacy_value CHANNEL_C_SHADOWROCKET_PORT)}"

redirect_port="${redirect_port:-16000}"
home_reality_port="${home_reality_port:-4433}"
dnscrypt_socks_port="${dnscrypt_socks_port:-1080}"
dnscrypt_port="${dnscrypt_port:-5354}"
managed_dns_forward_port="${managed_dns_forward_port:-$dnscrypt_port}"
channel_b_enabled="${channel_b_enabled:-0}"
channel_b_port="${channel_b_port:-0}"
native_enabled="${native_enabled:-0}"
native_public="${native_public:-443}"
native_port="${native_port:-41955}"
sr_enabled="${sr_enabled:-0}"
sr_public="${sr_public:-4443}"
sr_port="${sr_port:-41956}"

filter="${GHOSTROUTE_LIVE_FILTER:-all}"
active_probe="${GHOSTROUTE_LIVE_ACTIVE_PROBE:-0}"
deploy_gate="${GHOSTROUTE_LIVE_DEPLOY_GATE:-0}"
managed_domain="${GHOSTROUTE_MANAGED_CHECK_DOMAIN:-ipify.org}"
direct_domain="${GHOSTROUTE_DIRECT_CHECK_DOMAIN:-championat.com}"
cover_sni="${GHOSTROUTE_COVER_SNI:-gateway.icloud.com}"

listen_sockets="$(netstat -nlp 2>/dev/null || true)"
nat_prerouting="$(iptables -t nat -S PREROUTING 2>/dev/null || true)"
filter_input="$(iptables -S INPUT 2>/dev/null || true)"
filter_forward="$(iptables -S FORWARD 2>/dev/null || true)"
singbox_config="$(cat /opt/etc/sing-box/config.json 2>/dev/null || true)"
singbox_compact="$(printf '%s\n' "$singbox_config" | awk '{ gsub(/[[:space:]]/, ""); printf "%s", $0 }')"
log="/opt/var/log/sing-box.log"
tmp="/tmp/ghostroute-live-check.$$"
trap 'rm -f "$tmp"' EXIT
[ -f "$log" ] && tail -5000 "$log" 2>/dev/null > "$tmp" || : > "$tmp"

listener_ok() { printf '%s\n' "$listen_sockets" | grep -E "[:.]$1[[:space:]]" >/dev/null 2>&1; }
input_ok() { printf '%s\n' "$filter_input" | grep -F -- "--dport $1" | grep -F -- "-j ACCEPT" >/dev/null 2>&1; }
redirect_ok() { printf '%s\n' "$nat_prerouting" | grep -F -- "--dport $1" | grep -F -- "--to-ports $2" >/dev/null 2>&1; }
lan_redirect_ok() { printf '%s\n' "$nat_prerouting" | grep -F -- "-i br0" | grep -F -- "--to-ports $1" >/dev/null 2>&1; }
split_ok() {
  inbound="$1"
  printf '%s\n' "$singbox_compact" | grep -Fq "\"inbound\":\"$inbound\",\"rule_set\":[\"stealth-domains\",\"stealth-static\"],\"outbound\":\"reality-out\"" &&
    printf '%s\n' "$singbox_compact" | grep -Fq "\"inbound\":\"$inbound\",\"outbound\":\"direct-out\""
}
udp_drop_ok() {
  printf '%s\n' "$filter_forward" | grep -q -- '--dport 443 .*match-set STEALTH_DOMAINS dst .*DROP' &&
    printf '%s\n' "$filter_forward" | grep -q -- '--dport 443 .*match-set VPN_STATIC_NETS dst .*DROP'
}
line_count() { grep -F "$1" "$tmp" 2>/dev/null | wc -l | tr -d ' '; }
last_line() {
  grep -F "$1" "$tmp" 2>/dev/null | grep -F 'inbound connection to ' | tail -1 |
    sed -E -e 's/\[[^]]+\] inbound connection/[client] inbound connection/' \
      -e 's/[0-9]{1,3}(\.[0-9]{1,3}){3}/<ip>/g' \
      -e 's/from <ip>:[0-9]+/from <ip>:<port>/g' \
      -e 's/to <ip>:[0-9]+/to <ip>:<port>/g' || true
}

if [ "$filter" = all ] || [ "$filter" = channel-a ]; then
  listener_ok "$redirect_port" && emit channel_a_lan_listener OK "Channel A/LAN" "redirect-in listener is present" "port=$redirect_port" "No action." || emit channel_a_lan_listener CRIT "Channel A/LAN" "redirect-in listener is missing" "port=$redirect_port" "Check sing-box process before changing firewall."
  lan_redirect_ok "$redirect_port" && emit channel_a_lan_redirect OK "Channel A/LAN" "br0 managed TCP REDIRECT is present" "port=$redirect_port" "No action." || emit channel_a_lan_redirect CRIT "Channel A/LAN" "br0 managed TCP REDIRECT is missing" "port=$redirect_port" "Run verify and inspect firewall-start/nat-start; do not redeploy blindly."
  udp_drop_ok && emit channel_a_udp443_drop OK "Channel A/LAN" "managed UDP/443 DROP rules are present" "sets=STEALTH_DOMAINS,VPN_STATIC_NETS" "No action." || emit channel_a_udp443_drop WARN "Channel A/LAN" "managed UDP/443 DROP rules are incomplete" "sets=STEALTH_DOMAINS,VPN_STATIC_NETS" "Review firewall invariants before changing routing."
  listener_ok "$home_reality_port" && input_ok "$home_reality_port" && split_ok reality-in && emit home_reality_chain OK "Channel A/Home Reality" "Home Reality listener, INPUT and split rules are present" "port=$home_reality_port recent_log_lines=$(line_count 'inbound/vless[reality-in]')" "No action." || emit home_reality_chain CRIT "Channel A/Home Reality" "Home Reality runtime chain is incomplete" "port=$home_reality_port listener_input_split=check" "Check sing-box listener, INPUT rules and reality-in split."
  recent="$(line_count 'inbound/vless[reality-in]')"; last="$(last_line 'inbound/vless[reality-in]')"
  [ "$recent" -gt 0 ] && emit home_reality_recent OK "Channel A/Home Reality" "Recent Home Reality evidence is visible" "recent_log_lines=$recent last_seen=\"${last:-n/a}\"" "No action." || emit home_reality_recent IDLE "Channel A/Home Reality" "No recent Home Reality client event in log tail" "recent_log_lines=0" "If a client is trying now, inspect the client profile and ingress reachability."
fi

if [ "$filter" = all ] || [ "$filter" = channel-b ]; then
  if [ "$channel_b_enabled" = 1 ]; then
    listener_ok "$channel_b_port" && input_ok "$channel_b_port" && split_ok channel-b-relay-socks && emit channel_b_chain OK "Channel B" "Channel B ingress and relay split are present" "port=$channel_b_port recent_log_lines=$(line_count 'inbound/socks[channel-b-relay-socks]')" "No action." || emit channel_b_chain CRIT "Channel B" "Channel B runtime chain is incomplete" "port=$channel_b_port" "Check Channel B ingress, INPUT rules and relay SOCKS split."
  else
    emit channel_b_chain N/A "Channel B" "Channel B is disabled in runtime config" "enabled=0" "No action unless Channel B should be enabled."
  fi
  recent="$(line_count 'inbound/socks[channel-b-relay-socks]')"; last="$(last_line 'inbound/socks[channel-b-relay-socks]')"
  [ "$recent" -gt 0 ] && emit channel_b_recent OK "Channel B" "Recent Channel B relay evidence is visible" "recent_log_lines=$recent last_seen=\"${last:-n/a}\"" "No action." || emit channel_b_recent IDLE "Channel B" "No recent Channel B client event in log tail" "recent_log_lines=0" "If a Channel B client is trying now, check client profile and ingress reachability."
fi

if [ "$filter" = all ] || [ "$filter" = channel-c ]; then
  listener_ok "$sr_port" && input_ok "$sr_port" && { [ "$sr_public" = "$sr_port" ] || redirect_ok "$sr_public" "$sr_port"; } && split_ok channel-c-shadowrocket-http-in && emit channel_c_shadowrocket_chain OK "Channel C/C1-Shadowrocket" "C1-Shadowrocket listener, redirect, INPUT and split are present" "public_port=$sr_public internal_port=$sr_port recent_log_lines=$(line_count 'inbound/http[channel-c-shadowrocket-http-in]')" "No action." || emit channel_c_shadowrocket_chain CRIT "Channel C/C1-Shadowrocket" "C1-Shadowrocket runtime chain is incomplete" "public_port=$sr_public internal_port=$sr_port" "Check C1-Shadowrocket listener, redirect, INPUT and split."
  sr_recent="$(line_count 'inbound/http[channel-c-shadowrocket-http-in]')"; sr_last="$(last_line 'inbound/http[channel-c-shadowrocket-http-in]')"
  [ "$sr_recent" -gt 0 ] && emit channel_c_shadowrocket_recent OK "Channel C/C1-Shadowrocket" "Recent C1-Shadowrocket evidence is visible" "recent_log_lines=$sr_recent last_seen=\"${sr_last:-n/a}\"" "No action." || emit channel_c_shadowrocket_recent IDLE "Channel C/C1-Shadowrocket" "No recent C1-Shadowrocket client event in log tail" "recent_log_lines=0" "If a C1 client is trying now, check Shadowrocket profile and public port."
  listener_ok "$native_port" && input_ok "$native_port" && { [ "$native_public" = "$native_port" ] || redirect_ok "$native_public" "$native_port"; } && split_ok channel-c-naive-in && emit channel_c_native_chain OK "Channel C/native Naive" "Native Naive listener, redirect, INPUT and split are present" "public_port=$native_public internal_port=$native_port" "No action." || emit channel_c_native_chain WARN "Channel C/native Naive" "Native Naive runtime chain is incomplete" "public_port=$native_public internal_port=$native_port" "Native Naive is experimental; check only if testing an SFI client."
  native_recent="$(line_count 'inbound/naive[channel-c-naive-in]')"; native_last="$(last_line 'inbound/naive[channel-c-naive-in]')"
  [ "$native_recent" -gt 0 ] && emit channel_c_native_recent OK "Channel C/native Naive" "Recent native Naive evidence is visible" "recent_log_lines=$native_recent last_seen=\"${native_last:-n/a}\"" "No action." || emit channel_c_native_recent IDLE "Channel C/native Naive" "No recent native Naive client event; expected for tested iPhone SFI builds" "recent_log_lines=0" "No action unless actively testing native Naive support."
fi

if [ "$filter" = all ]; then
  listener_ok 53 && emit dnsmasq_listener OK "DNS/catalog" "dnsmasq listener is present" "port=53" "No action." || emit dnsmasq_listener CRIT "DNS/catalog" "dnsmasq listener is missing" "port=53" "Check dnsmasq before changing routing."
  listener_ok "$vps_dns_port" && emit vps_dns_in_listener OK "DNS/catalog" "vps-dns-in listener is present" "port=$vps_dns_port" "No action." || emit vps_dns_in_listener WARN "DNS/catalog" "vps-dns-in listener is missing" "port=$vps_dns_port" "Managed DNS may not use VPS path; check sing-box DNS inbound."
  grep -q "^server=/$managed_domain/127.0.0.1#$managed_dns_forward_port\$" /jffs/configs/dnsmasq-vps-managed.conf.add 2>/dev/null && emit managed_dns_forward_target OK "DNS/catalog" "Managed DNS include points to dnscrypt-backed local forwarder" "domain=$managed_domain port=$managed_dns_forward_port" "No action." || emit managed_dns_forward_target WARN "DNS/catalog" "Managed DNS include is not using the dnscrypt-backed forwarder" "domain=$managed_domain expected_port=$managed_dns_forward_port" "Regenerate rule-sets with the current managed DNS forward target before troubleshooting clients."
  grep -q "^ipset=/$managed_domain/STEALTH_DOMAINS\$" /jffs/configs/dnsmasq-stealth.conf.add 2>/dev/null && grep -q "\"$managed_domain\"" /opt/etc/sing-box/rule-sets/stealth-domains.json 2>/dev/null && emit managed_domain_sanity OK "DNS/catalog" "Managed checker domain is present in dnsmasq catalog and sing-box rule-set" "domain=$managed_domain" "No action." || emit managed_domain_sanity CRIT "DNS/catalog" "Managed checker domain is missing from catalog or rule-set" "domain=$managed_domain" "Run catalog review/sync dry-run before applying changes."
  grep -Eq "^[[:space:]]*$direct_domain([[:space:]]*(#.*)?)?$" /jffs/configs/domains-no-vpn.txt 2>/dev/null && emit direct_domain_sanity OK "DNS/catalog" "Direct checker domain is present in domains-no-vpn" "domain=$direct_domain expected_route=direct" "No action." || emit direct_domain_sanity WARN "DNS/catalog" "Direct checker domain is missing from domains-no-vpn" "domain=$direct_domain" "Review direct-domain policy before changing catalog."
  ! grep -q "^server=/$direct_domain/" /jffs/configs/dnsmasq-vps-managed.conf.add 2>/dev/null && ! grep -q "\"$direct_domain\"" /opt/etc/sing-box/rule-sets/stealth-domains.json 2>/dev/null && emit direct_domain_not_managed OK "DNS/catalog" "Direct checker domain is absent from managed DNS include and sing-box managed rule-set" "domain=$direct_domain expected_route=direct" "No action." || emit direct_domain_not_managed WARN "DNS/catalog" "Direct checker domain is present in managed DNS or sing-box rule-set" "domain=$direct_domain" "Remove the direct checker from managed catalogs before deploying."
  printf '%s\n' "$singbox_compact" | grep -Fq "\"server_name\":\"$cover_sni\"" && printf '%s\n' "$singbox_compact" | grep -Fq "\"handshake\":{\"server\":\"$cover_sni\",\"server_port\":443}" && emit reality_cover_sni OK "Reality SNI" "Router sing-box uses expected iCloud cover SNI" "sni=$cover_sni" "No action." || emit reality_cover_sni CRIT "Reality SNI" "Router sing-box cover SNI does not match expected iCloud value" "sni=$cover_sni" "Check generated sing-box config; do not rotate SNI blindly."
fi

if [ "$active_probe" = 1 ]; then
  curl_bin=""
  if [ -x /opt/bin/curl ]; then
    curl_bin="/opt/bin/curl"
  elif command -v curl >/dev/null 2>&1; then
    curl_bin="$(command -v curl)"
  fi
  if [ -z "$curl_bin" ]; then
    emit active_probe_tooling WARN "Active probe" "curl is unavailable on router" "curl=missing" "Install/restore curl before relying on active probes."
  else
    timeout 6 nslookup "$managed_domain" 127.0.0.1 >/dev/null 2>&1 && emit active_managed_dns_query OK "Active probe" "Managed checker resolves through router dnsmasq" "domain=$managed_domain" "No action." || emit active_managed_dns_query WARN "Active probe" "Managed checker DNS resolution through router dnsmasq failed" "domain=$managed_domain" "Inspect dnsmasq managed forward target and sing-box DNS logs before changing routing."
    timeout 6 nslookup "$cover_sni" 127.0.0.1 >/dev/null 2>&1 && emit active_cover_dns_query OK "Active probe" "Reality cover SNI resolves through router dnsmasq" "sni=$cover_sni" "No action." || emit active_cover_dns_query WARN "Active probe" "Reality cover SNI DNS resolution through router dnsmasq failed" "sni=$cover_sni" "Check the sing-box DNS resolver path; mobile Reality handshakes can fail if this lookup is broken."
    managed_identity=""
    direct_identity=""
    "$curl_bin" -sS --max-time 8 --proxy "socks5h://127.0.0.1:$dnscrypt_socks_port" "https://api.ipify.org" >/tmp/ghostroute-active-managed.$$ 2>/dev/null && managed_identity="$(cat /tmp/ghostroute-active-managed.$$ 2>/dev/null || true)" && emit active_managed_egress OK "Active probe" "Managed checker can use sing-box SOCKS/Reality path" "domain=$managed_domain socks_port=$dnscrypt_socks_port" "No action." || emit active_managed_egress WARN "Active probe" "Managed active egress probe failed" "domain=$managed_domain socks_port=$dnscrypt_socks_port" "Use default evidence and health report before restarting services."
    "$curl_bin" -skI --max-time 8 "https://$direct_domain" >/dev/null 2>&1 && emit active_direct_egress OK "Active probe" "Direct checker domain is reachable from router" "domain=$direct_domain" "No action." || emit active_direct_egress WARN "Active probe" "Direct checker domain probe failed" "domain=$direct_domain" "Could be remote site/network; compare with client symptom before changing rules."
    direct_identity="$("$curl_bin" -sS --max-time 8 "https://api.ipify.org" 2>/dev/null || true)"
    if [ -n "$managed_identity" ] && [ -n "$direct_identity" ] && [ "$managed_identity" != "$direct_identity" ]; then
      emit active_direct_identity OK "Active probe" "Router direct identity differs from managed Reality identity" "identity_match=0" "No action."
    elif [ -n "$managed_identity" ] && [ -n "$direct_identity" ]; then
      emit active_direct_identity WARN "Active probe" "Router direct identity matches managed Reality identity" "identity_match=1" "Check router OUTPUT/default path; direct/RU traffic may be using the managed egress."
    else
      emit active_direct_identity WARN "Active probe" "Could not compare direct and managed egress identity" "identity_match=unknown" "Check curl/ipify reachability before deploying."
    fi
    "$curl_bin" -skI --max-time 8 "https://$cover_sni" >/dev/null 2>&1 && emit active_cover_sni OK "Active probe" "iCloud cover SNI is reachable from router" "sni=$cover_sni" "No action." || emit active_cover_sni WARN "Active probe" "iCloud cover SNI reachability probe failed" "sni=$cover_sni" "Check WAN/DNS reachability; do not rotate SNI from one failed probe."
    rm -f /tmp/ghostroute-active-managed.$$
  fi
fi
REMOTE

append_vps_router_check
append_vps_edge_check
raw="$(cat "$raw_tmp")"

stamp="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"

rendered_tmp="$(mktemp)"
trap 'rm -f "$raw_tmp" "$rendered_tmp"' EXIT
RAW_INPUT="$raw" ruby -rjson -rtime - "$JSON_MODE" "$ACTIVE_PROBE" "$CHANNEL" "$stamp" "$DEPLOY_GATE" >"$rendered_tmp" <<'RUBY'
json_mode = ARGV[0] == "1"
active_probe = ARGV[1] == "1"
channel = ARGV[2]
generated_at = ARGV[3]
deploy_gate = ARGV[4] == "1"

rank = { "OK" => 0, "N/A" => 0, "IDLE" => 0, "WARN" => 1, "CRIT" => 2 }
gate_required = %w[
  channel_a_lan_listener
  channel_a_lan_redirect
  channel_a_udp443_drop
  home_reality_chain
  channel_b_chain
  channel_c_shadowrocket_chain
  dnsmasq_listener
  managed_dns_forward_target
  managed_domain_sanity
  direct_domain_sanity
  direct_domain_not_managed
  reality_cover_sni
  active_probe_tooling
  active_managed_dns_query
  active_cover_dns_query
  active_managed_egress
  active_direct_egress
  active_direct_identity
  active_cover_sni
  vps_edge_tcp443_listener
  vps_edge_public_dns53_closed
].to_h { |id| [id, true] }
checks = ENV.fetch("RAW_INPUT", "").each_line.map do |line|
  line = line.chomp
  next unless line.start_with?("CHECK|")
  _, id, status, component, summary, evidence, action = line.split("|", 7)
  if deploy_gate && gate_required[id] && status != "OK"
    status = "CRIT"
    summary = "Deploy gate failed: #{summary}"
    action = "#{action} This check must be OK before mutating deploy."
  end
  fields = {}
  evidence.to_s.scan(/([A-Za-z0-9_]+)=("[^"]*"|[^ ]+)/) do |key, value|
    fields[key] = value.to_s.sub(/\A"/, "").sub(/"\z/, "")
  end
  {
    id: id,
    status: status,
    component: component,
    summary: summary,
    evidence: evidence.to_s,
    evidence_fields: fields,
    suggested_action: action.to_s
  }
end.compact

overall_rank = checks.map { |c| rank.fetch(c[:status], 1) }.max || 1
overall = overall_rank == 2 ? "CRIT" : overall_rank == 1 ? "WARN" : "OK"
payload = {
  schema_version: 1,
  command: "ghostroute-health-monitor live-check",
  generated_at: generated_at,
  mode: deploy_gate ? "deploy-gate" : active_probe ? "active-probe" : "default",
  deploy_gate: deploy_gate,
  channel: channel,
  estimated_duration: deploy_gate ? "40-90s" : active_probe ? "15-30s" : "1-8s",
  overall_status: overall,
  exit_code: overall == "CRIT" ? 2 : overall == "WARN" ? 1 : 0,
  checks: checks
}

if json_mode
  puts JSON.pretty_generate(payload)
else
  puts "GhostRoute Health Monitor Live Check"
  puts "Generated: #{generated_at}"
  puts "Mode: #{payload[:mode]} (estimated #{payload[:estimated_duration]})"
  puts "Channel filter: #{channel}"
  puts "Overall: #{overall}"
  puts
  checks.each do |check|
    puts "[#{check[:status]}] #{check[:component]} / #{check[:id]} - #{check[:summary]}"
    puts "  evidence: #{check[:evidence]}" unless check[:evidence].empty?
    puts "  action: #{check[:suggested_action]}" unless check[:suggested_action].empty?
  end
end
RUBY
rendered="$(cat "$rendered_tmp")"

if [ "$LOG_ENABLED" = "1" ]; then
  mkdir -p "$LOG_DIR"
  file_stamp="$(date -u '+%Y%m%dT%H%M%SZ')"
  log_file="${LOG_DIR}/live-check-${file_stamp}.txt"
  latest_file="${LOG_DIR}/latest.txt"
  printf '%s\n' "$rendered" > "$log_file"
  cp "$log_file" "$latest_file"
fi

printf '%s\n' "$rendered"

if printf '%s\n' "$rendered" | grep -q '"exit_code": 2\|Overall: CRIT'; then
  exit 2
elif printf '%s\n' "$rendered" | grep -q '"exit_code": 1\|Overall: WARN'; then
  exit 1
fi
exit 0
