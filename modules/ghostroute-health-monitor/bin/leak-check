#!/bin/bash
# Active read-only leak/egress check for GhostRoute.

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
. "${PROJECT_ROOT}/modules/shared/lib/router-health-common.sh"

JSON_MODE=0
while [ $# -gt 0 ]; do
  case "$1" in
    --json)
      JSON_MODE=1
      shift
      ;;
    *)
      echo "Usage: ./modules/ghostroute-health-monitor/bin/leak-check [--json]" >&2
      exit 1
      ;;
  esac
done

TMPDIR="$(mktemp -d)"
trap 'rm -rf "$TMPDIR"' EXIT

RAW_FILE="${GHOSTROUTE_LEAK_RAW_FILE:-$TMPDIR/health-raw.jsonl}"

sanitize_line() {
  sed -E \
    -e 's/[0-9]{1,3}(\.[0-9]{1,3}){3}/<ip>/g' \
    -e 's/socks=[^ ]+/socks=<router-socks>/g' \
    -e 's/server=<ip>/server=<ip>/g' \
    -e 's/port=[0-9]+/port=<port>/g'
}

collect_probe_events() {
  if [ -n "${GHOSTROUTE_LEAK_RAW_FILE:-}" ]; then
    return 0
  fi
  if [ "${GHOSTROUTE_LEAK_SKIP_REMOTE:-0}" = "1" ]; then
    : > "$RAW_FILE"
    return 0
  fi

  router_ssh 'sh -s' <<'REMOTE' >/dev/null
set -eu
for probe in channel_a_reality mobile_routing_leaks channel_b_routing_leaks channel_c_routing_leaks dns_ipv6_leaks rule_set_sync; do
  /jffs/scripts/health-monitor/run-probes --probe "$probe" >/dev/null 2>&1 || true
done
REMOTE

  router_ssh 'sh -s' <<'REMOTE' > "$RAW_FILE" 2>/dev/null || true
base="/opt/var/log/router_configuration/health-monitor"
[ -f "$base/raw/$(date +%F).jsonl" ] || base="/jffs/addons/router_configuration/health-monitor"
cat "$base/raw/$(date +%F).jsonl" 2>/dev/null || true
REMOTE
}

collect_mirror_counts() {
  if [ -n "${GHOSTROUTE_LEAK_IPSET_COUNT:-}" ] || [ -n "${GHOSTROUTE_LEAK_MIRROR_COUNT:-}" ]; then
    printf '%s\t%s\n' "${GHOSTROUTE_LEAK_IPSET_COUNT:-unknown}" "${GHOSTROUTE_LEAK_MIRROR_COUNT:-unknown}"
    return 0
  fi
  if [ "${GHOSTROUTE_LEAK_SKIP_REMOTE:-0}" = "1" ]; then
    printf 'unknown\tunknown\n'
    return 0
  fi

  router_ssh 'sh -s' 2>/dev/null <<'REMOTE' || printf 'unknown\tunknown\n'
ipset_count="$(ipset list STEALTH_DOMAINS 2>/dev/null | awk '/^Number of entries:/ { print $4; exit }')"
rules="/opt/etc/sing-box/rule-sets/stealth-static.json"
mirror_count="unknown"
if [ -r "$rules" ]; then
  mirror_count="$(grep -Eo '"[0-9]+(\.[0-9]+){3}/32"' "$rules" 2>/dev/null | wc -l | tr -d ' ')"
fi
printf '%s\t%s\n' "${ipset_count:-unknown}" "${mirror_count:-unknown}"
REMOTE
}

latest_events() {
  ruby -rjson -e '
    probes = ARGV[1..-1]
    events = {}
    if File.exist?(ARGV[0])
      File.foreach(ARGV[0]) do |line|
        begin
          event = JSON.parse(line)
        rescue JSON::ParserError
          next
        end
        probe = event["probe"].to_s
        events[probe] = event if probes.include?(probe)
      end
    end
    probes.each do |probe|
      event = events[probe]
      if event
        fields = [
          probe,
          (event["status"] || "UNKNOWN").to_s,
          (event["message"] || "").to_s,
          (event["evidence"] || "").to_s
        ]
        puts fields.map { |field| field.gsub(/\s+/, " ").strip }.join("\t")
      else
        puts [probe, "SKIP", "No recent probe event was found.", "raw_event=missing"].join("\t")
      end
    end
  ' "$RAW_FILE" channel_a_reality mobile_routing_leaks channel_b_routing_leaks channel_c_routing_leaks dns_ipv6_leaks rule_set_sync
}

rank_status() {
  case "$1" in
    CRIT) printf '4' ;;
    WARN) printf '3' ;;
    SKIP|UNKNOWN) printf '2' ;;
    OK) printf '1' ;;
    *) printf '2' ;;
  esac
}

overall_from_rank() {
  case "$1" in
    4) printf 'CRIT' ;;
    3) printf 'WARN' ;;
    2) printf 'SKIP' ;;
    *) printf 'OK' ;;
  esac
}

collect_probe_events

max_rank=1
lines=()
json_rows=()
while IFS=$'\t' read -r probe status message evidence; do
  display_status="$status"
  label="$probe"
  case "$probe" in
    channel_a_reality)
      label="Reality exit"
      if [ "$status" = "OK" ] && printf '%s\n' "$evidence" | grep -F 'active_check=unavailable' >/dev/null 2>&1; then
        display_status="SKIP"
        message="Active SOCKS exit-IP probe unavailable; recent reality-out traffic is fallback evidence."
      fi
      ;;
    dns_ipv6_leaks)
      label="DNS/IPv6 policy"
      ;;
    mobile_routing_leaks)
      label="Home Reality split (Channel A)"
      ;;
    channel_b_routing_leaks)
      label="Channel B split"
      ;;
    channel_c_routing_leaks)
      label="Channel C split"
      ;;
    rule_set_sync)
      label="Rule-set sync"
      ;;
  esac

  rank="$(rank_status "$display_status")"
  [ "$rank" -le "$max_rank" ] || max_rank="$rank"
  clean_evidence="$(printf '%s\n' "${evidence:-n/a}" | sanitize_line)"
  lines+=("${label}: ${display_status} - ${message:-n/a} (${clean_evidence:-n/a})")
  json_rows+=("${probe}"$'\t'"${label}"$'\t'"${display_status}"$'\t'"${message:-n/a}"$'\t'"${clean_evidence:-n/a}")
done < <(latest_events)

IFS=$'\t' read -r ipset_count mirror_count < <(collect_mirror_counts)
mirror_status="SKIP"
mirror_message="Rule-set mirror count unavailable."
case "${ipset_count:-unknown}:${mirror_count:-unknown}" in
  *unknown*|*:|'')
    mirror_status="SKIP"
    mirror_message="Rule-set mirror count unavailable."
    ;;
  *)
    if [ "${ipset_count:-0}" -gt 0 ] 2>/dev/null && [ "${mirror_count:-0}" -gt 0 ] 2>/dev/null; then
      mirror_status="OK"
      mirror_message="Static raw-IP mirror has entries for mobile/ingress split routing."
    else
      mirror_status="CRIT"
      mirror_message="Static raw-IP mirror or STEALTH ipset is empty."
    fi
    ;;
esac

rank="$(rank_status "$mirror_status")"
[ "$rank" -le "$max_rank" ] || max_rank="$rank"
lines+=("Static IP mirror: ${mirror_status} - ${mirror_message} (STEALTH=${ipset_count:-unknown}, mirror=${mirror_count:-unknown})")
json_rows+=("static_ip_mirror"$'\t'"Static IP mirror"$'\t'"${mirror_status}"$'\t'"${mirror_message}"$'\t'"STEALTH=${ipset_count:-unknown}, mirror=${mirror_count:-unknown}")
lines+=("Channel C note: INFO - C1-SR / Shadowrocket :4443 works now as HTTPS CONNECT compatibility; C1-sing-box native Naive :443 is server-ready but client-blocked on tested iPhone SFI 1.11.4. (profiles=ansible/out/clients-channel-c/1-SR)")
json_rows+=("channel_c_note"$'\t'"Channel C note"$'\t'"INFO"$'\t'"C1-SR / Shadowrocket :4443 works now as HTTPS CONNECT compatibility; C1-sing-box native Naive :443 is server-ready but client-blocked on tested iPhone SFI 1.11.4."$'\t'"profiles=ansible/out/clients-channel-c/1-SR")

overall="$(overall_from_rank "$max_rank")"
next_command="./modules/ghostroute-health-monitor/bin/status"
case "$overall" in
  OK)
    next_command="./modules/ghostroute-health-monitor/bin/status"
    ;;
  SKIP|WARN)
    next_command="./modules/ghostroute-health-monitor/bin/router-health-report"
    ;;
  *)
    next_command="./verify.sh --verbose"
    ;;
esac

if [ "$JSON_MODE" = "1" ]; then
  JSON_ROWS_FILE="$TMPDIR/leak-check-rows.tsv"
  printf '%s\n' "${json_rows[@]}" > "$JSON_ROWS_FILE"
  ruby -rjson -rtime - "$overall" "$next_command" "$JSON_ROWS_FILE" <<'RUBY'
overall, next_command, rows_file = ARGV
rows = File.readlines(rows_file, chomp: true).reject(&:empty?).map do |line|
  probe, label, status, message, evidence = line.split("\t", 5)
  severity = case status
             when 'CRIT' then 'critical'
             when 'WARN' then 'warning'
             when 'OK' then 'info'
             else 'notice'
             end
  {
    probe: probe,
    label: label,
    status: status,
    severity: severity,
    message: message,
    evidence: evidence,
    confidence: 'exact'
  }
end

puts JSON.pretty_generate({
  schema_version: 1,
  generated_at: Time.now.utc.iso8601,
  source: {
    command: 'leak-check',
    confidence: 'exact'
  },
  confidence: 'exact',
  overall: overall,
  leaks: rows.select { |row| %w[CRIT WARN].include?(row[:status]) },
  checks: rows,
  evidence: rows.map { |row| { probe: row[:probe], evidence: row[:evidence] } },
  next_command: next_command
})
RUBY
  exit 0
fi

printf 'GhostRoute Leak Check\n'
printf 'Overall: %s\n' "$overall"
for line in "${lines[@]}"; do
  printf '%s\n' "$line"
done
printf 'Next: %s\n' "$next_command"
