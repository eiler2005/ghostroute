vps_ssh_host: "{{ vps_ssh_host }}"
vps_ssh_user: "{{ vps_ssh_user }}"

xui_admin_username: "{{ xui_admin_username }}"
xui_admin_password: "{{ xui_admin_password }}"
xui_admin_web_path: "{{ xui_admin_web_path }}"
xui_admin_web_port: {{ xui_admin_web_port }}

reality_dest: "{{ reality_dest }}"
reality_server_names:
{% for name in reality_server_names %}
  - "{{ name }}"
{% endfor %}
reality_server_private_key: "{{ template_reality_server_private_key }}"
reality_server_public_key: "{{ template_reality_server_public_key }}"
reality_short_ids:
{% for sid in template_reality_short_ids %}
  - "{{ sid }}"
{% endfor %}

# Remote mobile clients normally dial the home ASUS first. These identities
# live only on the router-side Reality inbound.
vault_home_reality_public_host: "{{ template_home_reality_public_host }}"
home_reality_ingress_port: {{ template_home_reality_ingress_port }}
home_reality_dest_host: "{{ template_home_reality_dest_host }}"
home_reality_dest_port: {{ template_home_reality_dest_port }}
home_reality_server_private_key: "{{ template_home_reality_server_private_key }}"
home_reality_server_public_key: "{{ template_home_reality_server_public_key }}"
home_reality_server_short_ids:
{% for sid in template_home_reality_server_short_ids %}
  - "{{ sid }}"
{% endfor %}

home_clients:
{% for client in template_home_clients %}
  - name: "{{ client.name }}"
    uuid: "{{ client.uuid }}"
    short_id: "{{ client.short_id }}"
{% endfor %}

# Emergency direct-VPS identities. Keep these disabled in client apps and
# use only when the home relay/router is unavailable but the VPS is healthy.
emergency_clients:
{% for client in template_emergency_clients %}
  - name: "{{ client.name }}"
    uuid: "{{ client.uuid }}"
    short_id: "{{ client.short_id }}"
    email: "{{ client.email | default(client.name ~ '@emergency.local') }}"
{% endfor %}

clients:
{% set emergency_uuids = template_emergency_clients | map(attribute='uuid') | list %}
{% for client in template_clients %}
{% if client.uuid not in emergency_uuids %}
  - name: "{{ client.name }}"
    uuid: "{{ client.uuid }}"
    short_id: "{{ client.short_id }}"
    email: "{{ client.email }}"
{% endif %}
{% endfor %}

router_ssh_host: "{{ router_ssh_host }}"
router_ssh_user: "{{ router_ssh_user }}"
