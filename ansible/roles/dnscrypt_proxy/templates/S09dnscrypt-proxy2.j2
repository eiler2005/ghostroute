#!/bin/sh
NAME="dnscrypt-proxy"
DAEMON="{{ dnscrypt_bin_path }}"
CONFIG="{{ dnscrypt_config_path }}"
PIDFILE="/opt/var/run/dnscrypt-proxy.pid"
LOGFILE="/opt/var/log/dnscrypt-proxy.log"

ensure_go_runtime_overcommit() {
    # Go dnscrypt-proxy needs virtual heap arena reservation. Strict overcommit
    # on Asuswrt/Entware can make the binary fail before config parsing.
    [ -w /proc/sys/vm/overcommit_memory ] && echo 1 > /proc/sys/vm/overcommit_memory
}

pid_is_live() {
    pid="$1"
    [ -n "$pid" ] || return 1
    kill -0 "$pid" 2>/dev/null || return 1
    state="$(ps w 2>/dev/null | awk -v pid="$pid" '$1 == pid { print $4; exit }')"
    [ -n "$state" ] || return 1
    case "$state" in
        *Z*) return 1 ;;
    esac
    return 0
}

live_pidof() {
    for pid in $(pidof "$NAME" 2>/dev/null); do
        if pid_is_live "$pid"; then
            echo "$pid"
            return 0
        fi
    done
    return 1
}

start() {
    PID=""
    [ -f "$PIDFILE" ] && PID="$(cat "$PIDFILE" 2>/dev/null || true)"
    if pid_is_live "$PID"; then
        echo "$NAME already running"
        return 0
    fi
    [ -n "$PID" ] && rm -f "$PIDFILE"
    EXISTING_PID="$(live_pidof || true)"
    if [ -n "$EXISTING_PID" ]; then
        echo "$EXISTING_PID" > "$PIDFILE"
        echo "$NAME already running (pid $EXISTING_PID)"
        return 0
    fi
    mkdir -p /opt/var/run /opt/var/log /opt/var/cache/dnscrypt-proxy
    ensure_go_runtime_overcommit
    nohup "$DAEMON" -config "$CONFIG" -logfile "$LOGFILE" >> "$LOGFILE" 2>&1 &
    echo $! > "$PIDFILE"
    sleep 2
    pid_is_live "$(cat "$PIDFILE" 2>/dev/null || true)" && echo "$NAME started" || {
        echo "$NAME failed to start"
        tail -n 20 "$LOGFILE" 2>/dev/null || true
        return 1
    }
}

stop() {
    if [ -f "$PIDFILE" ]; then
        kill "$(cat "$PIDFILE")" 2>/dev/null || true
        rm -f "$PIDFILE"
    fi
    killall "$NAME" 2>/dev/null || true
    for _ in 1 2 3 4 5; do
        live_pidof >/dev/null 2>&1 || break
        sleep 1
    done
    echo "$NAME stopped"
}

restart() {
    stop
    sleep 1
    start
}

status() {
    PID=""
    [ -f "$PIDFILE" ] && PID="$(cat "$PIDFILE" 2>/dev/null || true)"
    if pid_is_live "$PID"; then
        echo "running"
    else
        echo "stopped"
        return 1
    fi
}

case "$1" in
  start|stop|restart|status) "$1" ;;
  *) echo "usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac
