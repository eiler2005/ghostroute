#!/bin/sh
# Idempotent setup of Channel A routing and optional Channel B home ingress rules
# on Merlin router.
# Safe to re-run from firewall-start on every reconnect.

set -e

IPSET={{ stealth_ipset_name }}
STATIC_IPSET={{ stealth_static_source_ipset | default('VPN_STATIC_NETS') }}
MARK={{ stealth_fwmark }}
TABLE={{ stealth_route_table }}
IFACE={{ singbox_tun_name }}
REDIRECT_PORT={{ singbox_redirect_port }}
HOME_REALITY_PORT={{ home_reality_ingress_port }}
HOME_REALITY_CONNLIMIT_ABOVE={{ home_reality_connlimit_above | default(500) }}
HOME_REALITY_MSS={{ home_reality_mss | default(1360) }}
CHANNEL_B_HOME_ENABLED={{ channel_b_home_relay_enabled | default(false) | ternary('1', '0') }}
CHANNEL_B_HOME_PORT={{ channel_b_home_ingress_port | default(0) }}
CHANNEL_B_HOME_CONNLIMIT_ABOVE={{ channel_b_home_connlimit_above | default(500) }}
CHANNEL_B_HOME_MSS={{ channel_b_home_mss | default(1360) }}
ROUTER_TCP_PERF_TUNING={{ router_tcp_perf_tuning_enabled | default(true) | ternary('1', '0') }}
VPS_IP={{ vps_ssh_host }}
WAN_IF={{ wan_if }}
WAN_GW={{ wan_gw }}

{{ singbox_init_path }} start >/dev/null 2>&1 || true

# 0. Conservative TCP tuning for high-BDP mobile paths. These values keep the
# old Merlin defaults as floors, but allow the two TCP legs of the home relay to
# grow beyond the tiny 512 KiB core socket caps.
if [ "$ROUTER_TCP_PERF_TUNING" = "1" ]; then
  [ -e /proc/sys/net/core/rmem_max ] && echo {{ router_tcp_rmem_max | default(16777216) }} > /proc/sys/net/core/rmem_max
  [ -e /proc/sys/net/core/wmem_max ] && echo {{ router_tcp_wmem_max | default(16777216) }} > /proc/sys/net/core/wmem_max
  [ -e /proc/sys/net/ipv4/tcp_rmem ] && echo "{{ router_tcp_rmem | default('4096 262144 16777216') }}" > /proc/sys/net/ipv4/tcp_rmem
  [ -e /proc/sys/net/ipv4/tcp_wmem ] && echo "{{ router_tcp_wmem | default('4096 65536 16777216') }}" > /proc/sys/net/ipv4/tcp_wmem
  [ -e /proc/sys/net/ipv4/tcp_mtu_probing ] && echo {{ router_tcp_mtu_probing | default(1) }} > /proc/sys/net/ipv4/tcp_mtu_probing
  [ -e /proc/sys/net/ipv4/tcp_slow_start_after_idle ] && echo {{ router_tcp_slow_start_after_idle | default(0) }} > /proc/sys/net/ipv4/tcp_slow_start_after_idle
  [ -e /proc/sys/net/ipv4/tcp_window_scaling ] && echo {{ router_tcp_window_scaling | default(1) }} > /proc/sys/net/ipv4/tcp_window_scaling
  [ -e /proc/sys/net/ipv4/tcp_sack ] && echo {{ router_tcp_sack | default(1) }} > /proc/sys/net/ipv4/tcp_sack
  [ -e /proc/sys/net/ipv4/tcp_timestamps ] && echo {{ router_tcp_timestamps | default(1) }} > /proc/sys/net/ipv4/tcp_timestamps
fi

# The stable router path uses iptables REDIRECT into a local sing-box inbound.
# Keep the old TUN path fully inert if it was left behind by a previous deploy.
ip link delete "$IFACE" 2>/dev/null || true
for RPF_IF in all default br0; do
  [ -e "/proc/sys/net/ipv4/conf/$RPF_IF/rp_filter" ] && echo 0 > "/proc/sys/net/ipv4/conf/$RPF_IF/rp_filter"
done

# 1. ipset (match type: net, IPv4 only for now)
# STEALTH_DOMAINS is populated by dnsmasq ipset= rules and persisted as single
# resolved IPv4 addresses. Keep it hash:ip; hash:net makes ipset create fail
# against the restored set and prevents REDIRECT rules from being installed.
ipset create "$IPSET" hash:ip family inet -exist
ipset create "$STATIC_IPSET" hash:net family inet -exist

# 2. mangle cleanup: remove the previous TUN/policy-routing hooks.
iptables -t mangle -D PREROUTING -m set --match-set "$IPSET" dst -j MARK --set-mark "$MARK" 2>/dev/null || true
iptables -t mangle -D PREROUTING -i br0 -m set --match-set "$IPSET" dst -j MARK --set-mark "$MARK" 2>/dev/null || true
iptables -t mangle -D PREROUTING -i br0 -m set --match-set "$STATIC_IPSET" dst -j MARK --set-mark "$MARK" 2>/dev/null || true
iptables -t mangle -D OUTPUT -m set --match-set "$IPSET" dst -j MARK --set-mark "$MARK" 2>/dev/null || true
iptables -t mangle -D OUTPUT -m set --match-set "$STATIC_IPSET" dst -j MARK --set-mark "$MARK" 2>/dev/null || true

# Remove stale policy rule/table from the TUN implementation.
while ip rule del fwmark "$MARK" table "$TABLE" 2>/dev/null; do :; done
ip route flush table "$TABLE" 2>/dev/null || true

# 3. nat: Channel A owns LAN TCP by redirecting selected destinations into
# sing-box. This avoids Merlin TUN/TUNSETIFF races.
iptables -t nat -D PREROUTING -i br0 -p tcp -m set --match-set "$IPSET" dst -j REDIRECT --to-ports "$REDIRECT_PORT" 2>/dev/null || true
iptables -t nat -D PREROUTING -i br0 -p tcp -m set --match-set "$STATIC_IPSET" dst -j REDIRECT --to-ports "$REDIRECT_PORT" 2>/dev/null || true
iptables -t nat -A PREROUTING -i br0 -p tcp -m set --match-set "$IPSET" dst -j REDIRECT --to-ports "$REDIRECT_PORT"
iptables -t nat -A PREROUTING -i br0 -p tcp -m set --match-set "$STATIC_IPSET" dst -j REDIRECT --to-ports "$REDIRECT_PORT"

# 4. filter: force QUIC/HTTP3 fallback to TCP for Channel A.
# VLESS+Reality TCP is the stable path. Silently dropping UDP/443 avoids the
# local ICMP port-unreachable signature created by REJECT.
iptables -D FORWARD -i br0 -p udp --dport 443 -m set --match-set "$IPSET" dst -j REJECT --reject-with icmp-port-unreachable 2>/dev/null || true
iptables -D FORWARD -i br0 -p udp --dport 443 -m set --match-set "$STATIC_IPSET" dst -j REJECT --reject-with icmp-port-unreachable 2>/dev/null || true
iptables -D FORWARD -i br0 -p udp --dport 443 -m set --match-set "$IPSET" dst -j DROP 2>/dev/null || true
iptables -D FORWARD -i br0 -p udp --dport 443 -m set --match-set "$STATIC_IPSET" dst -j DROP 2>/dev/null || true
iptables -I FORWARD 1 -i br0 -p udp --dport 443 -m set --match-set "$STATIC_IPSET" dst -j DROP
iptables -I FORWARD 1 -i br0 -p udp --dport 443 -m set --match-set "$IPSET" dst -j DROP

# 5. input: allow remote mobile clients to reach the router-side Reality
# ingress. The inbound itself authenticates with Reality private key, short_id,
# UUID and VLESS flow; this rule only opens the TCP listener.
iptables -D INPUT -p tcp --dport "$HOME_REALITY_PORT" --syn -m connlimit --connlimit-above 30 -j DROP 2>/dev/null || true
iptables -D INPUT -p tcp --dport "$HOME_REALITY_PORT" --syn -m connlimit --connlimit-above 100 -j DROP 2>/dev/null || true
iptables -D INPUT -p tcp --dport "$HOME_REALITY_PORT" --syn -m connlimit --connlimit-above 300 -j DROP 2>/dev/null || true
iptables -D INPUT -p tcp --dport "$HOME_REALITY_PORT" --syn -m connlimit --connlimit-above 500 -j DROP 2>/dev/null || true
iptables -D INPUT -p tcp --dport "$HOME_REALITY_PORT" --syn -m connlimit --connlimit-above "$HOME_REALITY_CONNLIMIT_ABOVE" -j DROP 2>/dev/null || true
iptables -D INPUT -p tcp --dport "$HOME_REALITY_PORT" -j ACCEPT 2>/dev/null || true
iptables -D INPUT -p tcp --dport "$HOME_REALITY_PORT" -m comment --comment "mobile-reality-ingress" -j ACCEPT 2>/dev/null || true

# Clamp the outer mobile -> home TCP MSS before local delivery to sing-box.
# This avoids LTE PMTUD blackholes on the ingress leg without slowing ordinary
# home LAN traffic.
for OLD_MSS in 1280 1360 1380 1400 "$HOME_REALITY_MSS"; do
  iptables -t mangle -D PREROUTING -p tcp --dport "$HOME_REALITY_PORT" --tcp-flags SYN,RST SYN -j TCPMSS --set-mss "$OLD_MSS" 2>/dev/null || true
  iptables -t mangle -D OUTPUT -p tcp --sport "$HOME_REALITY_PORT" --tcp-flags SYN,RST SYN -j TCPMSS --set-mss "$OLD_MSS" 2>/dev/null || true
done
iptables -t mangle -I PREROUTING 1 -p tcp --dport "$HOME_REALITY_PORT" --tcp-flags SYN,RST SYN -j TCPMSS --set-mss "$HOME_REALITY_MSS" 2>/dev/null \
  || logger -t stealth-route-init "TCPMSS unavailable; mobile Reality ingress SYN has no MSS clamp"
iptables -t mangle -I OUTPUT 1 -p tcp --sport "$HOME_REALITY_PORT" --tcp-flags SYN,RST SYN -j TCPMSS --set-mss "$HOME_REALITY_MSS" 2>/dev/null \
  || logger -t stealth-route-init "TCPMSS unavailable; mobile Reality ingress SYN-ACK has no MSS clamp"

# Some Merlin builds lack the connlimit match. Keep rate-limiting opportunistic
# so the ingress ACCEPT is still installed on those kernels.
iptables -I INPUT 1 -p tcp --dport "$HOME_REALITY_PORT" --syn -m connlimit --connlimit-above "$HOME_REALITY_CONNLIMIT_ABOVE" -j DROP 2>/dev/null \
  || logger -t stealth-route-init "connlimit unavailable; mobile Reality ingress has no kernel connlimit"
iptables -I INPUT 2 -p tcp --dport "$HOME_REALITY_PORT" -j ACCEPT
iptables -A INPUT -p tcp --dport "$HOME_REALITY_PORT" -m comment --comment "mobile-reality-ingress" -j ACCEPT 2>/dev/null \
  || logger -t stealth-route-init "comment match unavailable; mobile Reality ingress counter is unnamed"

if [ "$CHANNEL_B_HOME_ENABLED" = "1" ]; then
  iptables -D INPUT -p tcp --dport "$CHANNEL_B_HOME_PORT" --syn -m connlimit --connlimit-above 30 -j DROP 2>/dev/null || true
  iptables -D INPUT -p tcp --dport "$CHANNEL_B_HOME_PORT" --syn -m connlimit --connlimit-above 100 -j DROP 2>/dev/null || true
  iptables -D INPUT -p tcp --dport "$CHANNEL_B_HOME_PORT" --syn -m connlimit --connlimit-above 300 -j DROP 2>/dev/null || true
  iptables -D INPUT -p tcp --dport "$CHANNEL_B_HOME_PORT" --syn -m connlimit --connlimit-above 500 -j DROP 2>/dev/null || true
  iptables -D INPUT -p tcp --dport "$CHANNEL_B_HOME_PORT" --syn -m connlimit --connlimit-above "$CHANNEL_B_HOME_CONNLIMIT_ABOVE" -j DROP 2>/dev/null || true
  iptables -D INPUT -p tcp --dport "$CHANNEL_B_HOME_PORT" -j ACCEPT 2>/dev/null || true
  iptables -D INPUT -p tcp --dport "$CHANNEL_B_HOME_PORT" -m comment --comment "mobile-reality-channel-b-ingress" -j ACCEPT 2>/dev/null || true

  for OLD_MSS in 1280 1360 1380 1400 "$CHANNEL_B_HOME_MSS"; do
    iptables -t mangle -D PREROUTING -p tcp --dport "$CHANNEL_B_HOME_PORT" --tcp-flags SYN,RST SYN -j TCPMSS --set-mss "$OLD_MSS" 2>/dev/null || true
    iptables -t mangle -D OUTPUT -p tcp --sport "$CHANNEL_B_HOME_PORT" --tcp-flags SYN,RST SYN -j TCPMSS --set-mss "$OLD_MSS" 2>/dev/null || true
  done
  iptables -t mangle -I PREROUTING 1 -p tcp --dport "$CHANNEL_B_HOME_PORT" --tcp-flags SYN,RST SYN -j TCPMSS --set-mss "$CHANNEL_B_HOME_MSS" 2>/dev/null \
    || logger -t stealth-route-init "TCPMSS unavailable; Channel B home ingress SYN has no MSS clamp"
  iptables -t mangle -I OUTPUT 1 -p tcp --sport "$CHANNEL_B_HOME_PORT" --tcp-flags SYN,RST SYN -j TCPMSS --set-mss "$CHANNEL_B_HOME_MSS" 2>/dev/null \
    || logger -t stealth-route-init "TCPMSS unavailable; Channel B home ingress SYN-ACK has no MSS clamp"

  iptables -I INPUT 1 -p tcp --dport "$CHANNEL_B_HOME_PORT" --syn -m connlimit --connlimit-above "$CHANNEL_B_HOME_CONNLIMIT_ABOVE" -j DROP 2>/dev/null \
    || logger -t stealth-route-init "connlimit unavailable; Channel B home ingress has no kernel connlimit"
  iptables -I INPUT 2 -p tcp --dport "$CHANNEL_B_HOME_PORT" -j ACCEPT
  iptables -A INPUT -p tcp --dport "$CHANNEL_B_HOME_PORT" -m comment --comment "mobile-reality-channel-b-ingress" -j ACCEPT 2>/dev/null \
    || logger -t stealth-route-init "comment match unavailable; Channel B home ingress counter is unnamed"
fi

echo "stealth-route-init: OK ($IPSET -> REDIRECT tcp/$REDIRECT_PORT, channel_b_home=$CHANNEL_B_HOME_ENABLED, vps=$VPS_IP via normal WAN)"
