#!/bin/sh
# Idempotent setup of channel B routing on Merlin router.
# Safe to re-run from firewall-start on every reconnect.

set -e

IPSET={{ stealth_ipset_name }}
STATIC_IPSET={{ stealth_static_source_ipset | default('VPN_STATIC_NETS') }}
MARK={{ stealth_fwmark }}
TABLE={{ stealth_route_table }}
IFACE={{ singbox_tun_name }}
REDIRECT_PORT={{ singbox_redirect_port }}
VPS_IP={{ vps_ssh_host }}
WAN_IF={{ wan_if }}
WAN_GW={{ wan_gw }}

{{ singbox_init_path }} start >/dev/null 2>&1 || true

# The stable router path uses iptables REDIRECT into a local sing-box inbound.
# Keep the old TUN path fully inert if it was left behind by a previous deploy.
ip link delete "$IFACE" 2>/dev/null || true
for RPF_IF in all default br0; do
  [ -e "/proc/sys/net/ipv4/conf/$RPF_IF/rp_filter" ] && echo 0 > "/proc/sys/net/ipv4/conf/$RPF_IF/rp_filter"
done

# 1. ipset (match type: net, IPv4 only for now)
ipset create "$IPSET" hash:net family inet -exist
ipset create "$STATIC_IPSET" hash:net family inet -exist

# 2. mangle cleanup: remove the previous TUN/policy-routing Channel B hooks.
# Clean up the earlier broad PREROUTING hook so remote wgs1 clients do not
# accidentally use Channel B; they stay on the old WGC1 reserve channel.
iptables -t mangle -D PREROUTING -m set --match-set "$IPSET" dst -j MARK --set-mark "$MARK" 2>/dev/null || true
iptables -t mangle -D PREROUTING -i wgs1 -m set --match-set "$IPSET" dst -j MARK --set-mark "$MARK" 2>/dev/null || true
iptables -t mangle -D PREROUTING -i br0 -m set --match-set "$IPSET" dst -j MARK --set-mark "$MARK" 2>/dev/null || true
iptables -t mangle -D PREROUTING -i br0 -m set --match-set "$STATIC_IPSET" dst -j MARK --set-mark "$MARK" 2>/dev/null || true
iptables -t mangle -D OUTPUT -m set --match-set "$IPSET" dst -j MARK --set-mark "$MARK" 2>/dev/null || true
iptables -t mangle -D OUTPUT -m set --match-set "$STATIC_IPSET" dst -j MARK --set-mark "$MARK" 2>/dev/null || true

# Remove stale policy rule/table from the TUN implementation.
while ip rule del fwmark "$MARK" table "$TABLE" 2>/dev/null; do :; done
ip route flush table "$TABLE" 2>/dev/null || true

# 3. nat: Channel B owns LAN TCP by redirecting selected destinations into
# sing-box. This avoids Merlin TUN/TUNSETIFF races and leaves remote wgs1
# clients on the old WGC1 reserve channel.
iptables -t nat -D PREROUTING -i br0 -p tcp -m set --match-set "$IPSET" dst -j REDIRECT --to-ports "$REDIRECT_PORT" 2>/dev/null || true
iptables -t nat -D PREROUTING -i br0 -p tcp -m set --match-set "$STATIC_IPSET" dst -j REDIRECT --to-ports "$REDIRECT_PORT" 2>/dev/null || true
iptables -t nat -A PREROUTING -i br0 -p tcp -m set --match-set "$IPSET" dst -j REDIRECT --to-ports "$REDIRECT_PORT"
iptables -t nat -A PREROUTING -i br0 -p tcp -m set --match-set "$STATIC_IPSET" dst -j REDIRECT --to-ports "$REDIRECT_PORT"

# 4. filter: force QUIC/HTTP3 fallback to TCP for Channel B.
# VLESS+Reality TCP is the stable path; rejecting UDP/443 makes iOS/YouTube
# retry over ordinary TLS instead of black-holing video traffic through XUDP.
iptables -D FORWARD -i br0 -p udp --dport 443 -m set --match-set "$IPSET" dst -j REJECT --reject-with icmp-port-unreachable 2>/dev/null || true
iptables -D FORWARD -i br0 -p udp --dport 443 -m set --match-set "$STATIC_IPSET" dst -j REJECT --reject-with icmp-port-unreachable 2>/dev/null || true
iptables -I FORWARD 1 -i br0 -p udp --dport 443 -m set --match-set "$STATIC_IPSET" dst -j REJECT --reject-with icmp-port-unreachable
iptables -I FORWARD 1 -i br0 -p udp --dport 443 -m set --match-set "$IPSET" dst -j REJECT --reject-with icmp-port-unreachable

echo "stealth-route-init: OK ($IPSET -> REDIRECT tcp/$REDIRECT_PORT, vps=$VPS_IP via normal WAN)"
