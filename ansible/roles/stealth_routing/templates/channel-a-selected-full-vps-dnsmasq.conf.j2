# Generated by Ansible. Channel A selected full-VPS DHCP/DNS policy.
{% if (channel_a_selected_full_vps_enabled | default(false) | bool) and ((channel_a_selected_full_vps_lan_clients | default([])) | length > 0) %}
{% for client in channel_a_selected_full_vps_lan_clients | default([]) %}
dhcp-host={{ client.mac }},set:{{ channel_a_selected_full_vps_dnsmasq_tag | default('ghostroute-channel-a-full-vps') }},{{ client.ip }},{{ client.hostname | default(client.name) }}
{% endfor %}
dhcp-option=tag:{{ channel_a_selected_full_vps_dnsmasq_tag | default('ghostroute-channel-a-full-vps') }},option:dns-server,{{ (channel_a_selected_full_vps_dns_servers | default([])) | join(',') }}
{% endif %}
