{
    servers {
        protocols h1
        listener_wrappers {
            layer4 {
                @reality tls sni {{ reality_server_names[0] }}
                route @reality {
                    proxy 127.0.0.1:8443
                }
            }
            tls
        }
    }
}

http://{{ system_caddy_site_host }} {
    redir https://{{ system_caddy_site_host }}{uri} 301
}

{{ system_caddy_site_host }} {
    tls {{ system_caddy_cert_file }} {{ system_caddy_key_file }} {
        client_auth {
            mode require_and_verify
            trusted_ca_cert_file {{ system_caddy_client_ca_file }}
        }
    }

    encode gzip zstd

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "no-referrer"
        Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
    }

    reverse_proxy {{ system_caddy_site_upstream }} {
        header_up Host {http.request.host}
        header_up X-Forwarded-Host {http.request.host}
        header_up X-Forwarded-Proto https
        transport http {
            versions 1.1
        }
    }
}
