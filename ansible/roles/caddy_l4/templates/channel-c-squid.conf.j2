{% if channel_c_naive_backend | default('stunnel_squid') == 'squid_tls' %}
https_port 127.0.0.1:{{ channel_c_naive_squid_local_port | default(18889) }} tls-cert=/etc/squid/channel-c-tls.crt tls-key=/etc/squid/channel-c-tls.key
{% else %}
http_port 127.0.0.1:{{ channel_c_naive_squid_local_port | default(18889) }}
{% endif %}

auth_param basic program /usr/lib/squid/basic_ncsa_auth /etc/squid/channel-c.htpasswd
auth_param basic realm channel-c
acl channel_c_auth proxy_auth REQUIRED

acl SSL_ports port 80
acl SSL_ports port 443
acl SSL_ports port 2052
acl SSL_ports port 2053
acl SSL_ports port 2082
acl SSL_ports port 2083
acl SSL_ports port 2086
acl SSL_ports port 2087
acl SSL_ports port 2095
acl SSL_ports port 2096
acl SSL_ports port 5222
acl SSL_ports port 5223
acl SSL_ports port 5228
acl SSL_ports port 5229
acl SSL_ports port 5230
acl SSL_ports port 853
acl SSL_ports port 993
acl SSL_ports port 995
acl SSL_ports port 4070
acl Safe_ports port 80
acl Safe_ports port 443
acl Safe_ports port 2052
acl Safe_ports port 2053
acl Safe_ports port 2082
acl Safe_ports port 2083
acl Safe_ports port 2086
acl Safe_ports port 2087
acl Safe_ports port 2095
acl Safe_ports port 2096
acl Safe_ports port 5222
acl Safe_ports port 5223
acl Safe_ports port 5228
acl Safe_ports port 5229
acl Safe_ports port 5230
acl Safe_ports port 853
acl Safe_ports port 993
acl Safe_ports port 995
acl Safe_ports port 4070
acl CONNECT method CONNECT

http_access deny !Safe_ports
http_access deny CONNECT !SSL_ports
http_access allow channel_c_auth
http_access deny all

via off
forwarded_for delete
request_header_access X-Forwarded-For deny all
request_header_access Via deny all
reply_header_access Via deny all

connect_timeout {{ channel_c_naive_squid_connect_timeout | default('8 seconds') }}
happy_eyeballs_connect_timeout {{ channel_c_naive_squid_happy_eyeballs_connect_timeout | default('250 milliseconds') }}
happy_eyeballs_connect_gap {{ channel_c_naive_squid_happy_eyeballs_connect_gap | default('50 milliseconds') }}
{% if channel_c_naive_squid_ipv4_only | default(true) | bool %}
tcp_outgoing_address {{ channel_c_naive_squid_outgoing_address | default('', true) or ansible_facts.default_ipv4.address }}
{% endif %}

access_log /var/log/squid/channel-c-access.log
cache_log /var/log/squid/channel-c-cache.log
pid_filename /run/squid/channel-c.pid
cache deny all
coredump_dir /var/spool/squid
