{
  "log": {
    "level": "info",
    "output": "{{ singbox_log_path }}",
    "timestamp": true
  },
  "inbounds": [
    {
      "type": "redirect",
      "tag": "redirect-in",
      "listen": "0.0.0.0",
      "listen_port": {{ singbox_redirect_port }},
      "sniff": true
    },
    {
      "type": "socks",
      "tag": "dnscrypt-socks-in",
      "listen": "127.0.0.1",
      "listen_port": {{ singbox_dnscrypt_socks_port }},
      "sniff": false
    }{% if home_reality_enabled | default(false) | bool %},
    {
      "type": "vless",
      "tag": "home-reality-in",
      "listen": "{{ home_reality_listen }}",
      "listen_port": {{ home_reality_port }},
      "users": [
{% for client in clients | rejectattr('name', 'equalto', 'router') | list %}
        {
          "name": "{{ client.name }}",
          "uuid": "{{ client.uuid }}",
          "flow": "xtls-rprx-vision"
        }{{ "," if not loop.last else "" }}
{% endfor %}
      ],
      "tls": {
        "enabled": true,
        "server_name": "{{ home_reality_server_names[0] }}",
        "reality": {
          "enabled": true,
          "handshake": {
            "server": "{{ home_reality_dest.split(':')[0] }}",
            "server_port": {{ home_reality_dest.split(':')[1] | int }}
          },
          "private_key": "{{ home_reality_server_private_key }}",
          "short_id": [
{% for client in clients | rejectattr('name', 'equalto', 'router') | list %}
            "{{ client.short_id }}"{{ "," if not loop.last else "" }}
{% endfor %}
          ]
        }
      }
    }
{% endif %}
  ],
  "outbounds": [
    {
      "type": "vless",
      "tag": "reality-out",
      "server": "{{ vps_ssh_host }}",
      "server_port": 443,
      "uuid": "{{ (clients | selectattr('name','equalto','router') | list | first).uuid }}",
      "flow": "xtls-rprx-vision",
      "packet_encoding": "xudp",
      "tcp_fast_open": false,
      "tcp_keep_alive_interval": "30s",
      "connect_timeout": "10s",
      "multiplex": {
        "enabled": false
      },
      "tls": {
        "enabled": true,
        "server_name": "{{ reality_server_names[0] }}",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "reality": {
          "enabled": true,
          "public_key": "{{ reality_server_public_key }}",
          "short_id": "{{ (clients | selectattr('name','equalto','router') | list | first).short_id }}"
        }
      }
    },
    { "type": "direct", "tag": "direct-out" }
  ],
  "route": {
    "rules": [
      { "inbound": "redirect-in", "outbound": "reality-out" },
      { "inbound": "dnscrypt-socks-in", "outbound": "reality-out" }{% if home_reality_enabled | default(false) | bool %},
      { "inbound": "home-reality-in", "outbound": "reality-out" }
{% endif %}
    ],
    "final": "direct-out"
  }
}
