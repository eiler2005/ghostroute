{
  "log": {
    "level": "info",
    "output": "{{ singbox_log_path }}",
    "timestamp": true
  },
  "inbounds": [
    {
      "type": "redirect",
      "tag": "redirect-in",
      "listen": "0.0.0.0",
      "listen_port": {{ singbox_redirect_port }},
      "sniff": true
    },
    {
      "type": "socks",
      "tag": "dnscrypt-socks-in",
      "listen": "127.0.0.1",
      "listen_port": {{ singbox_dnscrypt_socks_port }},
      "sniff": false
    }{% if home_reality_enabled | default(false) | bool %},
    {
      "type": "vless",
      "tag": "reality-in",
      "listen": "{{ home_reality_listen }}",
      "listen_port": {{ home_reality_ingress_port }},
      "users": [
{% for client in home_clients %}
        {
          "name": "{{ client.name }}",
          "uuid": "{{ client.uuid }}",
          "flow": "xtls-rprx-vision"
        }{{ "," if not loop.last else "" }}
{% endfor %}
      ],
      "tls": {
        "enabled": true,
        "server_name": "{{ home_reality_server_names[0] }}",
        "reality": {
          "enabled": true,
          "handshake": {
            "server": "{{ home_reality_dest_host }}",
            "server_port": {{ home_reality_dest_port }}
          },
          "private_key": "{{ home_reality_server_private_key }}",
          "short_id": {{ home_reality_server_short_ids | to_json }}
        }
      }
    },
    {
      "type": "socks",
      "tag": "channel-b-relay-socks",
      "listen": "127.0.0.1",
      "listen_port": {{ channel_b_home_upstream_socks_port }},
      "sniff": false
    }
{% endif %}
  ],
  "outbounds": [
    {
      "type": "vless",
      "tag": "reality-out",
      "server": "{{ vps_ssh_host }}",
      "server_port": 443,
      "uuid": "{{ (clients | selectattr('name','equalto','router') | list | first).uuid }}",
      "flow": "xtls-rprx-vision",
      "packet_encoding": "xudp",
      "tcp_fast_open": false,
      "tcp_keep_alive_interval": "30s",
      "connect_timeout": "10s",
      "multiplex": {
        "enabled": false
      },
      "tls": {
        "enabled": true,
        "server_name": "{{ reality_server_names[0] }}",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "reality": {
          "enabled": true,
          "public_key": "{{ reality_server_public_key }}",
          "short_id": "{{ (clients | selectattr('name','equalto','router') | list | first).short_id }}"
        }
      }
    },
    { "type": "direct", "tag": "direct-out" }
  ],
  "route": {
    "rule_set": [
      {
        "type": "local",
        "tag": "stealth-domains",
        "format": "source",
        "path": "/opt/etc/sing-box/rule-sets/stealth-domains.json"
      },
      {
        "type": "local",
        "tag": "stealth-static",
        "format": "source",
        "path": "/opt/etc/sing-box/rule-sets/stealth-static.json"
      }
    ],
    "rules": [
    { "inbound": "redirect-in", "outbound": "reality-out" },
      { "inbound": "dnscrypt-socks-in", "outbound": "reality-out" }{% if home_reality_enabled | default(false) | bool %},
      {
        "inbound": "reality-in",
        "port": [53, 853],
        "outbound": "reality-out"
      },
      {
        "inbound": "reality-in",
        "domain_suffix": [
          "vtb.ru",
          "app-analytics-services-att.com",
          "app-measurement.com",
          "firebaseinstallations.googleapis.com"
        ],
        "outbound": "direct-out"
      },
      { "inbound": "reality-in", "rule_set": ["stealth-domains", "stealth-static"], "outbound": "reality-out" },
      { "inbound": "reality-in", "outbound": "direct-out" },
      {
        "inbound": "channel-b-relay-socks",
        "port": [53, 853],
        "outbound": "reality-out"
      },
      {
        "inbound": "channel-b-relay-socks",
        "domain_suffix": [
          "vtb.ru",
          "app-analytics-services-att.com",
          "app-measurement.com",
          "firebaseinstallations.googleapis.com"
        ],
        "outbound": "direct-out"
      },
      { "inbound": "channel-b-relay-socks", "rule_set": ["stealth-domains", "stealth-static"], "outbound": "reality-out" },
      { "inbound": "channel-b-relay-socks", "outbound": "direct-out" }
{% endif %}
    ],
    "final": "direct-out"
  }
}
