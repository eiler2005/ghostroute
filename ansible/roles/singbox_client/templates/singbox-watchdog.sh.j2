#!/bin/sh
# Restart sing-box only after repeated local listener failures.

PORTS="{{ singbox_redirect_port }} {{ singbox_dnscrypt_socks_port }} {{ router_vps_dns_forward_port }}{% if home_reality_enabled | default(false) | bool %} {{ home_reality_ingress_port }}{% endif %}"
INIT={{ singbox_init_path }}
STATE_FILE=/opt/tmp/singbox-watchdog.state
FAIL_LIMIT=1

mkdir -p "$(dirname "$STATE_FILE")"

listener_present() {
  port="$1"

  if netstat -nl 2>/dev/null | grep "[.:]${port}[[:space:]]" >/dev/null 2>&1; then
    return 0
  fi

  if command -v nc >/dev/null 2>&1; then
    nc -z -w 2 127.0.0.1 "$port" >/dev/null 2>&1
    return $?
  fi
  if [ -x /opt/bin/nc ]; then
    /opt/bin/nc -z -w 2 127.0.0.1 "$port" >/dev/null 2>&1
    return $?
  fi

  return 1
}

ALL_OK=1
for PORT in $PORTS; do
  if ! listener_present "$PORT"; then
    ALL_OK=0
  fi
done

if [ "$ALL_OK" = "1" ]; then
  echo 0 > "$STATE_FILE"
  exit 0
fi

FAILS=0
[ -f "$STATE_FILE" ] && FAILS="$(cat "$STATE_FILE" 2>/dev/null || echo 0)"
case "$FAILS" in
  ''|*[!0-9]*) FAILS=0 ;;
esac
FAILS=$((FAILS + 1))
echo "$FAILS" > "$STATE_FILE"

if [ "$FAILS" -ge "$FAIL_LIMIT" ]; then
  logger -t singbox-watchdog "sing-box listener probe failed for ports $PORTS ($FAILS checks); restarting"
  "$INIT" restart >/dev/null 2>&1 || logger -t singbox-watchdog "restart command failed"
  echo 0 > "$STATE_FILE"
fi
