#!/bin/sh

ENABLED=yes
PROCS=xray
BIN="{{ channel_b_home_router_xray_bin_path }}"
CONFIG="{{ channel_b_home_router_xray_config_path }}"
LOG="{{ channel_b_home_router_xray_log_path }}"
PIDFILE=/opt/var/run/xray-channel-b-home.pid

pid_is_live() {
  pid="$1"
  [ -n "$pid" ] || return 1
  kill -0 "$pid" 2>/dev/null || return 1
  state="$(ps w 2>/dev/null | awk -v pid="$pid" '$1 == pid { print $4; exit }')"
  [ -n "$state" ] || return 1
  case "$state" in
    *Z*) return 1 ;;
  esac
  return 0
}

live_pidof() {
  for pid in $(pidof "$PROCS" 2>/dev/null); do
    if pid_is_live "$pid"; then
      echo "$pid"
      return 0
    fi
  done
  return 1
}

start() {
  [ "$ENABLED" = "yes" ] || return 0
  [ -x "$BIN" ] || return 1
  [ -f "$CONFIG" ] || return 1
  PID=""
  [ -f "$PIDFILE" ] && PID="$(cat "$PIDFILE" 2>/dev/null || true)"
  if pid_is_live "$PID"; then
    return 0
  fi
  [ -n "$PID" ] && rm -f "$PIDFILE"
  mkdir -p /opt/var/run "$(dirname "$LOG")"
  nohup "$BIN" run -config "$CONFIG" >> "$LOG" 2>&1 </dev/null &
  echo $! > "$PIDFILE"
}

stop() {
  if [ -f "$PIDFILE" ]; then
    kill "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null || true
    rm -f "$PIDFILE"
  fi
  killall -q xray 2>/dev/null || true
  for _ in 1 2 3 4 5; do
    live_pidof >/dev/null 2>&1 || break
    sleep 1
  done
}

restart() {
  stop
  sleep 1
  start
}

case "$1" in
  status)
    PID=""
    [ -f "$PIDFILE" ] && PID="$(cat "$PIDFILE" 2>/dev/null || true)"
    pid_is_live "$PID" && echo "running" || echo "stopped"
    ;;
  start|stop|restart)
    "$1"
    ;;
  enable|disable)
    ;;
  *)
    echo "Usage: $0 {start|stop|restart|enable|disable}"
    exit 1
    ;;
esac
