# ===== VPS =====
vps_ssh_host: "<vps_ip_or_dns_name>"
vps_ssh_user: "<vps_ssh_user>"

# Existing shared Caddy/OpenClaw site values. Keep real hostnames, cert paths
# and private admin paths in ansible-vault, not in group_vars or docs.
system_caddy_site_host: "openclaw.home.arpa"
system_caddy_site_upstream: "127.0.0.1:<existing_local_port>"
system_caddy_cert_file: "/etc/caddy/certs/openclaw-home-arpa-fullchain.pem"
system_caddy_key_file: "/etc/caddy/certs/openclaw-home-arpa-privkey.pem"
system_caddy_client_ca_file: "/etc/caddy/certs/<site>-access-ca.crt"

# ===== Mobile self-check (disabled by default) =====
# Phase 2 placeholder. Do not enable until a public HTTPS hostname and token are
# chosen for the manual iPhone Shortcut check-in flow.
vault_mobile_checkin_enabled: false
vault_mobile_checkin_public_host: ""
vault_mobile_checkin_token: ""

# ===== Selected-client B profiles =====
# Add the direct-mode Channel B hostname to the VPS public IP. Keep this name
# ordinary-looking; do not include vpn/proxy/xray/xhttp/naive.
vault_channel_b_xhttp_enabled: false
vault_channel_b_xhttp_public_host: "edge-api.example.com"
vault_channel_b_xhttp_local_port: 18081
vault_channel_b_xhttp_path: "/assets/<random-path>"
vault_channel_b_xhttp_clients:
  - name: "iphone-1"
    uuid: ""
    email: "iphone-1-xhttp@home.lan"
  - name: "macbook"
    uuid: ""
    email: "macbook-xhttp@home.lan"

# Channel B home-first relay mode: mobile clients connect to home router first,
# then router forwards upstream via local sing-box SOCKS -> Reality to VPS.
vault_channel_b_home_relay_enabled: false
vault_channel_b_home_ingress_port: "<home_channel_b_ingress_port>"
vault_channel_b_home_xhttp_host: "myhome.asuscomm.com"
vault_channel_b_home_xhttp_path: "/assets/<random-home-path>"
vault_channel_b_home_xhttp_mode: "packet-up"
vault_channel_b_home_upstream_socks_port: "<router_channel_b_socks_port>"
# Keep this separate from singbox_dnscrypt_socks_port to keep split-rules
# for dnscrypt and Channel B relay independent.
# Optional override. If omitted, channel_b_home_clients defaults to
# vault_channel_b_xhttp_clients.
# vault_channel_b_home_clients:
#   - name: "iphone-b-1"
#     uuid: ""

# Channel C1 home-first Naive mode: mobile clients connect to home router first
# using HTTPS/H2 CONNECT-like Naive traffic, then router applies the same
# managed split used by the other home-first lanes.
vault_channel_c_home_enabled: false
vault_channel_c_home_public_host: "myhome.asuscomm.com"
vault_channel_c_home_public_port: 443
vault_channel_c_home_ingress_port: "<home_channel_c_internal_ingress_port>"
vault_channel_c_home_connlimit_above: 300
vault_channel_c_home_mss: 1360
vault_channel_c_home_tls_cert_path: "/opt/etc/sing-box/channel-c-home-fullchain.pem"
vault_channel_c_home_tls_key_path: "/opt/etc/sing-box/channel-c-home-privkey.pem"
# Optional: set PEM content here to let Ansible install the real LE cert/key.
# Otherwise provision the files at the paths above before enabling C1.
vault_channel_c_home_tls_cert_pem: ""
vault_channel_c_home_tls_key_pem: ""
vault_channel_c_home_clients:
  - name: "iphone-1"
    username: ""
    password: ""
  - name: "macbook"
    username: ""
    password: ""

# ===== 3x-ui admin =====
xui_admin_username: "admin"
xui_admin_password: ""
xui_admin_web_path: ""
xui_admin_web_port: "<xui_admin_port>"
vault_xray_reality_listen_port: "<xray_reality_local_port>"

# ===== Router local/private ports =====
# Keep real runtime ports only in ansible-vault. Public docs and group_vars use
# these vault values instead of publishing production listener numbers.
vault_singbox_redirect_port: "<router_redirect_port>"
vault_singbox_dnscrypt_socks_port: "<router_socks_port>"
vault_dnscrypt_port: "<dnscrypt_port>"

# ===== Reality server =====
reality_dest: "gateway.icloud.com:443"
reality_server_names:
  - "gateway.icloud.com"
reality_server_private_key: ""
reality_server_public_key: ""
reality_short_ids:
  - ""

# ===== Home Reality ingress on ASUS =====
# Remote mobile clients dial this home DDNS/IP first. The router then uses the
# VPS Reality outbound above for managed egress.
vault_home_reality_public_host: "myhome.asuscomm.com"
vault_home_reality_ingress_port: "<home_reality_ingress_port>"
home_reality_dest_host: "gateway.icloud.com"
home_reality_dest_port: 443
home_reality_server_private_key: ""
home_reality_server_public_key: ""
home_reality_server_short_ids:
  - ""

# These are router-side mobile identities. They must be different from
# VPS-side clients[] and are the only mobile identities after migration.
home_clients:
  - name: "iphone-1"
    uuid: ""
    short_id: ""
  - name: "iphone-2"
    uuid: ""
    short_id: ""
  - name: "iphone-3"
    uuid: ""
    short_id: ""
  - name: "iphone-4"
    uuid: ""
    short_id: ""
  - name: "iphone-5"
    uuid: ""
    short_id: ""
  - name: "iphone-6"
    uuid: ""
    short_id: ""
  - name: "macbook"
    uuid: ""
    short_id: ""

# Emergency direct-VPS profiles. Import these as disabled/off profiles on
# mobile devices. They are only for rare home relay/router outages while the VPS
# is still healthy. Their short_id values must also exist in reality_short_ids.
emergency_clients:
  - name: "iphone-1"
    uuid: ""
    short_id: ""
    email: "iphone-1-emergency@home.lan"
  - name: "iphone-2"
    uuid: ""
    short_id: ""
    email: "iphone-2-emergency@home.lan"
  - name: "iphone-3"
    uuid: ""
    short_id: ""
    email: "iphone-3-emergency@home.lan"
  - name: "iphone-4"
    uuid: ""
    short_id: ""
    email: "iphone-4-emergency@home.lan"
  - name: "iphone-5"
    uuid: ""
    short_id: ""
    email: "iphone-5-emergency@home.lan"
  - name: "iphone-6"
    uuid: ""
    short_id: ""
    email: "iphone-6-emergency@home.lan"
  - name: "macbook"
    uuid: ""
    short_id: ""
    email: "macbook-emergency@home.lan"

# ===== Clients =====
# Primary VPS-side Reality identities. Keep only the router here; normal
# mobile identities live in home_clients[] and are relayed through the home
# router. Emergency direct-VPS identities live in emergency_clients[].
clients:
  - name: "router"
    uuid: ""
    short_id: ""
    email: "router@home.lan"

# ===== Router =====
router_ssh_host: "<router_lan_ip>"
router_ssh_user: "<router_ssh_user>"
