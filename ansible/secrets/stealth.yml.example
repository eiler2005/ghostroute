# ===== VPS =====
vps_ssh_host: "<vps_ip_or_dns_name>"
vps_ssh_user: "<vps_ssh_user>"

# Existing shared Caddy/OpenClaw site values. Keep real hostnames, cert paths
# and private admin paths in ansible-vault, not in group_vars or docs.
system_caddy_site_host: "<existing_caddy_site_host>"
system_caddy_site_upstream: "127.0.0.1:<existing_local_port>"
system_caddy_cert_file: "/etc/caddy/certs/<site>-fullchain.pem"
system_caddy_key_file: "/etc/caddy/certs/<site>-privkey.pem"
system_caddy_client_ca_file: "/etc/caddy/certs/<site>-access-ca.crt"

# ===== 3x-ui admin =====
xui_admin_username: "admin"
xui_admin_password: ""
xui_admin_web_path: ""
xui_admin_web_port: <xui-admin-port>

# ===== Reality server =====
reality_dest: "www.microsoft.com:443"
reality_server_names:
  - "www.microsoft.com"
reality_server_private_key: ""
reality_server_public_key: ""
reality_short_ids:
  - ""

# ===== Clients =====
clients:
  - name: "router"
    uuid: ""
    short_id: ""
    email: "router@home.lan"
  - name: "iphone-1"
    uuid: ""
    short_id: ""
    email: "iphone-1@home.lan"
  - name: "iphone-2"
    uuid: ""
    short_id: ""
    email: "iphone-2@home.lan"
  - name: "iphone-3"
    uuid: ""
    short_id: ""
    email: "iphone-3@home.lan"
  - name: "iphone-4"
    uuid: ""
    short_id: ""
    email: "iphone-4@home.lan"
  - name: "iphone-5"
    uuid: ""
    short_id: ""
    email: "iphone-5@home.lan"
  - name: "iphone-6"
    uuid: ""
    short_id: ""
    email: "iphone-6@home.lan"
  - name: "macbook"
    uuid: ""
    short_id: ""
    email: "macbook@home.lan"

# ===== Router =====
router_ssh_host: "<router_lan_ip>"
router_ssh_user: "<router_ssh_user>"
