#!/bin/bash

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
OUT_DIR="${PROJECT_ROOT}/ansible/out/clients"

usage() {
  cat >&2 <<'EOF'
Usage: ./scripts/client-profiles <generate|list|open|clean>

Commands:
  generate  Generate local VLESS .conf and QR .png files from ansible-vault.
  list      List generated local client artifacts.
  open      Open local qr-index.html when it exists.
  clean     Remove generated local client artifacts.
EOF
}

cmd="${1:-}"
case "$cmd" in
  generate)
    cd "${PROJECT_ROOT}/ansible"
    ansible-playbook playbooks/30-generate-client-profiles.yml
    ;;
  list)
    if [ -d "$OUT_DIR" ]; then
      find "$OUT_DIR" -maxdepth 1 -type f | sort
    else
      echo "No generated client directory: $OUT_DIR" >&2
      exit 1
    fi
    ;;
  open)
    index="${OUT_DIR}/qr-index.html"
    [ -f "$index" ] || {
      echo "Missing $index. Run: ./scripts/client-profiles generate" >&2
      exit 1
    }
    if command -v open >/dev/null 2>&1; then
      open "$index"
    elif command -v xdg-open >/dev/null 2>&1; then
      xdg-open "$index"
    else
      echo "$index"
    fi
    ;;
  clean)
    mkdir -p "$OUT_DIR"
    find "$OUT_DIR" -maxdepth 1 -type f ! -name '.gitkeep' -delete
    ;;
  -h|--help|help|"")
    usage
    [ -n "$cmd" ] || exit 1
    ;;
  *)
    usage
    exit 1
    ;;
esac
