  WGS1_CONNTRACK_TITLE="WIREGUARD SERVER PEERS (END-OF-PERIOD CONNECTION SNAPSHOT)"
  LAN_NOTE="Counts above are end-of-period conntrack entries, not cumulative bytes."
fi

