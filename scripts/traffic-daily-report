#!/bin/bash
# Period traffic report entrypoint.
#
# Channel A WireGuard counters were retired with the final decommission. The
# authoritative supported report is the current Reality-first snapshot from
# scripts/traffic-report.

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PERIOD_ARG="${1:-today}"

cat <<EOF
=== PERIOD REQUEST ===
Requested period:        ${PERIOD_ARG}
Status:                  historical period deltas for Channel A are retired

The current supported observability view is Reality-first and does not inspect
wgs1/wgc1. Running current snapshot now:

EOF

"${PROJECT_ROOT}/scripts/traffic-report"
