  month) REPORT_TITLE="MONTH TRAFFIC REPORT (${ACTUAL_START_DATE} .. ${END_DATE})" ;;
  *) REPORT_TITLE="DAILY TRAFFIC REPORT (${START_DATE})" ;;
esac

