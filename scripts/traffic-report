#!/bin/bash
# Reality-first traffic report from the router.
#
# This report intentionally does not inspect wgs1/wgc1. Channel A is
# decommissioned; managed traffic enters sing-box through local REDIRECT.
# Per-device Reality attribution comes from router-side mangle counters that
# observe managed REDIRECT flows before nat rewrites them.

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
. "${PROJECT_ROOT}/scripts/lib/router-health-common.sh"
. "${PROJECT_ROOT}/scripts/lib/device-labels.sh"
router_health_load_env

REPORT_REDACT_NAMES="${REPORT_REDACT_NAMES:-1}"
DEVICE_METADATA_FILE="${DEVICE_METADATA_FILE:-$(device_labels_default_metadata_file)}"

TMPDIR="$(mktemp -d)"
trap 'rm -rf "$TMPDIR"' EXIT

STATE_FILE="$TMPDIR/state.txt"
CURRENT_COUNTERS="$TMPDIR/current-counters.tsv"
HISTORY_COUNTERS="$TMPDIR/history-counters.tsv"
LAN_BYTES_HISTORY="$TMPDIR/lan-device-counters.tsv"
LAN_BYTES_CURRENT="$TMPDIR/lan-device-counters-current.tsv"
LAN_BYTES_BASE="$TMPDIR/lan-device-counters-base.tsv"
LAN_BYTES_PARSED="$TMPDIR/lan-device-bytes.txt"
LAN_ALIAS_MAP="$TMPDIR/lan-alias-map.txt"
DEVICE_METADATA_MAP="$TMPDIR/device-metadata-map.txt"
DEVICE_MIX_TOTALS="$TMPDIR/device-mix-totals.txt"
DEVICE_TOP_REALITY="$TMPDIR/device-top-reality.txt"
DEVICE_TOP_WAN="$TMPDIR/device-top-wan.txt"
MOBILE_LOG="$TMPDIR/mobile-reality.log"
MOBILE_TOTALS="$TMPDIR/mobile-reality-totals.txt"
MOBILE_CLIENTS="$TMPDIR/mobile-reality-clients.txt"
MOBILE_DESTS="$TMPDIR/mobile-reality-dests.txt"
MOBILE_ALIAS_MAP="$TMPDIR/mobile-alias-map.txt"
MOBILE_BYTES_HISTORY="$TMPDIR/mobile-reality-counters.tsv"
MOBILE_BYTES_CURRENT="$TMPDIR/mobile-reality-counters-current.tsv"
MOBILE_BYTES_BASE="$TMPDIR/mobile-reality-counters-base.tsv"
MOBILE_BYTES_PARSED="$TMPDIR/mobile-reality-bytes.txt"
MOBILE_BYTES_TOTALS="$TMPDIR/mobile-reality-byte-totals.txt"
CURRENT_TAILSCALE="$TMPDIR/current-tailscale.json"
BASE_TAILSCALE="$TMPDIR/base-tailscale.json"
TAILSCALE_PARSED="$TMPDIR/tailscale.txt"
TAILSCALE_TOP_SUMMARY="$TMPDIR/tailscale-top-summary.txt"

human_gib() {
  awk -v bytes="${1:-0}" 'BEGIN { printf "%.2f GiB", bytes / 1024 / 1024 / 1024; }'
}

human_bytes() {
  awk -v bytes="${1:-0}" '
    BEGIN {
      if (bytes >= 1024 * 1024 * 1024) printf "%.2f GiB", bytes / 1024 / 1024 / 1024;
      else if (bytes >= 1024 * 1024) printf "%.1f MiB", bytes / 1024 / 1024;
      else if (bytes >= 1024) printf "%.1f KiB", bytes / 1024;
      else printf "%d B", bytes;
    }'
}

human_pct() {
  awk -v part="${1:-0}" -v total="${2:-0}" '
    BEGIN {
      if (total <= 0) printf "n/a";
      else printf "%.1f%%", (part / total) * 100;
    }'
}

delta_or_current() {
  local current="${1:-0}"
  local base="${2:-0}"
  if [ "$current" -ge "$base" ]; then
    echo $((current - base))
  else
    echo "$current"
  fi
}

apply_device_metadata() {
  [ -s "$DEVICE_METADATA_MAP" ] || return 0
  [ -s "$LAN_BYTES_PARSED" ] || return 0

  awk -F'|' '
    BEGIN { OFS="|" }
    NR == FNR {
      label[$1] = $2
      next
    }
    {
      if (($1 in label) && label[$1] != "") $2 = label[$1]
      print
    }
  ' "$DEVICE_METADATA_MAP" "$LAN_BYTES_PARSED" > "$LAN_BYTES_PARSED.metadata" && mv "$LAN_BYTES_PARSED.metadata" "$LAN_BYTES_PARSED"
}

redact_report_tables() {
  [ "$REPORT_REDACT_NAMES" = "1" ] || return 0
  [ -s "$LAN_BYTES_PARSED" ] || return 0

  awk -F'|' '$1 != "" { print $1 }' "$LAN_BYTES_PARSED" | sort -u | awk '
    NF { printf "%s|lan-host-%02d\n", $1, ++idx }
  ' > "$LAN_ALIAS_MAP"

  awk -F'|' '
    BEGIN { OFS="|" }
    NR == FNR {
      alias[$1] = $2
      next
    }
    {
      if ($1 in alias) $2 = alias[$1]
      print
    }' "$LAN_ALIAS_MAP" "$LAN_BYTES_PARSED" > "$LAN_BYTES_PARSED.redacted" && mv "$LAN_BYTES_PARSED.redacted" "$LAN_BYTES_PARSED"
}

router_ssh 'sh -s' <<'REMOTE' > "$STATE_FILE"
set -e
STATE_DIR="/jffs/addons/router_configuration/traffic"
[ -x /opt/bin/opkg ] && STATE_DIR="/opt/var/log/router_configuration"
mkdir -p "$STATE_DIR" "$STATE_DIR/tailscale"

printf "STATE_DIR=%s\n" "$STATE_DIR"
printf "WAN_IP=%s\n" "$(nvram get wan0_ipaddr 2>/dev/null || true)"
printf "TODAY=%s\n" "$(date +%Y-%m-%d)"

for iface in wan0 br0 eth6 eth7; do
  if [ -d "/sys/class/net/$iface" ]; then
    rx=$(cat "/sys/class/net/$iface/statistics/rx_bytes")
    tx=$(cat "/sys/class/net/$iface/statistics/tx_bytes")
    printf "CUR|%s|%s|%s\n" "$iface" "$rx" "$tx"
  fi
done

[ -f "$STATE_DIR/interface-counters.tsv" ] && cat "$STATE_DIR/interface-counters.tsv" || true
REMOTE

awk -F'|' '$1 == "CUR" { print $2 "|" $3 "|" $4 }' "$STATE_FILE" > "$CURRENT_COUNTERS"
awk -F'|' '$1 != "CUR" && NF == 4 { print $0 }' "$STATE_FILE" > "$HISTORY_COUNTERS"

TODAY="$(awk -F= '/^TODAY=/{print $2}' "$STATE_FILE")"

router_ssh '/opt/bin/tailscale status --json 2>/dev/null || printf "{}\n"' > "$CURRENT_TAILSCALE"
router_ssh "STATE_DIR=\$( [ -x /opt/bin/opkg ] && printf /opt/var/log/router_configuration || printf /jffs/addons/router_configuration/traffic ); SNAP=\$(ls \"\$STATE_DIR/tailscale\"/${TODAY}T*.json 2>/dev/null | sort | head -1); [ -n \"\$SNAP\" ] && cat \"\$SNAP\" || printf '{}\n'" > "$BASE_TAILSCALE"
router_ssh "STATE_DIR=\$( [ -x /opt/bin/opkg ] && printf /opt/var/log/router_configuration || printf /jffs/addons/router_configuration/traffic ); [ -f \"\$STATE_DIR/lan-device-counters.tsv\" ] && cat \"\$STATE_DIR/lan-device-counters.tsv\" || true" > "$LAN_BYTES_HISTORY"
router_ssh '[ -x /jffs/scripts/lan-device-counters-snapshot ] && /jffs/scripts/lan-device-counters-snapshot 2>/dev/null || true' > "$LAN_BYTES_CURRENT"
router_ssh "STATE_DIR=\$( [ -x /opt/bin/opkg ] && printf /opt/var/log/router_configuration || printf /jffs/addons/router_configuration/traffic ); [ -f \"\$STATE_DIR/mobile-reality-counters.tsv\" ] && cat \"\$STATE_DIR/mobile-reality-counters.tsv\" || true" > "$MOBILE_BYTES_HISTORY"
router_ssh '[ -x /jffs/scripts/mobile-reality-counters-snapshot ] && /jffs/scripts/mobile-reality-counters-snapshot 2>/dev/null || true' > "$MOBILE_BYTES_CURRENT"
router_ssh 'TODAY="$(date +%Y-%m-%d)"; LOG="/opt/var/log/sing-box.log"; [ -f "$LOG" ] && grep " $TODAY " "$LOG" | grep -E "inbound/vless\\[reality-in\\]|outbound/(vless\\[reality-out\\]|direct\\[direct-out\\])" || true' > "$MOBILE_LOG"

iface_current() {
  local iface="$1"
  local column="$2"
  awk -F'|' -v iface="$iface" -v column="$column" '$1 == iface { print $column }' "$CURRENT_COUNTERS"
}

iface_base_pair() {
  local iface="$1"
  awk -F'|' -v today="$TODAY" -v iface="$iface" '$1 ~ ("^" today) && $2 == iface { print $3 "|" $4; exit }' "$HISTORY_COUNTERS"
}

REPORT_START="$(awk -F'|' -v today="$TODAY" '$1 ~ ("^" today) { print $1; exit }' "$HISTORY_COUNTERS")"
[ -n "$REPORT_START" ] || REPORT_START="${TODAY} (no samples yet; using current totals)"
LAN_BYTES_START="$(awk -F'|' -v today="$TODAY" '$1 ~ ("^" today) { print $1; exit }' "$LAN_BYTES_HISTORY")"
MOBILE_BYTES_START="$(awk -F'|' -v today="$TODAY" '$1 ~ ("^" today) { print $1; exit }' "$MOBILE_BYTES_HISTORY")"

WAN_RX_NOW="$(iface_current wan0 2)"; WAN_TX_NOW="$(iface_current wan0 3)"
BR0_RX_NOW="$(iface_current br0 2)"; BR0_TX_NOW="$(iface_current br0 3)"
WIFI24_RX_NOW="$(iface_current eth6 2)"; WIFI24_TX_NOW="$(iface_current eth6 3)"
WIFI5_RX_NOW="$(iface_current eth7 2)"; WIFI5_TX_NOW="$(iface_current eth7 3)"

base_pair="$(iface_base_pair wan0)"; WAN_RX_BASE="${base_pair%%|*}"; WAN_TX_BASE="${base_pair##*|}"; [ "$base_pair" = "$WAN_RX_BASE" ] && WAN_RX_BASE=0 WAN_TX_BASE=0
base_pair="$(iface_base_pair br0)"; BR0_RX_BASE="${base_pair%%|*}"; BR0_TX_BASE="${base_pair##*|}"; [ "$base_pair" = "$BR0_RX_BASE" ] && BR0_RX_BASE=0 BR0_TX_BASE=0
base_pair="$(iface_base_pair eth6)"; WIFI24_RX_BASE="${base_pair%%|*}"; WIFI24_TX_BASE="${base_pair##*|}"; [ "$base_pair" = "$WIFI24_RX_BASE" ] && WIFI24_RX_BASE=0 WIFI24_TX_BASE=0
base_pair="$(iface_base_pair eth7)"; WIFI5_RX_BASE="${base_pair%%|*}"; WIFI5_TX_BASE="${base_pair##*|}"; [ "$base_pair" = "$WIFI5_RX_BASE" ] && WIFI5_RX_BASE=0 WIFI5_TX_BASE=0

WAN_RX="$(delta_or_current "${WAN_RX_NOW:-0}" "${WAN_RX_BASE:-0}")"
WAN_TX="$(delta_or_current "${WAN_TX_NOW:-0}" "${WAN_TX_BASE:-0}")"
BR0_RX="$(delta_or_current "${BR0_RX_NOW:-0}" "${BR0_RX_BASE:-0}")"
BR0_TX="$(delta_or_current "${BR0_TX_NOW:-0}" "${BR0_TX_BASE:-0}")"
WIFI24_RX="$(delta_or_current "${WIFI24_RX_NOW:-0}" "${WIFI24_RX_BASE:-0}")"
WIFI24_TX="$(delta_or_current "${WIFI24_TX_NOW:-0}" "${WIFI24_TX_BASE:-0}")"
WIFI5_RX="$(delta_or_current "${WIFI5_RX_NOW:-0}" "${WIFI5_RX_BASE:-0}")"
WIFI5_TX="$(delta_or_current "${WIFI5_TX_NOW:-0}" "${WIFI5_TX_BASE:-0}")"

WAN_TOTAL=$(( WAN_RX + WAN_TX ))
BR0_TOTAL=$(( BR0_RX + BR0_TX ))
WIFI_RX_TOTAL=$(( WIFI24_RX + WIFI5_RX ))
WIFI_TX_TOTAL=$(( WIFI24_TX + WIFI5_TX ))
WIFI_TOTAL=$(( WIFI_RX_TOTAL + WIFI_TX_TOTAL ))

if [ -n "$LAN_BYTES_START" ] && [ -s "$LAN_BYTES_CURRENT" ]; then
  awk -F'|' -v ts="$LAN_BYTES_START" '
    $1 == ts { print $2 "|" $3 "|" $4 "|" $5 "|" $6 "|" $7 "|" $8 "|" $9 }
  ' "$LAN_BYTES_HISTORY" > "$LAN_BYTES_BASE"

  awk -F'|' '
    function delta(current, base) {
      current += 0
      base += 0
      return current >= base ? current - base : current
    }
    NR == FNR {
      host[$1] = $2
      reality_up[$1] = $3 + 0
      reality_down[$1] = $4 + 0
      wan_up[$1] = $5 + 0
      wan_down[$1] = $6 + 0
      other_up[$1] = $7 + 0
      other_down[$1] = $8 + 0
      seen[$1] = 1
      next
    }
    {
      ip = $1
      current_host[ip] = $2
      creality_up[ip] = $3 + 0
      creality_down[ip] = $4 + 0
      cwan_up[ip] = $5 + 0
      cwan_down[ip] = $6 + 0
      cother_up[ip] = $7 + 0
      cother_down[ip] = $8 + 0
      seen[ip] = 1
    }
    END {
      for (ip in seen) {
        label = current_host[ip]
        if (label == "" || label == "?") label = host[ip]
        if (label == "" || label == "?") label = ip

        rup = delta(creality_up[ip], reality_up[ip])
        rdown = delta(creality_down[ip], reality_down[ip])
        wup = delta(cwan_up[ip], wan_up[ip])
        wdown = delta(cwan_down[ip], wan_down[ip])
        oup = delta(cother_up[ip], other_up[ip])
        odown = delta(cother_down[ip], other_down[ip])

        rtotal = rup + rdown
        wtotal = wup + wdown
        ototal = oup + odown
        upload = rup + wup + oup
        download = rdown + wdown + odown
        total = upload + download

        printf "%s|%s|%d|%d|%d|%d|%d|%d\n",
          ip, label, rtotal, wtotal, ototal, upload, download, total
      }
    }' "$LAN_BYTES_BASE" "$LAN_BYTES_CURRENT" | sort -t'|' -k8,8nr -k1,1V > "$LAN_BYTES_PARSED"
else
  : > "$LAN_BYTES_PARSED"
fi

device_labels_build_map "$DEVICE_METADATA_MAP" "$DEVICE_METADATA_FILE"
apply_device_metadata
redact_report_tables

if [ -s "$LAN_BYTES_PARSED" ]; then
  awk -F'|' '
    {
      total += $8 + 0
      reality += $3 + 0
      wan += $4 + 0
      other += $5 + 0
      devices++
    }
    END {
      printf "%d|%d|%d|%d|%d\n", total, reality, wan, other, devices
    }
  ' "$LAN_BYTES_PARSED" > "$DEVICE_MIX_TOTALS"
  sort -t'|' -k3,3nr -k8,8nr "$LAN_BYTES_PARSED" | awk -F'|' '$3 > 0 { print }' > "$DEVICE_TOP_REALITY"
  sort -t'|' -k4,4nr -k8,8nr "$LAN_BYTES_PARSED" | awk -F'|' '$4 > 0 { print }' > "$DEVICE_TOP_WAN"
else
  : > "$DEVICE_MIX_TOTALS"
  : > "$DEVICE_TOP_REALITY"
  : > "$DEVICE_TOP_WAN"
fi

if [ -s "$MOBILE_LOG" ]; then
  awk -v totals="$MOBILE_TOTALS" -v clients_out="$MOBILE_CLIENTS" -v dests_out="$MOBILE_DESTS" '
    function conn_id(line,   start, body, parts) {
      if (match(line, /\[[0-9]+ [^]]+\]/)) {
        body = substr(line, RSTART + 1, RLENGTH - 2)
        split(body, parts, " ")
        return parts[1]
      }
      return ""
    }
    function human_dest(dest,   d) {
      d = dest
      sub(/:[0-9]+$/, "", d)
      return d
    }
    {
      id = conn_id($0)
      if (id == "") next

      if ($0 ~ /inbound\/vless\[reality-in\]: \[[^]]+\] inbound connection to /) {
        client = $0
        sub(/^.*inbound\/vless\[reality-in\]: \[/, "", client)
        sub(/\].*$/, "", client)

        dest = $0
        sub(/^.* inbound connection to /, "", dest)

        seen[id] = 1
        client_by_id[id] = client
        dest_by_id[id] = dest
        next
      }

      if ($0 ~ /inbound\/vless\[reality-in\]: process connection from .*: EOF/) {
        mobile_errors++
        next
      }

      if ($0 ~ /outbound\/vless\[reality-out\]: outbound connection to / && (id in seen)) {
        outbound_by_id[id] = "reality"
        next
      }

      if ($0 ~ /outbound\/direct\[direct-out\]: outbound connection to / && (id in seen)) {
        outbound_by_id[id] = "direct"
        next
      }
    }
    END {
      for (id in seen) {
        client = client_by_id[id]
        dest = human_dest(dest_by_id[id])
        outbound = outbound_by_id[id]
        if (outbound == "") outbound = "unresolved"

        total++
        clients[client] = 1
        client_total[client]++
        dest_total[dest]++

        if (outbound == "reality") {
          reality++
          client_reality[client]++
          dest_reality[dest]++
        } else if (outbound == "direct") {
          direct++
          client_direct[client]++
          dest_direct[dest]++
        } else {
          unresolved++
          client_unresolved[client]++
          dest_unresolved[dest]++
        }
      }

      client_count = 0
      for (client in clients) client_count++
      printf "%d|%d|%d|%d|%d|%d\n", total + 0, reality + 0, direct + 0, unresolved + 0, mobile_errors + 0, client_count + 0 > totals

      for (client in clients) {
        printf "%s|%d|%d|%d|%d\n", client, client_total[client] + 0, client_reality[client] + 0, client_direct[client] + 0, client_unresolved[client] + 0 >> clients_out
      }

      for (dest in dest_total) {
        printf "%s|%d|%d|%d|%d\n", dest, dest_total[dest] + 0, dest_reality[dest] + 0, dest_direct[dest] + 0, dest_unresolved[dest] + 0 >> dests_out
      }
    }
  ' "$MOBILE_LOG"

  [ -s "$MOBILE_CLIENTS" ] && sort -t'|' -k2,2nr -k1,1 "$MOBILE_CLIENTS" -o "$MOBILE_CLIENTS"
  [ -s "$MOBILE_DESTS" ] && sort -t'|' -k2,2nr -k1,1 "$MOBILE_DESTS" -o "$MOBILE_DESTS"
else
  printf '0|0|0|0|0|0\n' > "$MOBILE_TOTALS"
  : > "$MOBILE_CLIENTS"
  : > "$MOBILE_DESTS"
fi

if [ -n "$MOBILE_BYTES_START" ] && [ -s "$MOBILE_BYTES_CURRENT" ]; then
  awk -F'|' -v ts="$MOBILE_BYTES_START" '
    $1 == ts { print $2 "|" $3 "|" $4 "|" $5 }
  ' "$MOBILE_BYTES_HISTORY" > "$MOBILE_BYTES_BASE"

  awk -F'|' '
    function delta(current, base) {
      current += 0
      base += 0
      return current >= base ? current - base : current
    }
    NR == FNR {
      label[$1] = $2
      upload[$1] = $3 + 0
      download[$1] = $4 + 0
      seen[$1] = 1
      next
    }
    {
      ip = $1
      current_label[ip] = $2
      current_upload[ip] = $3 + 0
      current_download[ip] = $4 + 0
      seen[ip] = 1
    }
    END {
      for (ip in seen) {
        out_label = current_label[ip]
        if (out_label == "") out_label = label[ip]
        if (out_label == "") out_label = "remote:" ip

        up = delta(current_upload[ip], upload[ip])
        down = delta(current_download[ip], download[ip])
        total = up + down
        printf "%s|%s|%d|%d|%d\n", ip, out_label, up, down, total
      }
    }' "$MOBILE_BYTES_BASE" "$MOBILE_BYTES_CURRENT" | sort -t'|' -k5,5nr -k1,1V > "$MOBILE_BYTES_PARSED"
else
  : > "$MOBILE_BYTES_PARSED"
fi

if [ -s "$MOBILE_BYTES_PARSED" ]; then
  awk -F'|' '
    BEGIN { OFS = "|" }
    {
      label = $2
      if (label == "") label = $1
      upload[label] += $3 + 0
      download[label] += $4 + 0
      total[label] += $5 + 0
    }
    END {
      for (label in total) {
        print label, label, upload[label], download[label], total[label]
      }
    }' "$MOBILE_BYTES_PARSED" | sort -t'|' -k5,5nr -k1,1 > "$MOBILE_BYTES_PARSED.aggregated"
  mv "$MOBILE_BYTES_PARSED.aggregated" "$MOBILE_BYTES_PARSED"
fi

if [ -s "$MOBILE_BYTES_PARSED" ]; then
  awk -F'|' '
    {
      upload += $3 + 0
      download += $4 + 0
      total += $5 + 0
      sources++
    }
    END {
      printf "%d|%d|%d|%d\n", total, upload, download, sources
    }' "$MOBILE_BYTES_PARSED" > "$MOBILE_BYTES_TOTALS"
else
  : > "$MOBILE_BYTES_TOTALS"
fi

ruby -rjson -e '
  current = JSON.parse(File.read(ARGV[0]))
  base = JSON.parse(File.read(ARGV[1]))
  base_peers = {}
  (base["Peer"] || {}).each_value do |peer|
    next unless peer["ID"]
    base_peers[peer["ID"]] = {
      "rx" => (peer["RxBytes"] || 0).to_i,
      "tx" => (peer["TxBytes"] || 0).to_i
    }
  end

  peers = (current["Peer"] || {}).values
  peers.sort_by { |peer| peer["DNSName"].to_s }.each do |peer|
    id = peer["ID"]
    base_rx = base_peers.dig(id, "rx").to_i
    base_tx = base_peers.dig(id, "tx").to_i
    cur_rx = (peer["RxBytes"] || 0).to_i
    cur_tx = (peer["TxBytes"] || 0).to_i
    delta_rx = cur_rx >= base_rx ? cur_rx - base_rx : cur_rx
    delta_tx = cur_tx >= base_tx ? cur_tx - base_tx : cur_tx

    name = peer["DNSName"].to_s.sub(/\.$/, "").sub(/\.tail.*$/, "")
    name = peer["HostName"].to_s if name.empty?
    puts [name, peer["Online"], delta_rx, delta_tx, peer["LastSeen"].to_s].join("|")
  end
' "$CURRENT_TAILSCALE" "$BASE_TAILSCALE" > "$TAILSCALE_PARSED"

TAILSCALE_RX_TOTAL="$(awk -F'|' '{ sum += ($3 + 0) } END { print sum + 0 }' "$TAILSCALE_PARSED")"
TAILSCALE_TX_TOTAL="$(awk -F'|' '{ sum += ($4 + 0) } END { print sum + 0 }' "$TAILSCALE_PARSED")"
TAILSCALE_TOTAL=$(( TAILSCALE_RX_TOTAL + TAILSCALE_TX_TOTAL ))

if [ "$REPORT_REDACT_NAMES" = "1" ] && { [ -s "$MOBILE_CLIENTS" ] || [ -s "$MOBILE_BYTES_PARSED" ]; }; then
  {
    awk -F'|' '$1 != "" { print $1 }' "$MOBILE_CLIENTS"
    awk -F'|' '$2 != "" { print $2 }' "$MOBILE_BYTES_PARSED"
  } | sort -u | awk '
    NF { printf "%s|mobile-client-%02d\n", $1, ++idx }
  ' > "$MOBILE_ALIAS_MAP"

  if [ -s "$MOBILE_CLIENTS" ]; then
    awk -F'|' '
      BEGIN { OFS="|" }
      NR == FNR {
        alias[$1] = $2
        next
      }
      {
        if ($1 in alias) $1 = alias[$1]
        print
      }' "$MOBILE_ALIAS_MAP" "$MOBILE_CLIENTS" > "$MOBILE_CLIENTS.redacted" && mv "$MOBILE_CLIENTS.redacted" "$MOBILE_CLIENTS"
  fi

  if [ -s "$MOBILE_BYTES_PARSED" ]; then
    awk -F'|' '
      BEGIN { OFS="|" }
      NR == FNR {
        alias[$1] = $2
        next
      }
      {
        if ($2 in alias) $2 = alias[$2]
        print
      }' "$MOBILE_ALIAS_MAP" "$MOBILE_BYTES_PARSED" > "$MOBILE_BYTES_PARSED.redacted" && mv "$MOBILE_BYTES_PARSED.redacted" "$MOBILE_BYTES_PARSED"
  fi
fi

ROUTER_WINDOW_LINE="${REPORT_START} -> current router state"
if [ -s "$LAN_BYTES_PARSED" ] && [ -n "$LAN_BYTES_START" ]; then
  DEVICE_WINDOW_LINE="${LAN_BYTES_START} -> current router state"
else
  DEVICE_WINDOW_LINE="n/a (no byte baseline yet)"
fi
if [ -s "$MOBILE_BYTES_PARSED" ] && [ -n "$MOBILE_BYTES_START" ]; then
  MOBILE_WINDOW_LINE="${MOBILE_BYTES_START} -> current router state"
else
  MOBILE_WINDOW_LINE="n/a (no byte baseline yet)"
fi

echo "=== WINDOW ==="
echo "Router-wide window:      ${ROUTER_WINDOW_LINE}"
echo "Per-device byte window:  ${DEVICE_WINDOW_LINE}"
echo "Mobile byte window:      ${MOBILE_WINDOW_LINE}"
echo
echo "=== TOTALS ==="
echo "WAN total:               $(human_gib "$WAN_TOTAL")  (RX $(human_gib "$WAN_RX") / TX $(human_gib "$WAN_TX"))"
if [ -s "$DEVICE_MIX_TOTALS" ]; then
  IFS='|' read -r DEVICE_TOTAL_BYTES DEVICE_REALITY_BYTES DEVICE_WAN_BYTES DEVICE_OTHER_BYTES DEVICE_COUNT < "$DEVICE_MIX_TOTALS"
  echo "Reality-managed total:   $(human_bytes "$DEVICE_REALITY_BYTES")"
else
  echo "Reality-managed total:   n/a"
fi
echo "Wi-Fi total:             $(human_gib "$WIFI_TOTAL")  (RX $(human_gib "$WIFI_RX_TOTAL") / TX $(human_gib "$WIFI_TX_TOTAL"))"
echo "LAN bridge:              $(human_gib "$BR0_TOTAL")  (RX $(human_gib "$BR0_RX") / TX $(human_gib "$BR0_TX"))"
echo "Tailscale total:         $(human_gib "$TAILSCALE_TOTAL")  (RX $(human_gib "$TAILSCALE_RX_TOTAL") / TX $(human_gib "$TAILSCALE_TX_TOTAL"))"
if [ -s "$DEVICE_MIX_TOTALS" ]; then
  echo "Reality share/WAN:       $(human_pct "$DEVICE_REALITY_BYTES" "$WAN_TOTAL")"
else
  echo "Reality share/WAN:       n/a"
fi
echo
echo "=== DEVICE TRAFFIC MIX ==="
if [ -s "$DEVICE_MIX_TOTALS" ]; then
  echo "Devices in byte view:    ${DEVICE_COUNT}"
  echo "Device byte total:       $(human_bytes "$DEVICE_TOTAL_BYTES")"
  echo "Via Reality:             $(human_bytes "$DEVICE_REALITY_BYTES")  ($(human_pct "$DEVICE_REALITY_BYTES" "$DEVICE_TOTAL_BYTES"))"
  echo "Direct WAN:              $(human_bytes "$DEVICE_WAN_BYTES")  ($(human_pct "$DEVICE_WAN_BYTES" "$DEVICE_TOTAL_BYTES"))"
  echo "Other:                   $(human_bytes "$DEVICE_OTHER_BYTES")  ($(human_pct "$DEVICE_OTHER_BYTES" "$DEVICE_TOTAL_BYTES"))"
  echo "Interpretation:          Reality = managed REDIRECT/sing-box flows; Direct WAN = traffic that bypassed REDIRECT."
else
  echo "Devices in byte view:    n/a"
  echo "Device byte total:       n/a"
  echo "Via Reality:             n/a"
  echo "Direct WAN:              n/a"
  echo "Other:                   n/a"
fi
echo
echo "=== TOP BY REALITY ==="
if [ -s "$DEVICE_TOP_REALITY" ]; then
  awk -F'|' '
    function human_bytes(x) {
      x += 0
      if (x >= 1024 * 1024 * 1024) return sprintf("%.2f GiB", x / 1024 / 1024 / 1024)
      if (x >= 1024 * 1024) return sprintf("%.1f MiB", x / 1024 / 1024)
      if (x >= 1024) return sprintf("%.1f KiB", x / 1024)
      return sprintf("%d B", x)
    }
    function pct(part, total) {
      part += 0
      total += 0
      if (total <= 0) return "n/a"
      return sprintf("%.1f%%", (part / total) * 100)
    }
    NR <= 5 {
      printf "  %-30s %10s  (%s of device total)\n", $2, human_bytes($3), pct($3, $8)
    }' "$DEVICE_TOP_REALITY"
else
  echo "  none"
fi
echo
echo "=== TOP BY DIRECT WAN ==="
if [ -s "$DEVICE_TOP_WAN" ]; then
  awk -F'|' '
    function human_bytes(x) {
      x += 0
      if (x >= 1024 * 1024 * 1024) return sprintf("%.2f GiB", x / 1024 / 1024 / 1024)
      if (x >= 1024 * 1024) return sprintf("%.1f MiB", x / 1024 / 1024)
      if (x >= 1024) return sprintf("%.1f KiB", x / 1024)
      return sprintf("%d B", x)
    }
    NR <= 5 {
      printf "  %-30s %10s  (%s of device total)\n", $2, human_bytes($4), ( ($8 + 0) > 0 ? sprintf("%.1f%%", (($4 + 0) / ($8 + 0)) * 100) : "n/a" )
    }' "$DEVICE_TOP_WAN"
else
  echo "  none"
fi
echo
echo "=== TAILSCALE PEERS ==="
printf "%-22s  %-7s  %12s  %12s  %s\n" "Name" "Online" "RX" "TX" "Last seen"
awk -F'|' '
  function human_gib(x) {
    return sprintf("%.2f GiB", x / 1024 / 1024 / 1024);
  }
  {
    last_seen = ($5 == "" ? "-" : $5);
    printf "%-22s  %-7s  %12s  %12s  %s\n", $1, $2, human_gib($3 + 0), human_gib($4 + 0), last_seen;
  }' "$TAILSCALE_PARSED"
echo
echo "=== MOBILE HOME REALITY ==="
if [ -s "$MOBILE_TOTALS" ]; then
  IFS='|' read -r MOBILE_TOTAL MOBILE_REALITY MOBILE_DIRECT MOBILE_UNRESOLVED MOBILE_ERRORS MOBILE_CLIENT_COUNT < "$MOBILE_TOTALS"
  echo "Client profiles seen:    ${MOBILE_CLIENT_COUNT}"
  echo "Mobile connections:      ${MOBILE_TOTAL}"
  if [ -s "$MOBILE_BYTES_TOTALS" ]; then
    IFS='|' read -r MOBILE_BYTE_TOTAL MOBILE_BYTE_UPLOAD MOBILE_BYTE_DOWNLOAD MOBILE_BYTE_SOURCES < "$MOBILE_BYTES_TOTALS"
    echo "Mobile byte sources:     ${MOBILE_BYTE_SOURCES}"
    echo "Mobile byte total:       $(human_bytes "$MOBILE_BYTE_TOTAL")  (upload $(human_bytes "$MOBILE_BYTE_UPLOAD") / download $(human_bytes "$MOBILE_BYTE_DOWNLOAD"))"
  else
    echo "Mobile byte sources:     n/a"
    echo "Mobile byte total:       n/a"
  fi
  echo "Mobile via Reality:      ${MOBILE_REALITY}  ($(human_pct "$MOBILE_REALITY" "$MOBILE_TOTAL"))"
  echo "Mobile direct-out:       ${MOBILE_DIRECT}  ($(human_pct "$MOBILE_DIRECT" "$MOBILE_TOTAL"))"
  echo "Mobile unresolved:       ${MOBILE_UNRESOLVED}"
  echo "Mobile EOF/errors:       ${MOBILE_ERRORS}"
  if [ -s "$MOBILE_CLIENTS" ]; then
    echo
    printf "%-18s  %8s  %8s  %8s  %10s\n" "Client" "Total" "Reality" "Direct" "Unresolved"
    awk -F'|' 'NR <= 10 { printf "%-18s  %8d  %8d  %8d  %10d\n", $1, $2, $3, $4, $5 }' "$MOBILE_CLIENTS"
  fi
  if [ -s "$MOBILE_BYTES_PARSED" ]; then
    echo
    printf "%-18s  %10s  %10s  %10s\n" "Byte source" "Total" "Upload" "Download"
    awk -F'|' '
      function human_bytes(x) {
        x += 0
        if (x >= 1024 * 1024 * 1024) return sprintf("%.2f GiB", x / 1024 / 1024 / 1024)
        if (x >= 1024 * 1024) return sprintf("%.1f MiB", x / 1024 / 1024)
        if (x >= 1024) return sprintf("%.1f KiB", x / 1024)
        return sprintf("%d B", x)
      }
      NR <= 10 { printf "%-18s  %10s  %10s  %10s\n", $2, human_bytes($5), human_bytes($3), human_bytes($4) }
    ' "$MOBILE_BYTES_PARSED"
  fi
  if [ -s "$MOBILE_DESTS" ]; then
    echo
    echo "Top mobile destinations:"
    awk -F'|' 'NR <= 10 { printf "  %-42s %5d  (Reality %d / Direct %d)\n", $1, $2, $3, $4 }' "$MOBILE_DESTS"
  fi
else
  echo "No mobile Home Reality log data for today."
fi
echo
echo "=== LAN DEVICE BYTES ==="
if [ -s "$LAN_BYTES_PARSED" ]; then
  printf "%-8s  %-18s  %10s  %10s  %10s  %10s  %10s  %10s\n" "Device" "Host" "Total" "Reality" "WAN" "Other" "Upload" "Download"
  awk -F'|' '
    function human_bytes(x) {
      x += 0
      if (x >= 1024 * 1024 * 1024) return sprintf("%.2f GiB", x / 1024 / 1024 / 1024)
      if (x >= 1024 * 1024) return sprintf("%.1f MiB", x / 1024 / 1024)
      if (x >= 1024) return sprintf("%.1f KiB", x / 1024)
      return sprintf("%d B", x)
    }
    BEGIN { idx = 0 }
    {
      idx++
      printf "LAN-%-4d  %-18s  %10s  %10s  %10s  %10s  %10s  %10s\n",
        idx, $2, human_bytes($8), human_bytes($3), human_bytes($4), human_bytes($5), human_bytes($6), human_bytes($7)
    }' "$LAN_BYTES_PARSED"
  echo
  echo "Rows above are cumulative byte deltas since ${LAN_BYTES_START}."
else
  echo "No LAN byte baseline for today yet. Wait for the next scheduled snapshot or run cron-traffic-snapshot on the router."
fi
echo
echo "=== NOTES ==="
echo "- Channel A WireGuard is retired; wgs1/wgc1 are intentionally not inspected."
echo "- Reality-managed bytes are mangle-accounted managed REDIRECT flows, not a wgc1 interface counter."
echo "- Mobile Home Reality bytes are encrypted TCP/<home-reality-port> ingress counters by remote source IP; if several profiles share one carrier NAT IP, bytes are shown under a combined source label."
echo "- Mobile Reality/direct split is still log-attributed by connection count/client/outbound; byte counters cover the whole Home Reality tunnel before split."
if [ "$REPORT_REDACT_NAMES" = "1" ]; then
  echo "- LAN hostnames are redacted by default. Use REPORT_REDACT_NAMES=0 for trusted local inspection."
fi
