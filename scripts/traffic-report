  awk -F'|' -v clients_file="$MOBILE_CLIENTS" -v global_total="$MOBILE_TOTAL" -v global_vps="$MOBILE_REALITY" -v global_direct="$MOBILE_DIRECT" '
    function human_bytes(x) {
      x += 0
      if (x >= 1024 * 1024 * 1024) return sprintf("%.2f GiB", x / 1024 / 1024 / 1024)
      if (x >= 1024 * 1024) return sprintf("%.1f MiB", x / 1024 / 1024)
      if (x >= 1024) return sprintf("%.1f KiB", x / 1024)
      return sprintf("%d B", x)
    }
    function pct(part, total) {
      part += 0
      total += 0
      if (total <= 0) return "n/a"
      return sprintf("%.1f%%", (part / total) * 100)
    }
    BEGIN {
      while ((getline line < clients_file) > 0) {
        split(line, fields, "|")
        client_total[fields[1]] = fields[2] + 0
        client_vps[fields[1]] = fields[3] + 0
        client_direct[fields[1]] = fields[4] + 0
      }
      close(clients_file)
    }
    ($5 + 0) > 0 && NR <= 8 {
      label = $2
      bytes = $5 + 0
      if ((label in client_total) && client_total[label] > 0) {
        split_total = client_total[label]
        split_vps = client_vps[label]
        split_direct = client_direct[label]
      } else {
        split_total = global_total + 0
        split_vps = global_vps + 0
        split_direct = global_direct + 0
      }
      vps_bytes = split_total > 0 ? bytes * split_vps / split_total : 0
      direct_bytes = split_total > 0 ? bytes * split_direct / split_total : 0
      printf "%-24s %12s %12s %12s %12s %12s %9s\n", label, human_bytes(bytes), human_bytes($3), human_bytes($4), human_bytes(vps_bytes), human_bytes(direct_bytes), pct(vps_bytes, bytes)
    }' "$MOBILE_BYTES_PARSED"
fi
