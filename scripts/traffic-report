  printf "%-18s %8s %8s %8s %12s %12s %10s\n" "Client/profile" "Conn" "VPS" "Direct" "VPS est." "RU est." "Unresolved"
  awk -F'|' -v mobile_bytes="$MOBILE_BYTE_TOTAL" -v mobile_total="$MOBILE_TOTAL" '
    function human_bytes(x) {
      x += 0
      if (x >= 1024 * 1024 * 1024) return sprintf("%.2f GiB", x / 1024 / 1024 / 1024)
      if (x >= 1024 * 1024) return sprintf("%.1f MiB", x / 1024 / 1024)
      if (x >= 1024) return sprintf("%.1f KiB", x / 1024)
      return sprintf("%d B", x)
    }
    NR <= 8 {
      total = $2 + 0
      vps = $3 + 0
      direct = $4 + 0
      vps_bytes = mobile_total > 0 ? mobile_bytes * vps / mobile_total : 0
      direct_bytes = mobile_total > 0 ? mobile_bytes * direct / mobile_total : 0
      printf "%-18s %8d %8d %8d %12s %12s %10d\n", $1, total, vps, direct, human_bytes(vps_bytes), human_bytes(direct_bytes), $5
