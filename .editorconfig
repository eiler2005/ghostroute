# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Shell + router runtime scripts (BusyBox ash / bash).
[*.{sh,bash,ash}]
indent_size = 2

# Makefiles and TSV catalogs require real tabs.
[Makefile]
indent_style = tab

[*.tsv]
indent_style = tab
trim_trailing_whitespace = false

# Markdown: keep trailing whitespace meaningful (hard line breaks).
[*.md]
trim_trailing_whitespace = false

# Python / Ansible.
[*.{py,yml,yaml,j2}]
indent_size = 2
